{% extends 'portal/layout.html.twig' %}

{% block title %}Kalendář obsazenosti{% endblock %}

{% block content %}
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-gray-900">Kalendář obsazenosti</h1>
    </div>

    <div class="card mb-6">
        <div class="card-body">
            <form method="get" action="{{ path('portal_calendar') }}" class="flex flex-wrap items-end gap-4">
                <input type="hidden" name="year" value="{{ year }}">
                <input type="hidden" name="month" value="{{ month }}">
                <input type="hidden" name="view" value="{{ view }}">
                <div class="flex-1 min-w-[200px]">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Místo</label>
                    <select name="place" class="form-input" data-controller="tom-select" data-tom-select-autosubmit-value="true">
                        <option value="">-- Vyberte místo --</option>
                        <option value="all" {{ selectedPlaceId == 'all' ? 'selected' : '' }}>Všechny</option>
                        {% for place in places %}
                            <option value="{{ place.id }}" {{ selectedPlace and selectedPlace.id.equals(place.id) ? 'selected' : '' }}>
                                {{ place.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="flex-1 min-w-[200px]">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Typ skladu</label>
                    <select name="storage_type" class="form-input" data-controller="tom-select" data-tom-select-autosubmit-value="true">
                        <option value="">-- Vyberte typ skladu --</option>
                        <option value="all" {{ selectedStorageTypeId == 'all' ? 'selected' : '' }}>Všechny</option>
                        {% for storageType in storageTypes %}
                            <option value="{{ storageType.id }}" {{ selectedStorageType and selectedStorageType.id.equals(storageType.id) ? 'selected' : '' }}>
                                {{ storageType.name }} ({{ storageType.getDimensionsInMeters() }})
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </form>
        </div>
    </div>

    {% set filterParams = {place: selectedPlaceId, storage_type: selectedStorageTypeId, year: year, month: month} %}

    <div class="card">
            <div class="card-header bg-gray-50 px-6 py-4 border-b">
                <div class="flex items-center justify-between flex-wrap gap-4">
                    <div class="flex items-center gap-4">
                        <a href="{{ path('portal_calendar', filterParams|merge({year: prevYear, month: prevMonth, view: view})) }}" class="btn btn-ghost btn-sm">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                            </svg>
                        </a>
                        <div class="text-center">
                            <h2 class="text-xl font-semibold text-gray-900">{{ monthName }} {{ year }}</h2>
                            <p class="text-sm text-gray-500">
                                {% if selectedPlace %}
                                    {{ selectedPlace.name }}
                                {% else %}
                                    Všechna místa
                                {% endif %}
                                -
                                {% if selectedStorageType %}
                                    {{ selectedStorageType.name }}
                                {% else %}
                                    Všechny typy
                                {% endif %}
                                - {{ storages|length }} skladů
                            </p>
                        </div>
                        <a href="{{ path('portal_calendar', filterParams|merge({year: nextYear, month: nextMonth, view: view})) }}" class="btn btn-ghost btn-sm">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                    <div class="flex items-center gap-4 flex-wrap">
                        <div class="inline-flex rounded-md shadow-sm" role="group">
                            <a href="{{ path('portal_calendar', filterParams|merge({view: 'month'})) }}"
                               class="px-3 py-1.5 text-sm font-medium border border-gray-300 rounded-l-md {{ view == 'month' ? 'bg-accent text-white border-accent' : 'bg-white text-gray-700 hover:bg-gray-50' }}">Měsíc</a>
                            <a href="{{ path('portal_calendar', filterParams|merge({view: 'timeline'})) }}"
                               class="px-3 py-1.5 text-sm font-medium border border-l-0 border-gray-300 rounded-r-md {{ view == 'timeline' ? 'bg-accent text-white border-accent' : 'bg-white text-gray-700 hover:bg-gray-50' }}">Časová osa</a>
                        </div>
                        <div class="flex items-center gap-4 text-sm">
                            <span class="flex items-center gap-1">
                                <span class="w-3 h-3 rounded-full bg-green-500"></span> Dostupné
                            </span>
                            <span class="flex items-center gap-1">
                                <span class="w-3 h-3 rounded-full bg-red-500"></span> Obsazené
                            </span>
                            <span class="flex items-center gap-1">
                                <span class="w-3 h-3 rounded-full bg-gray-400"></span> Nedostupné
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            {% if view == 'month' %}
            <div class="p-4">
                <div class="grid grid-cols-7 gap-1 text-center mb-2">
                    <div class="text-sm font-semibold text-gray-500 py-2">Po</div>
                    <div class="text-sm font-semibold text-gray-500 py-2">Ut</div>
                    <div class="text-sm font-semibold text-gray-500 py-2">St</div>
                    <div class="text-sm font-semibold text-gray-500 py-2">Čt</div>
                    <div class="text-sm font-semibold text-gray-500 py-2">Pá</div>
                    <div class="text-sm font-semibold text-gray-500 py-2">So</div>
                    <div class="text-sm font-semibold text-gray-500 py-2">Ne</div>
                </div>

                {% set firstDayWeekday = startOfMonth|date('N') %}
                {% set lastDayWeekday = endOfMonth|date('N') %}

                <div class="grid grid-cols-7 gap-1">
                    {# Empty cells for days before the first of month #}
                    {% for i in 1..(firstDayWeekday - 1) %}
                        <div class="h-28 bg-gray-50 rounded"></div>
                    {% endfor %}

                    {# Days of the month #}
                    {% for day in 1..daysInMonth %}
                        {% set dateKey = year ~ '-' ~ (month < 10 ? '0' ~ month : month) ~ '-' ~ (day < 10 ? '0' ~ day : day) %}
                        {% set dayData = calendarData[dateKey] ?? null %}
                        {% set isToday = dateKey == today|date('Y-m-d') %}
                        {% set endsCount = endingToday[dateKey] ?? 0 %}
                        {% set startsCount = startingToday[dateKey] ?? 0 %}
                        {% set details = dayDetails[dateKey] ?? [] %}

                        <details class="relative h-28 border rounded p-2 group {{ isToday ? 'border-accent border-2' : 'border-gray-200' }} hover:bg-gray-50">
                            <summary class="cursor-pointer list-none">
                                <div class="flex justify-between items-start mb-1">
                                    <span class="text-sm font-semibold {{ isToday ? 'text-accent' : 'text-gray-700' }}">{{ day }}</span>
                                    {% if dayData %}
                                        {% set occupancyPercent = dayData.total > 0 ? ((dayData.occupied + dayData.unavailable) / dayData.total * 100)|round : 0 %}
                                        <span class="text-xs px-1.5 py-0.5 rounded {{ occupancyPercent == 100 ? 'bg-red-100 text-red-700' : (occupancyPercent > 50 ? 'bg-yellow-100 text-yellow-700' : 'bg-green-100 text-green-700') }}">
                                            {{ 100 - occupancyPercent }}%
                                        </span>
                                    {% endif %}
                                </div>
                                {% if dayData %}
                                    <div class="space-y-0.5 text-xs">
                                        {% if dayData.available > 0 %}
                                            <div class="flex items-center gap-1">
                                                <span class="w-2 h-2 rounded-full bg-green-500"></span>
                                                <span class="text-green-700">{{ dayData.available }} volných</span>
                                            </div>
                                        {% endif %}
                                        {% if dayData.occupied > 0 %}
                                            <div class="flex items-center gap-1">
                                                <span class="w-2 h-2 rounded-full bg-red-500"></span>
                                                <span class="text-red-700">{{ dayData.occupied }} obsazených</span>
                                            </div>
                                        {% endif %}
                                        {% if dayData.unavailable > 0 %}
                                            <div class="flex items-center gap-1">
                                                <span class="w-2 h-2 rounded-full bg-gray-400"></span>
                                                <span class="text-gray-600">{{ dayData.unavailable }} blokovaných</span>
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endif %}
                                <div class="mt-1 flex flex-wrap gap-1">
                                    {% if endsCount > 0 %}
                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-amber-100 text-amber-800">{{ endsCount }} končí</span>
                                    {% endif %}
                                    {% if startsCount > 0 %}
                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs bg-emerald-100 text-emerald-800">{{ startsCount }} začíná</span>
                                    {% endif %}
                                </div>
                            </summary>
                            {% if details|length > 0 %}
                                <div class="absolute z-20 top-full left-0 mt-1 w-72 bg-white shadow-lg rounded p-3 text-sm border border-gray-200">
                                    {% set endingDetails = details|filter(d => d.kind == 'ending') %}
                                    {% set startingDetails = details|filter(d => d.kind == 'starting') %}
                                    {% if endingDetails|length > 0 %}
                                        <div class="mb-2">
                                            <p class="text-xs font-semibold text-amber-800 uppercase mb-1">Končí</p>
                                            {% for d in endingDetails|slice(0, 5) %}
                                                <div class="text-gray-900">Sklad {{ d.storageNumber }} — {{ d.tenantName ?? '—' }}</div>
                                            {% endfor %}
                                            {% if endingDetails|length > 5 %}
                                                <div class="text-xs text-gray-500">…a dalších {{ endingDetails|length - 5 }}</div>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                    {% if startingDetails|length > 0 %}
                                        <div>
                                            <p class="text-xs font-semibold text-emerald-800 uppercase mb-1">Začíná</p>
                                            {% for d in startingDetails|slice(0, 5) %}
                                                <div class="text-gray-900">Sklad {{ d.storageNumber }} — {{ d.tenantName ?? '—' }}</div>
                                            {% endfor %}
                                            {% if startingDetails|length > 5 %}
                                                <div class="text-xs text-gray-500">…a dalších {{ startingDetails|length - 5 }}</div>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </details>
                    {% endfor %}

                    {# Empty cells for days after the last of month #}
                    {% if lastDayWeekday < 7 %}
                        {% for i in (lastDayWeekday + 1)..7 %}
                            <div class="h-28 bg-gray-50 rounded"></div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
            {% else %}
            <div class="p-4">
                {% if storages|length == 0 %}
                    <p class="text-center text-gray-500 py-8">Pro vybrané filtry nebyly nalezeny žádné sklady.</p>
                {% else %}
                    <div class="hidden md:block overflow-x-auto" data-test="timeline-grid">
                        <div class="grid items-center" style="grid-template-columns: 180px 1fr; gap: 8px;">
                            <div></div>
                            <div class="grid text-xs text-gray-500" style="grid-template-columns: repeat({{ daysInMonth }}, minmax(20px, 1fr));">
                                {% for d in 1..daysInMonth %}
                                    {% set dateKey = year ~ '-' ~ (month < 10 ? '0' ~ month : month) ~ '-' ~ (d < 10 ? '0' ~ d : d) %}
                                    {% set isToday = dateKey == today|date('Y-m-d') %}
                                    <div class="text-center {{ isToday ? 'text-accent font-semibold' : '' }}">{{ d }}</div>
                                {% endfor %}
                            </div>
                        </div>
                        {% for storage in storages %}
                            {% set storageId = storage.id.toRfc4122 %}
                            {% set storageSpans = spans[storageId] ?? [] %}
                            <div class="grid items-center mt-1" style="grid-template-columns: 180px 1fr; gap: 8px;">
                                <div class="text-sm text-gray-900 truncate">
                                    {{ storage.number }} <span class="text-gray-500 text-xs">({{ storage.storageType.name }})</span>
                                </div>
                                <div class="grid relative" style="grid-template-columns: repeat({{ daysInMonth }}, minmax(20px, 1fr));">
                                    {% for d in 1..daysInMonth %}
                                        {% set dayDate = startOfMonth|date_modify('+' ~ (d - 1) ~ ' days') %}
                                        {% set dateKey = dayDate|date('Y-m-d') %}
                                        {% set isToday = dateKey == today|date('Y-m-d') %}
                                        {% set covering = null %}
                                        {% for span in storageSpans %}
                                            {% if covering is null and span.startDate <= dayDate and (span.endDate is null or span.endDate >= dayDate) %}
                                                {% set covering = span %}
                                            {% endif %}
                                        {% endfor %}
                                        {% set color = 'bg-green-100' %}
                                        {% if covering %}
                                            {% if covering.kind.value == 'block' %}
                                                {% set color = 'bg-gray-300' %}
                                            {% else %}
                                                {% set color = 'bg-red-400' %}
                                            {% endif %}
                                        {% endif %}
                                        <div class="h-6 {{ color }} {{ isToday ? 'outline outline-2 outline-accent -outline-offset-1' : '' }}"
                                             title="{% if covering %}{{ covering.tenantName ?? 'Blokováno' }}{% if covering.endDate %} (do {{ covering.endDate|date('d.m.Y') }}){% else %} (neomezeně){% endif %}{% else %}Volný{% endif %}">
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    <div class="md:hidden text-center text-sm text-gray-500 py-8">
                        Pro plánování přepněte na desktop.
                    </div>
                {% endif %}
            </div>
            {% endif %}
        </div>

        {# Storage list below calendar #}
        {% if storages|length > 0 %}
            <div class="card mt-6">
                <div class="card-header bg-gray-50 px-6 py-4 border-b">
                    <h3 class="text-lg font-semibold text-gray-900">Přehled skladů</h3>
                </div>
                <div class="overflow-x-auto">
                    <table class="table table-zebra">
                        <thead>
                            <tr>
                                <th>Číslo</th>
                                <th>Místo</th>
                                <th>Typ</th>
                                <th>Stav</th>
                                <th>Pronajato OD</th>
                                <th>Pronajato DO</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for storage in storages %}
                                {% set storageId = storage.id.toRfc4122 %}
                                {% set rentalView = rentalViews[storageId] ?? null %}
                                <tr>
                                    <td class="font-medium text-gray-900">{{ storage.number }}</td>
                                    <td>{{ storage.place.name }}</td>
                                    <td>{{ storage.storageType.name }}</td>
                                    <td>
                                        {% if storage.status.value == 'available' %}
                                            <span class="badge badge-success">Dostupný</span>
                                        {% elseif storage.status.value == 'reserved' %}
                                            <span class="badge badge-warning">Rezervovaný</span>
                                        {% elseif storage.status.value == 'occupied' %}
                                            <span class="badge badge-error">Obsazený</span>
                                        {% else %}
                                            <span class="badge badge-ghost">Nedostupný</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-gray-700">
                                        {% if rentalView and rentalView.rentedFrom %}
                                            {{ rentalView.rentedFrom|date('d.m.Y') }}
                                        {% else %}
                                            —
                                        {% endif %}
                                    </td>
                                    <td class="text-gray-700">
                                        {% if rentalView and rentalView.isOccupied %}
                                            {% if rentalView.isTerminating %}
                                                <span class="text-amber-700" title="Smlouva je ve výpovědi">
                                                    do {{ rentalView.rentedUntil|date('d.m.Y') }}
                                                    <span aria-hidden="true">⚠</span>
                                                    <span class="sr-only">ukončuje se</span>
                                                </span>
                                            {% elseif rentalView.isUnlimited %}
                                                <span title="Pronájem na dobu neurčitou">neomezeně <span aria-hidden="true">∞</span></span>
                                            {% else %}
                                                do {{ rentalView.rentedUntil|date('d.m.Y') }}
                                            {% endif %}
                                        {% else %}
                                            —
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% else %}
            <div class="card mt-6">
                <div class="card-body text-center py-12">
                    <svg class="mx-auto h-8 w-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                    </svg>
                    <h3 class="mt-4 text-lg font-medium text-gray-900">Žádné sklady</h3>
                    <p class="mt-2 text-sm text-gray-500">Pro vybrané filtry nebyly nalezeny žádné sklady.</p>
                </div>
            </div>
        {% endif %}
{% endblock %}
