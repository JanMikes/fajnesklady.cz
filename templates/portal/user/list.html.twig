{% extends 'portal/layout.html.twig' %}

{% block title %}Uživatelé - Admin{% endblock %}

{% macro sort_header(label, column, sort, dir, search, filter) %}
    {% set is_active = sort == column %}
    {% set next_dir = (is_active and dir == 'asc') ? 'desc' : 'asc' %}
    <th>
        <a href="{{ path('portal_users_list', {q: search, filter: filter, sort: column, dir: next_dir, page: 1}) }}" class="inline-flex items-center gap-1 hover:text-gray-900">
            {{ label }}
            {% if is_active %}
                <span class="text-accent">{{ dir == 'asc' ? '▲' : '▼' }}</span>
            {% endif %}
        </a>
    </th>
{% endmacro %}

{% block content %}
    {% import _self as headers %}

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-gray-900">Uživatelé</h1>
        {% include 'components/excel_export_button.html.twig' with {
            href: path('portal_users_export', app.request.query.all)
        } %}
    </div>

    <form method="get" action="{{ path('portal_users_list') }}" class="mb-4 flex items-center gap-2">
        {% if filter %}<input type="hidden" name="filter" value="{{ filter }}">{% endif %}
        {% if sort %}<input type="hidden" name="sort" value="{{ sort }}">{% endif %}
        {% if dir %}<input type="hidden" name="dir" value="{{ dir }}">{% endif %}
        <input type="search" name="q" value="{{ search }}" placeholder="Hledat jméno, e-mail, telefon…" class="form-input text-sm py-1.5 w-72" autocomplete="off">
        <button type="submit" class="btn btn-sm btn-primary">Hledat</button>
        {% if search %}
            <a href="{{ path('portal_users_list', filter ? {filter: filter} : {}) }}" class="btn btn-sm btn-ghost" title="Zrušit hledání">×</a>
        {% endif %}
    </form>

    <div class="mb-2 flex items-center gap-2 flex-wrap">
        <a href="{{ path('portal_users_list', {q: search}) }}" class="btn btn-sm {{ filter ? 'btn-ghost' : 'btn-primary' }}">Vše</a>
        <a href="{{ path('portal_users_list', {q: search, filter: 'overdue'}) }}" class="btn btn-sm {{ filter == 'overdue' ? 'btn-error' : 'btn-ghost' }}">
            Pouze dlužníci ({{ overdueUserCount }})
        </a>
        <a href="{{ path('portal_users_list', {q: search, filter: 'onboarded'}) }}" class="btn btn-sm {{ filter == 'onboarded' ? 'btn-secondary' : 'btn-ghost' }}">
            Pouze onboardovaní ({{ onboardedUserCount }})
        </a>
        <a href="{{ path('portal_users_list', {q: search, filter: 'active'}) }}" class="btn btn-sm {{ filter == 'active' ? 'btn-success' : 'btn-ghost' }}">
            S aktivními smlouvami ({{ activeUserCount }})
        </a>
        <a href="{{ path('portal_users_list', {q: search, filter: 'inactive'}) }}" class="btn btn-sm {{ filter == 'inactive' ? 'btn-warning' : 'btn-ghost' }}">
            Bez aktivních smluv ({{ inactiveUserCount }})
        </a>
        <a href="{{ path('portal_users_list', {q: search, filter: 'unverified'}) }}" class="btn btn-sm {{ filter == 'unverified' ? 'btn-accent' : 'btn-ghost' }}">
            Neověření ({{ unverifiedUserCount }})
        </a>
    </div>
    <p class="text-xs text-gray-400 mb-4">Počty u filtrů jsou celkové; hledání zužuje pouze tabulku.</p>

    <div class="card">
        <div class="overflow-x-auto">
            <table class="table table-zebra">
                <thead>
                    <tr>
                        {{ headers.sort_header('Jméno', 'name', sort, dir, search, filter) }}
                        {{ headers.sort_header('Email', 'email', sort, dir, search, filter) }}
                        <th>Role</th>
                        <th>Stav</th>
                        {{ headers.sort_header('Smlouvy', 'contracts', sort, dir, search, filter) }}
                        {{ headers.sort_header('MRR', 'mrr', sort, dir, search, filter) }}
                        {{ headers.sort_header('YRR', 'yrr', sort, dir, search, filter) }}
                        {{ headers.sort_header('Vytvořeno', 'created', sort, dir, search, filter) }}
                        <th>Akce</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in rows %}
                        <tr>
                            <td>
                                <div class="flex items-center space-x-3">
                                    <div class="flex-shrink-0 h-10 w-10 rounded-full bg-gray-600 text-white flex items-center justify-center font-medium text-sm">
                                        {{ row.fullName|first|upper }}
                                    </div>
                                    <div class="font-medium text-gray-900">{{ row.fullName }}</div>
                                </div>
                            </td>
                            <td class="text-gray-500">{{ row.email }}</td>
                            <td>
                                <div class="flex flex-wrap gap-1">
                                    {% for role in row.roles %}
                                        {% if role != 'ROLE_USER' %}
                                            <span class="badge badge-primary">{{ role|role_label }}</span>
                                        {% else %}
                                            <span class="badge badge-secondary">{{ role|role_label }}</span>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </td>
                            <td>
                                <div class="flex flex-wrap gap-1">
                                    {% if row.isDeactivated %}
                                        <span class="badge badge-error">Deaktivován</span>
                                    {% elseif row.isVerified %}
                                        <span class="badge badge-success">
                                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                            </svg>
                                            Ověřený
                                        </span>
                                    {% else %}
                                        <span class="badge badge-warning">Neověřený</span>
                                    {% endif %}
                                    {% if row.isOverdue %}
                                        <span class="badge badge-error" title="Smlouva po splatnosti">
                                            <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l6.518 11.59c.75 1.335-.213 2.98-1.742 2.98H3.481c-1.53 0-2.493-1.645-1.743-2.98L8.257 3.099zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                                            </svg>
                                            Dlužník
                                        </span>
                                    {% endif %}
                                    {% if row.isOnboarded %}
                                        <span class="badge badge-secondary" title="Zákazník byl onboardován adminem">Onboardovaný</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="text-sm">
                                {% if row.totalCount == 0 %}
                                    <span class="text-gray-400">—</span>
                                {% else %}
                                    <span class="font-medium text-gray-900">{{ row.activeCount }}</span>
                                    <span class="text-gray-500">aktivních</span>
                                    <span class="text-gray-400 text-xs">· {{ row.totalCount }} celkem</span>
                                {% endif %}
                            </td>
                            <td class="text-sm">
                                {% if row.mrrInHaler == 0 %}
                                    <span class="text-gray-400">—</span>
                                {% else %}
                                    <span class="font-medium text-gray-900">{{ (row.mrrInHaler / 100)|number_format(0, ',', ' ') }}</span>
                                    <span class="text-gray-500">Kč/měs</span>
                                {% endif %}
                            </td>
                            <td class="text-sm">
                                {% if row.yrrInHaler == 0 %}
                                    <span class="text-gray-400">—</span>
                                {% else %}
                                    <span class="font-medium text-gray-900">{{ (row.yrrInHaler / 100)|number_format(0, ',', ' ') }}</span>
                                    <span class="text-gray-500">Kč/rok</span>
                                {% endif %}
                            </td>
                            <td class="text-gray-500 text-sm">{{ row.createdAt|date('d.m.Y H:i') }}</td>
                            <td>
                                <div class="flex gap-2">
                                    <a href="{{ path('portal_users_view', {id: row.id}) }}" class="inline-flex items-center link text-sm font-medium">
                                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                        </svg>
                                        Zobrazit
                                    </a>
                                    {% if not row.isVerified %}
                                        <form action="{{ path('portal_users_verify', {id: row.id}) }}" method="post" class="inline">
                                            <button type="submit" class="btn btn-xs btn-success">Ověřit</button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="9" class="text-center text-gray-500 py-8">Žádní uživatelé neodpovídají hledání.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if totalPages > 1 %}
            {% include 'components/pagination.html.twig' with {
                currentPage: currentPage,
                totalPages: totalPages,
                totalItems: totalUsers,
                itemLabel: 'uživatelů',
                route: 'portal_users_list',
                routeParams: {q: search, filter: filter, sort: sort, dir: dir},
            } %}
        {% endif %}
    </div>
{% endblock %}
