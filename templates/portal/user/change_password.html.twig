{% extends 'portal/layout.html.twig' %}

{% block title %}Změnit heslo uživatele - Admin{% endblock %}

{% block breadcrumb %}
    {% include 'components/breadcrumb.html.twig' with {breadcrumb_items: [
        {label: 'Uživatelé', url: path('portal_users_list')},
        {label: user.fullName, url: path('portal_users_view', {id: user.id})},
        {label: 'Změnit heslo'},
    ]} %}
{% endblock %}

{% block content %}
    <h1 class="text-3xl font-bold mb-2">Změnit heslo uživatele</h1>
    <p class="text-gray-600 mb-6">Po uložení bude uživateli odeslán e-mail s upozorněním, že jeho heslo bylo změněno administrátorem.</p>

    <div class="max-w-2xl">
        <div class="card mb-6">
            <div class="card-body">
                <div class="flex items-center gap-4">
                    <div class="flex-shrink-0">
                        <div class="bg-gray-600 text-white rounded-full w-16 h-16 flex items-center justify-center">
                            <span class="text-xl font-semibold">{{ user.fullName|first|upper }}</span>
                        </div>
                    </div>
                    <div>
                        <h2 class="text-xl font-bold text-gray-900">{{ user.fullName }}</h2>
                        <p class="text-gray-600">{{ user.email }}</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                {{ form_start(form) }}
                    <div class="mb-4">
                        {{ form_label(form.newPassword.first) }}
                        {{ form_widget(form.newPassword.first) }}
                        {{ form_errors(form.newPassword.first) }}
                    </div>
                    <div class="mb-6">
                        {{ form_label(form.newPassword.second) }}
                        {{ form_widget(form.newPassword.second) }}
                        {{ form_errors(form.newPassword.second) }}
                    </div>

                    <div class="flex justify-end gap-2">
                        <a href="{{ path('portal_users_view', {id: user.id}) }}" class="btn btn-ghost">Zrušit</a>
                        <button type="submit" class="btn btn-primary">Uložit nové heslo</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
