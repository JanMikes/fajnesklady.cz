{% extends 'portal/layout.html.twig' %}

{% block title %}Detail objednávky - Portal{% endblock %}

{% block breadcrumb %}
    {% include 'components/breadcrumb.html.twig' with {breadcrumb_items: [
        {label: 'Objednávky', url: path('portal_user_orders')},
        {label: 'Detail'},
    ]} %}
{% endblock %}

{% block content %}
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Detail objednávky</h1>
        <div class="flex items-center space-x-3">
            {% set statusClass = {
                'created': 'bg-gray-100 text-gray-800',
                'reserved': 'bg-yellow-100 text-yellow-800',
                'awaiting_payment': 'bg-amber-100 text-amber-800',
                'paid': 'bg-green-100 text-green-800',
                'completed': 'bg-green-100 text-green-800',
                'cancelled': 'bg-red-100 text-red-800',
                'expired': 'bg-gray-100 text-gray-800'
            } %}
            {% set statusLabel = {
                'created': 'Vytvořeno',
                'reserved': 'Rezervováno',
                'awaiting_payment': 'Čeká na platbu',
                'paid': 'Zaplaceno',
                'completed': 'Dokončeno',
                'cancelled': 'Zrušeno',
                'expired': 'Expirováno'
            } %}
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium {{ statusClass[order.status.value] ?? 'bg-gray-100 text-gray-800' }}">
                {{ statusLabel[order.status.value] ?? order.status.value }}
            </span>
            {% if contract %}
                {% set isContractActive = contract.terminatedAt is null and (contract.endDate is null or contract.endDate >= now) %}
                {% if contract.terminatedAt %}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">
                        Smlouva ukončena
                    </span>
                {% elseif isContractActive %}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                        Smlouva aktivní
                    </span>
                {% endif %}
            {% endif %}
        </div>
    </div>

    {# Renewal CTA — visible whenever there's a finished limited rental.
       Wording adapts to remaining days / past expiry. #}
    {% set canRenew = order.status.value in ['paid', 'completed']
        and order.rentalType.value == 'limited'
        and order.endDate is not null %}

    {% if canRenew %}
        {% set isExpiringSoon = daysRemaining is not null and daysRemaining <= 14 and daysRemaining > 0 and contract is not null and contract.terminatedAt is null %}
        {% set hasExpired = daysRemaining is not null and daysRemaining <= 0 %}

        <div class="mb-6 rounded-lg border p-4
                    {% if isExpiringSoon or hasExpired %}bg-yellow-50 border-yellow-200{% else %}bg-green-50 border-green-200{% endif %}">
            <div class="flex items-start justify-between gap-4 flex-wrap">
                <div>
                    <h3 class="text-sm font-semibold {% if isExpiringSoon or hasExpired %}text-yellow-800{% else %}text-green-800{% endif %}">
                        {% if hasExpired %}
                            Smlouva skončila
                        {% elseif isExpiringSoon %}
                            Smlouva brzy končí
                        {% else %}
                            Pokračovat v pronájmu?
                        {% endif %}
                    </h3>
                    <p class="mt-1 text-sm {% if isExpiringSoon or hasExpired %}text-yellow-700{% else %}text-green-700{% endif %}">
                        Stačí jeden klik — všechny údaje doplníme za Vás. Stejný sklad (pokud bude volný), stejné období, stejné fakturační údaje.
                    </p>
                </div>
                <a href="{{ path('public_order_renew', {previousOrderId: order.id}) }}"
                   class="btn btn-primary whitespace-nowrap">
                    Prodloužit pronájem
                </a>
            </div>
        </div>
    {% endif %}

    {% include 'components/order_access_code.html.twig' with {storage: storage, contract: contract} only %}

    {# Own-padlock reminder — insurance is conditional on it, so keep it
       visible alongside the access code customers come here to look up. #}
    {% if contract %}
        <div class="mt-6">
            {% include 'components/lock_disclaimer.html.twig' %}
        </div>
    {% endif %}

    {% include 'components/customer_billing_status.html.twig' with {
        contract: contract,
        now: now,
        manualNowUrl: manualNowUrl,
        manualNowAmount: manualNowAmount,
        manualNowPeriodStart: manualNowPeriodStart,
        nextManualDate: nextManualDate,
    } only %}

    {% if handoverProtocol %}
        {% include 'components/handover_banner.html.twig' with {
            protocol: handoverProtocol,
            actor: 'tenant',
            viewUrl: path('portal_user_handover_view', {id: handoverProtocol.id}),
        } only %}
    {% endif %}

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
        {# Order Details #}
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
                <h3 class="text-lg font-medium text-gray-900">Informace o objednávce</h3>
            </div>
            <div class="px-4 py-5 sm:p-6">
                <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Číslo objednávky</dt>
                        <dd class="mt-1 text-sm text-gray-900 font-mono">{{ order.id|slice(0, 8)|upper }}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Typ pronájmu</dt>
                        <dd class="mt-1 text-sm text-gray-900">
                            {% if order.rentalType.value == 'limited' %}
                                Na dobu určitou
                            {% else %}
                                Na dobu neurčitou
                            {% endif %}
                        </dd>
                    </div>
                    {% if order.expectedDuration %}
                        <div>
                            <dt class="text-sm font-medium text-gray-500">Předpokládaná doba pronájmu</dt>
                            <dd class="mt-1 text-sm text-gray-900">{{ order.expectedDuration.label }}</dd>
                        </div>
                    {% endif %}
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Datum začátku</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ order.startDate|date('d.m.Y') }}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Datum konce</dt>
                        <dd class="mt-1 text-sm text-gray-900">
                            {% if order.endDate %}
                                {{ order.endDate|date('d.m.Y') }}
                                {% if contract and daysRemaining is not null and contract.terminatedAt is null %}
                                    <span class="text-gray-500">({{ daysRemaining }} {{ daysRemaining == 1 ? 'den' : (daysRemaining < 5 ? 'dny' : 'dni') }})</span>
                                {% endif %}
                            {% else %}
                                Na dobu neurčitou
                            {% endif %}
                        </dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">{{ order.isRecurring ? 'Měsíční platba' : 'Celková cena' }}</dt>
                        <dd class="mt-1 text-sm text-gray-900 font-semibold">{{ (order.firstPaymentPrice / 100)|number_format(2, ',', ' ') }} Kč{% if order.isRecurring %} / měsíc{% endif %}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Vytvořeno</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ order.createdAt|date('d.m.Y H:i') }}</dd>
                    </div>
                    {% if order.paidAt %}
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Zaplaceno</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ order.paidAt|date('d.m.Y H:i') }}</dd>
                    </div>
                    {% endif %}
                    {% if order.expiresAt %}
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Expirace</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ order.expiresAt|date('d.m.Y H:i') }}</dd>
                    </div>
                    {% endif %}
                </dl>
            </div>
        </div>

        {# Storage Details #}
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
                <h3 class="text-lg font-medium text-gray-900">Skladová jednotka</h3>
            </div>
            <div class="px-4 py-5 sm:p-6">
                <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Typ skladu</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ storageType.name }}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Číslo jednotky</dt>
                        <dd class="mt-1 text-sm text-gray-900 font-semibold">{{ storage.number }}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Rozměry</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ storageType.dimensionsInMeters }}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Pobočka</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ place.name }}</dd>
                    </div>
                    <div class="sm:col-span-2">
                        <dt class="text-sm font-medium text-gray-500">Adresa</dt>
                        <dd class="mt-1 text-sm text-gray-900">
                            {% include 'components/place_address.html.twig' with {place: place} only %}
                        </dd>
                    </div>
                </dl>
            </div>
        </div>
    </div>

    {# Contract Details - show for completed orders with contract #}
    {% if contract %}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">Smlouva</h3>
        </div>
        <div class="px-4 py-5 sm:p-6">
            <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2 lg:grid-cols-4">
                <div>
                    <dt class="text-sm font-medium text-gray-500">Číslo smlouvy</dt>
                    <dd class="mt-1 text-sm text-gray-900 font-mono">{{ contract.id|slice(0, 8)|upper }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500">Vytvořeno</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ contract.createdAt|date('d.m.Y H:i') }}</dd>
                </div>
                {% if contract.signedAt %}
                <div>
                    <dt class="text-sm font-medium text-gray-500">Podepsáno</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ contract.signedAt|date('d.m.Y H:i') }}</dd>
                </div>
                {% endif %}
                {% if contract.terminatedAt %}
                <div>
                    <dt class="text-sm font-medium text-gray-500">Ukončeno</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ contract.terminatedAt|date('d.m.Y H:i') }}</dd>
                </div>
                {% endif %}
            </dl>
        </div>
    </div>
    {% endif %}

    {# Documents — unified panel shown once the order is paid #}
    {% if order.status.value in ['paid', 'completed'] %}
    <div id="dokumenty" class="mt-6">
        {% include 'components/order_documents.html.twig' with {order, contract, invoices, place, handoverProtocol} only %}
    </div>
    {% endif %}

    {# Termination Section for Unlimited Contracts #}
    {% if canTerminate %}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg border border-red-200">
        <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-red-900">Ukončit smlouvu</h3>
            <p class="mt-1 text-sm text-gray-600">
                Smlouvu na dobu neurčitou můžete kdykoliv ukončit. Po ukončení bude skladová jednotka uvolněna.
            </p>
            <div class="mt-4">
                <form action="{{ path('portal_user_contract_terminate', {id: contract.id}) }}" method="post" onsubmit="return confirm('Opravdu chcete ukončit tuto smlouvu? Tato akce je nevratná.');">
                    <button type="submit" class="inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50">
                        <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        Ukončit smlouvu
                    </button>
                </form>
            </div>
        </div>
    </div>
    {% endif %}

    {# Cancel Order Section #}
    {% if order.canBeCancelled() %}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg border border-red-200">
        <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-red-900">Zrušit objednávku</h3>
            <p class="mt-1 text-sm text-gray-600">
                Objednávku můžete zrušit, dokud nebyla zaplacena. Po zrušení bude skladová jednotka uvolněna.
            </p>
            <div class="mt-4">
                <form action="{{ path('portal_user_order_cancel', {id: order.id}) }}" method="post" onsubmit="return confirm('Opravdu chcete zrušit tuto objednávku? Tato akce je nevratná.');">
                    <button type="submit" class="inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50">
                        <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        Zrušit objednávku
                    </button>
                </form>
            </div>
        </div>
    </div>
    {% endif %}

    {% if order.status.value == 'created' %}
    <div class="mt-6 flex justify-end">
        <a href="{{ path('public_order_create', {placeId: order.storage.place.id, storageTypeId: order.storage.storageType.id, storageId: order.storage.id}) }}" class="btn btn-primary">
            Dokončit objednávku
        </a>
    </div>
    {% elseif order.status.value == 'reserved' or order.status.value == 'awaiting_payment' %}
    <div class="mt-6 flex justify-end">
        <a href="{{ path('public_order_payment', {id: order.id}) }}" class="btn btn-primary">
            Rekapitulace
        </a>
    </div>
    {% endif %}
{% endblock %}
