{% extends 'portal/layout.html.twig' %}

{% block title %}Přehled - Admin{% endblock %}

{% block content %}
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Přehled platformy</h1>

    {# Po splatnosti + Operace — always visible, red/amber when > 0, green when 0 #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        <a href="{{ path('admin_overdue') }}" class="block overflow-hidden shadow rounded-lg {% if stats.overdueCount > 0 %}bg-red-50 hover:bg-red-100 border border-red-300{% else %}bg-green-50 hover:bg-green-100 border border-green-200{% endif %}">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <svg class="h-7 w-7 {% if stats.overdueCount > 0 %}text-red-600{% else %}text-green-600{% endif %}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-medium {% if stats.overdueCount > 0 %}text-red-700{% else %}text-green-700{% endif %} truncate uppercase">Po splatnosti</dt>
                            {% if stats.overdueCount > 0 %}
                                <dd class="flex items-baseline gap-3 flex-wrap">
                                    <span class="text-3xl font-bold text-red-700">{{ stats.overdueCount }}</span>
                                    <span class="text-sm text-red-700">{{ stats.overdueCount == 1 ? 'smlouva' : (stats.overdueCount < 5 ? 'smlouvy' : 'smluv') }}</span>
                                    <span class="text-2xl font-semibold text-red-700">· {{ (stats.overdueAmount / 100)|number_format(0, ',', ' ') }} Kč</span>
                                </dd>
                            {% else %}
                                <dd class="text-lg font-semibold text-green-700">Žádné platby po splatnosti.</dd>
                            {% endif %}
                        </dl>
                    </div>
                </div>
            </div>
        </a>

        <a href="{{ path('admin_operations') }}" class="block overflow-hidden shadow rounded-lg {% if stats.operationsPendingCount > 0 %}bg-amber-50 hover:bg-amber-100 border border-amber-300{% else %}bg-green-50 hover:bg-green-100 border border-green-200{% endif %}">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <svg class="h-7 w-7 {% if stats.operationsPendingCount > 0 %}text-amber-600{% else %}text-green-600{% endif %}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
                        </svg>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-medium {% if stats.operationsPendingCount > 0 %}text-amber-700{% else %}text-green-700{% endif %} truncate uppercase">Operace</dt>
                            {% if stats.operationsPendingCount > 0 %}
                                <dd class="flex items-baseline gap-3 flex-wrap">
                                    <span class="text-3xl font-bold text-amber-700">{{ stats.operationsPendingCount }}</span>
                                    <span class="text-sm text-amber-700">
                                        {{ stats.operationsPendingCount == 1 ? 'úkol k vyřízení' : (stats.operationsPendingCount < 5 ? 'úkoly k vyřízení' : 'úkolů k vyřízení') }}
                                    </span>
                                </dd>
                            {% else %}
                                <dd class="text-lg font-semibold text-green-700">Žádné čekající úkoly.</dd>
                            {% endif %}
                        </dl>
                    </div>
                </div>
            </div>
        </a>
    </div>

    {# Revenue Stats Cards #}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <a href="{{ path('admin_bank_payments') }}" class="block bg-white overflow-hidden shadow rounded-lg hover:shadow-md transition-shadow">
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <dt class="text-sm font-medium text-gray-500 truncate">Tržby minulý měsíc</dt>
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
                <dd class="mt-2 text-2xl font-semibold text-gray-900">{{ (stats.lastMonthRevenue / 100)|number_format(0, ',', ' ') }} Kč</dd>
            </div>
            <div class="bg-gray-50 px-5 py-3">
                <span class="text-sm text-gray-500">Celkové hrubé tržby</span>
            </div>
        </a>

        <a href="{{ path('admin_orders_list') }}" class="block bg-white overflow-hidden shadow rounded-lg hover:shadow-md transition-shadow">
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <dt class="text-sm font-medium text-gray-500 truncate">Provize minulý měsíc</dt>
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
                <dd class="mt-2 text-2xl font-semibold text-gray-900">{{ (stats.lastMonthCommission / 100)|number_format(0, ',', ' ') }} Kč</dd>
            </div>
            <div class="bg-gray-50 px-5 py-3">
                <span class="text-sm text-gray-500">Příjem platformy</span>
            </div>
        </a>

        <a href="{{ path('admin_orders_list') }}" class="block bg-white overflow-hidden shadow rounded-lg hover:shadow-md transition-shadow">
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <dt class="text-sm font-medium text-gray-500 truncate">Očekávané tržby</dt>
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
                <dd class="mt-2 text-2xl font-semibold text-gray-900">{{ (stats.expectedThisMonthRevenue / 100)|number_format(0, ',', ' ') }} Kč</dd>
            </div>
            <div class="bg-gray-50 px-5 py-3">
                <span class="text-sm text-gray-500">{{ stats.activeRecurringContracts }} aktivních smluv</span>
            </div>
        </a>

        <a href="{{ path('admin_places_list') }}" class="block bg-white overflow-hidden shadow rounded-lg hover:shadow-md transition-shadow">
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <dt class="text-sm font-medium text-gray-500 truncate">Obsazenost</dt>
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
                <dd class="mt-2 text-2xl font-semibold text-gray-900">{{ stats.platformOccupancyRate|number_format(1, ',', ' ') }}%</dd>
            </div>
            <div class="bg-gray-50 px-5 py-3">
                <div class="w-full bg-gray-200 rounded-full h-2">
                    <div class="bg-green-600 h-2 rounded-full" style="width: {{ min(stats.platformOccupancyRate, 100) }}%"></div>
                </div>
            </div>
        </a>
    </div>

    {# Platform Stats Cards #}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <a href="{{ path('admin_places_list') }}" class="block bg-white overflow-hidden shadow rounded-lg hover:shadow-md transition-shadow">
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <dt class="text-sm font-medium text-gray-500 truncate">Celkem míst</dt>
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
                <dd class="mt-2 text-2xl font-semibold text-gray-900">{{ stats.totalPlaces }}</dd>
            </div>
            <div class="bg-gray-50 px-5 py-3">
                <span class="text-sm text-gray-500">Na platformě</span>
            </div>
        </a>

        <a href="{{ path('admin_places_list') }}" class="block bg-white overflow-hidden shadow rounded-lg hover:shadow-md transition-shadow">
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <dt class="text-sm font-medium text-gray-500 truncate">Celkem skladů</dt>
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
                <dd class="mt-2 text-2xl font-semibold text-gray-900">{{ stats.totalStorages }}</dd>
            </div>
            <div class="bg-gray-50 px-5 py-3">
                <span class="text-sm text-gray-500">{{ stats.occupiedStorages }} obsazených</span>
            </div>
        </a>

        <a href="{{ path('portal_users_list') }}" class="block bg-white overflow-hidden shadow rounded-lg hover:shadow-md transition-shadow">
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <dt class="text-sm font-medium text-gray-500 truncate">Pronajímatelů</dt>
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
                <dd class="mt-2 text-2xl font-semibold text-gray-900">{{ stats.landlordCount }}</dd>
            </div>
            <div class="bg-gray-50 px-5 py-3">
                <span class="text-sm text-gray-500">Registrovaných</span>
            </div>
        </a>

        <a href="{{ path('admin_orders_list') }}" class="block bg-white overflow-hidden shadow rounded-lg hover:shadow-md transition-shadow">
            <div class="p-5">
                <div class="flex items-center justify-between">
                    <dt class="text-sm font-medium text-gray-500 truncate">Aktivních smluv</dt>
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </div>
                <dd class="mt-2 text-2xl font-semibold text-gray-900">{{ stats.activeRecurringContracts }}</dd>
            </div>
            <div class="bg-gray-50 px-5 py-3">
                <span class="text-sm text-gray-500">S opakovanou platbou</span>
            </div>
        </a>
    </div>

    {# Revenue Chart #}
    <div class="mb-8">
        {{ component('RevenueChart') }}
    </div>

    {# Compact user stats row #}
    <div class="flex items-center justify-between bg-white shadow rounded-lg px-5 py-4 mb-8">
        <div class="flex items-center gap-6">
            <div class="text-sm text-gray-500">
                Celkem uživatelů: <span class="font-semibold text-gray-900">{{ stats.totalUsers }}</span>
            </div>
            <div class="text-sm text-gray-500">
                Ověřených: <span class="font-semibold text-gray-900">{{ stats.verifiedUsers }}</span>
            </div>
        </div>
        <a href="{{ path('portal_users_list', {filter: 'unverified'}) }}"
           class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-sm font-medium
                  {% if stats.unverifiedUsers > 0 %}bg-amber-100 text-amber-800 hover:bg-amber-200{% else %}bg-green-100 text-green-700{% endif %}">
            {% if stats.unverifiedUsers > 0 %}
                {{ stats.unverifiedUsers }} {{ stats.unverifiedUsers == 1 ? 'neověřený' : (stats.unverifiedUsers < 5 ? 'neověření' : 'neověřených') }}
            {% else %}
                Všichni ověření
            {% endif %}
        </a>
    </div>

    {# Poslední objednávky #}
    <div class="bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
            <div class="flex justify-between items-center">
                <h3 class="text-lg font-medium text-gray-900">Poslední objednávky</h3>
                <a href="{{ path('admin_orders_list') }}" class="link text-sm">Zobrazit vše</a>
            </div>
        </div>
        {% if recentOrders|length > 0 %}
            <div class="divide-y divide-gray-200">
                {% for order in recentOrders %}
                    <a href="{{ path('admin_order_detail', {id: order.id}) }}" class="block px-4 py-4 hover:bg-gray-50">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="text-sm font-medium text-gray-900">
                                    {{ order.user.fullName }}
                                </p>
                                <p class="text-sm text-gray-500">
                                    {{ order.storage.storageType.place.name }} · {{ order.storage.storageType.name }} - {{ order.storage.number }} | {{ order.createdAt|date('d.m.Y H:i') }}
                                </p>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-medium text-gray-900">
                                    {{ (order.firstPaymentPrice / 100)|number_format(0, ',', ' ') }} Kč{% if order.isRecurring %} / {{ order.isYearlyFrequency ? 'rok' : 'měsíc' }}{% endif %}
                                </p>
                                {% set statusClass = {
                                    'created': 'bg-gray-100 text-gray-800',
                                    'reserved': 'bg-yellow-100 text-yellow-800',
                                    'awaiting_payment': 'bg-amber-100 text-amber-800',
                                    'paid': 'bg-green-100 text-green-800',
                                    'completed': 'bg-green-100 text-green-800',
                                    'cancelled': 'bg-red-100 text-red-800',
                                    'expired': 'bg-gray-100 text-gray-800'
                                } %}
                                {% set statusLabel = {
                                    'created': 'Vytvořeno',
                                    'reserved': 'Rezervováno',
                                    'awaiting_payment': 'Čeká na platbu',
                                    'paid': 'Zaplaceno',
                                    'completed': 'Dokončeno',
                                    'cancelled': 'Zrušeno',
                                    'expired': 'Expirováno'
                                } %}
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium {{ statusClass[order.status.value] ?? 'bg-gray-100 text-gray-800' }}">
                                    {{ statusLabel[order.status.value] ?? order.status.value }}
                                </span>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="px-4 py-6 text-center text-gray-500">
                Zatím žádné objednávky
            </div>
        {% endif %}
    </div>
{% endblock %}
