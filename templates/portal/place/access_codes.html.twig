{% extends 'portal/layout.html.twig' %}

{% block title %}Přístupové kódy - {{ place.name }}{% endblock %}

{% block breadcrumb %}
    {% include 'components/breadcrumb.html.twig' with {breadcrumb_items: [
        {label: 'Místa', url: path('portal_places_list')},
        {label: place.name, url: path('portal_places_detail', {id: place.id})},
        {label: 'Přístupové kódy'},
    ]} %}
{% endblock %}

{% block content %}
    <div class="flex justify-between items-start mb-6">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Přístupové kódy</h1>
            <p class="text-gray-600">{{ place.name }}</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-6">
            <div class="card">
                <div class="card-body">
                    <h2 class="text-lg font-bold text-gray-900 mb-4">Konfigurace</h2>
                    <p class="text-sm text-gray-600 mb-6">
                        Po zapnutí budou kódy validovány na přesný počet číslic v zadaném rozsahu.
                        Doporučujeme 4 číslice (0–9999), což odpovídá běžným mechanickým zámkům.
                    </p>
                    {{ form_start(form) }}
                        <div class="space-y-4">
                            {{ form_row(form.enabled) }}
                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                                {{ form_row(form.digits) }}
                                {{ form_row(form.from) }}
                                {{ form_row(form.to) }}
                            </div>
                            <button type="submit" class="btn btn-primary">Uložit</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>

            {% if place.storageCodesEnabled %}
                <div class="card">
                    <div class="card-body">
                        <h2 class="text-lg font-bold text-gray-900 mb-4">Akce</h2>
                        <div class="space-y-3">
                            <form method="post" action="{{ path('portal_place_access_codes_bulk_generate', {placeId: place.id}) }}">
                                <button type="submit" class="btn btn-secondary"
                                        {% if emptyCount == 0 %}disabled title="Žádný sklad bez přiřazeného kódu"{% endif %}>
                                    Vygenerovat kódy pro prázdné sklady{% if emptyCount > 0 %} ({{ emptyCount }}){% endif %}
                                </button>
                            </form>
                            <button type="button" class="btn btn-secondary"
                                    onclick="document.getElementById('resetAccessCodesModal').showModal()">Resetovat použité kódy</button>
                            {% embed 'components/_danger_modal.html.twig' with {
                                id: 'resetAccessCodesModal',
                                title: 'Resetovat použité kódy',
                                action: path('portal_place_access_codes_reset', {placeId: place.id}),
                            } %}
                                {% block description %}
                                    Tímto trvale smažete historii použitých kódů. Kódy aktuálně přiřazené skladům
                                    zůstanou zachovány. <strong class="text-red-700">Tato akce je nevratná.</strong>
                                {% endblock %}
                                {% block submit_label %}Resetovat kódy{% endblock %}
                            {% endembed %}
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-body">
                        <h2 class="text-lg font-bold text-gray-900 mb-4">Sklady na tomto místě</h2>
                        {% if storages is empty %}
                            <p class="text-sm text-gray-500">Na tomto místě zatím nejsou žádné sklady.</p>
                        {% else %}
                            <div class="overflow-x-auto">
                                <table class="min-w-full divide-y divide-gray-200">
                                    <thead class="bg-gray-50">
                                        <tr>
                                            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Číslo</th>
                                            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Kód</th>
                                        </tr>
                                    </thead>
                                    <tbody class="bg-white divide-y divide-gray-200">
                                        {% for storage in storages %}
                                            <tr>
                                                <td class="px-4 py-2 text-sm text-gray-900">{{ storage.number }}</td>
                                                <td class="px-4 py-2 text-sm font-mono text-gray-900">
                                                    {% if storage.lockCode %}
                                                        {{ storage.lockCode }}
                                                    {% else %}
                                                        <span class="text-gray-400">—</span>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="space-y-6">
            {% if place.storageCodesEnabled %}
                <div class="card">
                    <div class="card-body">
                        <h2 class="text-lg font-bold text-gray-900 mb-4">Souhrn</h2>
                        <dl class="space-y-3 text-sm">
                            <div class="flex justify-between">
                                <dt class="text-gray-500">Rozsah</dt>
                                <dd class="font-medium text-gray-900">{{ place.storageCodeRangeSize() }} kódů</dd>
                            </div>
                            <div class="flex justify-between">
                                <dt class="text-gray-500">Použito</dt>
                                <dd class="font-medium text-gray-900">{{ usedCodesCount }}</dd>
                            </div>
                            <div class="flex justify-between">
                                <dt class="text-gray-500">Dostupné</dt>
                                <dd class="font-medium text-gray-900">{{ availableCount }}</dd>
                            </div>
                        </dl>
                    </div>
                </div>
            {% else %}
                <div class="card bg-gray-50">
                    <div class="card-body">
                        <h2 class="text-lg font-bold text-gray-900 mb-2">Funkce vypnuta</h2>
                        <p class="text-sm text-gray-600">
                            Po zapnutí systém ohlídá unikátnost přístupových kódů a nabídne automatické
                            generování při předávacím protokolu i v editoru skladu.
                        </p>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
