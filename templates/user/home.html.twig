{% extends 'user/layout.html.twig' %}

{% block title %}Fajnesklady.cz - Bezpečné uskladnění Vašich věcí ve skladovacích jednotkách{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
          crossorigin=""/>
{% endblock %}

{% set heroImages = [
    '1644589657.jpg',
    '1644589677.jpg',
    '1644589691.jpg',
    '1644589704.jpg',
    '1644589713.jpg',
    '1644589722.jpg',
    '1644589731.jpg'
] %}

{% block hero %}
    {# Full-screen Hero with Image Slider #}
    <div class="hero-container" data-controller="hero-slider" data-hero-slider-interval-value="6000">
        {# Background slides #}
        {% for image in heroImages %}
        <div class="hero-slide {% if loop.first %}active{% endif %}" data-hero-slider-target="slide">
            <div class="hero-slide-image" style="background-image: url('{{ asset('images/hero/' ~ image) }}')"></div>
            <div class="hero-gradient"></div>
        </div>
        {% endfor %}

        {# Content overlay #}
        <div class="hero-content pt-16 pb-10">
            <img src="{{ asset('images/logo-white-no-text.svg') }}" alt="Fajnesklady.cz" class="h-14 sm:h-16 md:h-24 mb-5 sm:mb-6 drop-shadow-lg">
            <h1 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold mb-4 sm:mb-6 max-w-4xl leading-tight drop-shadow-lg">
                Bezpečné uskladnění<br class="hidden md:block"> Vašich věcí
            </h1>
            <p class="text-base sm:text-lg md:text-xl mb-8 sm:mb-10 text-white/90 max-w-2xl leading-relaxed">
                Skladovací jednotky s přístupem 24/7, kompletním zabezpečením a flexibilním pronájmem
            </p>
            <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 w-full sm:w-auto sm:flex-wrap justify-center">
                <a href="#pobocky" class="btn btn-primary btn-lg shadow-lg w-full sm:w-auto">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    </svg>
                    Najít pobočku
                </a>
                <a href="#jak-to-funguje" class="btn-hero-secondary w-full sm:w-auto">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Jak to funguje?
                </a>
            </div>

            {# Scroll indicator #}
            <a href="#jak-to-funguje" class="mt-10 sm:mt-12 flex flex-col items-center text-white/60 hover:text-white/90 transition-colors">
                <span class="text-xs uppercase tracking-widest mb-2">Více</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                </svg>
            </a>
        </div>
    </div>
{% endblock %}

{% block main_class %}min-h-screen{% endblock %}

{% block content %}
    {# Combined Map + Places Section #}
    <section id="pobocky" class="pt-20 pb-20 relative section-gradient-light"
             data-controller="map"
             data-map-places-value="{{ placesData|json_encode|e('html_attr') }}">
        {# Light gradient fade at top — full-bleed so the fade reads against the previous section #}
        <div class="absolute top-0 left-0 right-0 h-40 pointer-events-none z-10" style="background: linear-gradient(180deg, #f1f5f9 0%, #f8fafc 40%, transparent 100%)"></div>

        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-20">
            <div class="text-center mb-10">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Přehled poboček a cen</h2>
                <p class="text-gray-600 max-w-2xl mx-auto text-lg">Najděte nejbližší pobočku a nejvhodnější skladovací jednotku</p>
            </div>

            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-end gap-3 mb-5">
                <button type="button"
                        data-action="map#requestGeolocation"
                        data-map-target="geoButton"
                        class="btn btn-ghost btn-sm">
                    <svg class="h-4 w-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Najít nejbližší pobočku
                </button>
            </div>

            <div class="places-layout">
                {# Place cards list — visible ≥1024px; hidden on mobile (replaced by bottom-sheet pill) #}
                {% if placesWithStorageTypes|length > 0 %}
                <div class="places-list-col" data-map-target="placeList">
                    {% for item in placesWithStorageTypes %}
                    <div class="place-card"
                         data-map-target="placeCard"
                         data-place-id="{{ item.place.id }}">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0 flex-1">
                                <h3 class="font-bold text-gray-900 text-base leading-tight truncate">{{ item.place.name }}</h3>
                                <p class="text-gray-500 text-xs mt-0.5">{{ item.place.city }}</p>
                            </div>
                            {% if item.isAvailable %}
                                <span class="badge-available">K dispozici</span>
                            {% else %}
                                <span class="badge-sold-out">Obsazeno</span>
                            {% endif %}
                        </div>
                        {% if item.lowestPrice and item.lowestAreaM2 %}
                            <p class="text-gray-700 text-sm mt-2">
                                Od <strong>{{ item.lowestPrice|number_format(0, ',', ' ') }} Kč</strong>/měs
                                · od <strong>{{ item.lowestAreaM2|number_format(1, ',', ' ') }} m²</strong>
                            </p>
                        {% endif %}
                        <a href="{{ path('public_place_detail', {id: item.place.id}) }}"
                           class="absolute inset-0" aria-label="Zobrazit detail pobočky {{ item.place.name }}"></a>
                    </div>
                    {% endfor %}
                </div>
                {% endif %}

                {# Map #}
                <div class="places-map-col">
                    <div data-map-target="mapContainer" class="map-container overflow-hidden" style="height: 100%; min-height: 500px;"></div>

                    {# Mobile-only floating pill — opens the bottom sheet #}
                    {% if placesWithStorageTypes|length > 0 %}
                    <button type="button"
                            data-map-target="bottomSheetPill"
                            data-action="map#openBottomSheet"
                            class="bottom-sheet-pill"
                            hidden>
                        Seznam poboček ({{ placesWithStorageTypes|length }})
                    </button>
                    {% endif %}

                    {# Closest-place chip — shown when user location is known and no marker is in viewport #}
                    <button type="button"
                            data-map-target="closestChip"
                            data-action="map#flyToClosest"
                            class="closest-chip"
                            hidden></button>
                </div>
            </div>
        </div>

        {# Mobile fullscreen modal (<768 px) #}
        <div data-map-target="modal" class="map-modal" hidden>
            <div class="map-modal__backdrop" data-action="click->map#closeMobileModal"></div>
            <div class="map-modal__panel" data-map-target="modalBody" role="dialog" aria-modal="true"></div>
        </div>

        {# Mobile bottom sheet (<1024 px) — JS clones the desktop cards into the list #}
        <div data-map-target="bottomSheet" class="bottom-sheet" hidden>
            <div class="bottom-sheet__backdrop" data-action="click->map#closeBottomSheet"></div>
            <div class="bottom-sheet__panel">
                <div class="bottom-sheet__handle"></div>
                <h2 class="bottom-sheet__title">Pobočky</h2>
                <div class="bottom-sheet__list" data-map-target="bottomSheetList"></div>
            </div>
        </div>
    </section>

    {# How it works section #}
    <section id="jak-to-funguje" class="section-gradient-light"
             data-controller="place-wizard"
             data-place-wizard-places-value="{{ placesData|json_encode|e('html_attr') }}">
        <div class="py-20 max-w-6xl mx-auto px-4">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Jak to funguje?</h2>
                <p class="text-gray-600 max-w-3xl mx-auto text-lg leading-relaxed">
                    Naše skladovací jednotky můžete využít na sezónní věci, jako jsou lyže, kola, pneumatiky, střešní boxy nebo třeba kožich po babičce, který nosíte jen v zimě. V případě stěhování jsou naše sklady ideálním místem, kde můžete na libovolnou dobu uložit vše potřebné. Využijte naše služby i v případě, že Vás vyhodí drahá polovička z domu. Ale pozor! Ne, abyste se nám tam nastěhovali! V neposlední řadě nabízíme skladovací prostory i firmám, které potřebují nárazově nebo trvale řešit, kam uložit svůj inventář, ať už sezónně nebo po celý rok. My tady máme uložený náš sen o obchodu s akvaristikou.
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 lg:gap-8 max-w-4xl mx-auto">
                {# Krok 1 #}
                <button type="button" class="group flex flex-col items-center text-center bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all border border-gray-100 hover:border-primary/30 cursor-pointer" data-action="place-wizard#open">
                    <div class="relative mb-5">
                        <div class="w-16 h-16 rounded-2xl text-white flex items-center justify-center group-hover:scale-110 transition-transform" style="background: linear-gradient(to bottom right, #e54545, #b82829)">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <div class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm shadow-lg">1</div>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900">Vyberte pobočku</h3>
                </button>

                {# Krok 2 #}
                <button type="button" class="group flex flex-col items-center text-center bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all border border-gray-100 hover:border-primary/30 cursor-pointer" data-action="place-wizard#open">
                    <div class="relative mb-5">
                        <div class="w-16 h-16 rounded-2xl text-white flex items-center justify-center group-hover:scale-110 transition-transform" style="background: linear-gradient(to bottom right, #e54545, #b82829)">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" />
                            </svg>
                        </div>
                        <div class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm shadow-lg">2</div>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900">Zvolte velikost</h3>
                </button>

                {# Krok 3 #}
                <button type="button" class="group flex flex-col items-center text-center bg-white rounded-2xl p-8 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all border border-gray-100 hover:border-primary/30 cursor-pointer" data-action="place-wizard#open">
                    <div class="relative mb-5">
                        <div class="w-16 h-16 rounded-2xl text-white flex items-center justify-center group-hover:scale-110 transition-transform" style="background: linear-gradient(to bottom right, #e54545, #b82829)">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <div class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-primary text-white flex items-center justify-center font-bold text-sm shadow-lg">3</div>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900">Objednejte online</h3>
                </button>
            </div>
        </div>

        {# Wizard modal #}
        <div data-place-wizard-target="modal" class="wizard-modal" role="dialog" aria-modal="true">
            <div data-action="click->place-wizard#close" class="wizard-modal__backdrop"></div>
            <div class="wizard-modal__panel">
                <div class="wizard-modal__header">
                    <button type="button"
                            data-place-wizard-target="backButton"
                            data-action="place-wizard#back"
                            class="wizard-modal__back hidden">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                        Zpět
                    </button>
                    <button type="button"
                            data-action="place-wizard#close"
                            class="wizard-modal__close" aria-label="Zavřít">&times;</button>
                </div>
                <div data-place-wizard-target="stepIndicator" class="wizard-modal__steps"></div>
                <div data-place-wizard-target="stepContent" class="wizard-modal__content"></div>
            </div>
        </div>
    </section>

    {# Why choose us section #}
    <section id="nas-pribeh" class="py-20 relative overflow-hidden">
        {# Decorative background elements #}
        <div class="absolute inset-0 pointer-events-none">
            <div class="absolute top-20 left-0 w-72 h-72 bg-accent/5 rounded-full blur-3xl"></div>
            <div class="absolute bottom-20 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
            {# Subtle container pattern #}
            <svg class="absolute top-10 right-10 w-32 h-32 text-gray-100 rotate-12" viewBox="0 0 100 60" fill="none">
                <rect x="5" y="5" width="90" height="50" rx="2" stroke="currentColor" stroke-width="2" fill="none"/>
                <line x1="5" y1="15" x2="95" y2="15" stroke="currentColor" stroke-width="1"/>
                <rect x="40" y="20" width="20" height="30" stroke="currentColor" stroke-width="2" fill="none"/>
            </svg>
            <svg class="absolute bottom-20 left-20 w-24 h-24 text-gray-100 -rotate-6" viewBox="0 0 100 60" fill="none">
                <rect x="5" y="5" width="90" height="50" rx="2" stroke="currentColor" stroke-width="2" fill="none"/>
                <line x1="5" y1="15" x2="95" y2="15" stroke="currentColor" stroke-width="1"/>
                <rect x="40" y="20" width="20" height="30" stroke="currentColor" stroke-width="2" fill="none"/>
            </svg>
        </div>

        <div class="max-w-6xl mx-auto px-4 relative">
            {# Header with personality #}
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 mb-6 leading-tight">
                    Proč si vybrat <span class="text-accent">Fajnesklady.cz</span>?
                </h2>
            </div>

            {# Why-choose-us pictograms (old-site design) #}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12 lg:gap-x-0 lg:gap-y-0 lg:divide-x lg:divide-gray-200">
                {# Security #}
                <div class="flex flex-col items-center text-center px-4 lg:px-8">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-16 w-16 text-gray-900 mb-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" />
                    </svg>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4">Zabezpečení</h3>
                    <p class="text-gray-600 leading-relaxed">
                        Celý areál Fajných skladů je hlídán 24/7 ultra špičkovým kamerovým systémem a senzory pohybu. Kdyby se mělo stéblo pohnout, naši lidé o tom budou vědět.
                    </p>
                </div>

                {# Access #}
                <div class="flex flex-col items-center text-center px-4 lg:px-8">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-16 w-16 text-gray-900 mb-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4">Přístupnost</h3>
                    <p class="text-gray-600 leading-relaxed">
                        Na místo se dostanete každou hodinu každého dne, pomocí vlastního přístupového ovládání k hlavní bráně a klíčům ke skladovací jednotce.
                    </p>
                </div>

                {# Insurance #}
                <div class="flex flex-col items-center text-center px-4 lg:px-8">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-16 w-16 text-gray-900 mb-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                    </svg>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4">Pojištění</h3>
                    <p class="text-gray-600 leading-relaxed">
                        Obsah každé skladovací jednotky je pojištěn, pro případ živelné pohromy a odcizení. S námi můžete v noci v klidu spát. O vaše věci je u nás postaráno.
                    </p>
                </div>

                {# Flexibility #}
                <div class="flex flex-col items-center text-center px-4 lg:px-8">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-16 w-16 text-gray-900 mb-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
                    </svg>
                    <h3 class="text-2xl font-bold text-gray-900 mb-4">Flexibilní pronájem</h3>
                    <p class="text-gray-600 leading-relaxed">
                        Potřebujete skladovací jednotku na týden? Není problém. Potřebujete ji na měsíc? To je taky v cajku. V případě, že potřebujete prodloužit pronájem, stačí se domluvit na konkrétních podmínkách.
                    </p>
                </div>
            </div>

        </div>
    </section>

{% endblock %}
