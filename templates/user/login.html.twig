{% extends 'user/layout.html.twig' %}

{% block title %}Přihlášení - {{ parent() }}{% endblock %}

{% block content %}
    <div class="flex justify-center">
        <div class="card w-full max-w-md">
            <div class="card-body">
                <h2 class="text-center text-2xl font-bold mb-4 text-gray-900">Přihlášení</h2>

                {% if error %}
                    <div role="alert" class="alert alert-error mb-4">
                        <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
                    </div>
                {% endif %}

                {% if app.session.get('unverified_user_email') %}
                    <div role="alert" class="alert alert-warning mb-4">
                        <div class="flex flex-col gap-2">
                            <span>Váš email ještě nebyl ověřen.</span>
                            <form action="{{ path('app_resend_verification_email') }}" method="post" class="inline">
                                <button type="submit" class="link text-amber-700 underline">
                                    Odeslat ověřovací email znovu
                                </button>
                            </form>
                        </div>
                    </div>
                {% endif %}

                <form method="post">
                    <div class="form-group">
                        <label class="form-label">E-mailová adresa</label>
                        <input
                            type="email"
                            name="_username"
                            value="{{ last_username }}"
                            class="form-input"
                            required
                            autofocus
                            autocomplete="email"
                        >
                    </div>

                    <div class="form-group">
                        <label class="form-label">Heslo</label>
                        <div class="relative" data-controller="password-toggle">
                            <input
                                type="password"
                                name="_password"
                                class="form-input pr-10"
                                required
                                autocomplete="current-password"
                                data-password-toggle-target="input"
                            >
                            <button type="button"
                                    tabindex="-1"
                                    class="absolute inset-y-0 right-0 flex items-center px-3 text-gray-400 hover:text-gray-600 focus:outline-none focus:text-gray-600"
                                    aria-label="Zobrazit heslo"
                                    data-action="click->password-toggle#toggle">
                                <svg data-password-toggle-target="showIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="h-5 w-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                                <svg data-password-toggle-target="hideIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="h-5 w-5 hidden">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="flex items-center cursor-pointer gap-3">
                            <input type="checkbox" name="_remember_me" class="h-4 w-4 text-accent focus:ring-accent border-gray-300 rounded">
                            <span class="text-sm text-gray-700">Zapamatovat si mě</span>
                        </label>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary w-full">Přihlásit se</button>
                    </div>

                    <div class="text-center">
                        <a href="{{ path('app_request_password_reset') }}" class="link text-sm">Zapomněli jste heslo?</a>
                    </div>
                </form>

                <div class="relative my-6">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-gray-200"></div>
                    </div>
                    <div class="relative flex justify-center text-sm">
                        <span class="px-2 bg-white text-gray-500">NEBO</span>
                    </div>
                </div>

                <p class="text-center text-gray-700">
                    Nemáte účet?
                    <a href="{{ path('app_register') }}" class="link">Zaregistrujte se</a>
                </p>
            </div>
        </div>
    </div>
{% endblock %}
