{% use "form_div_layout.html.twig" %}

{# Form row #}
{% block form_row -%}
    <div class="form-group">
        {{- form_label(form) -}}
        {{- form_widget(form) -}}
        {{- form_errors(form) -}}
        {{- form_help(form) -}}
    </div>
{%- endblock form_row %}

{# Form label #}
{% block form_label -%}
    {% if label is not same as(false) -%}
        {% set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' form-label' ~ (required|default(false) ? ' form-label-required' : ''))|trim}) -%}
        <label{% if label_attr %}{% with { attr: label_attr } %} {{ block('attributes') }}{% endwith %}{% endif %}>
            {%- if label is empty -%}
                {{- name|humanize -}}
            {%- else -%}
                {{- translation_domain is same as(false) ? label : label|trans(label_translation_parameters, translation_domain) -}}
            {%- endif -%}
        </label>
    {%- endif %}
{%- endblock form_label %}

{# Form widget #}
{% block form_widget_simple -%}
    {% set type = type|default('text') -%}
    {% set attr = attr|merge({
        class: (attr.class|default('') ~ ' form-input' ~ (errors|length ? ' form-input-error' : ''))|trim
    }) -%}
    <input type="{{ type }}" {{ block('widget_attributes') }} {% if value is not empty %}value="{{ value }}" {% endif %}/>
{%- endblock form_widget_simple %}

{# Password widget with show/hide toggle as an input-group #}
{% block password_widget -%}
    {% set type = type|default('password') -%}
    {% set attr = attr|merge({
        class: (attr.class|default('') ~ ' form-input flex-1 min-w-0 rounded-r-none!' ~ (errors|length ? ' form-input-error' : ''))|trim
    }) -%}
    <div class="flex" data-controller="password-toggle">
        <input type="{{ type }}" {{ block('widget_attributes') }} {% if value is not empty %}value="{{ value }}" {% endif %}data-password-toggle-target="input" />
        <button type="button"
                tabindex="-1"
                class="flex items-center justify-center px-3 border border-l-0 border-gray-300 rounded-r-md bg-gray-50 hover:bg-gray-100 text-gray-400 hover:text-gray-600 focus:outline-none"
                aria-label="Zobrazit heslo"
                data-action="click->password-toggle#toggle">
            {# Eye icon — visible when password is hidden #}
            <svg data-password-toggle-target="showIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="h-5 w-5">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            {# Eye-slash icon — visible when password is shown #}
            <svg data-password-toggle-target="hideIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="h-5 w-5 hidden">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
            </svg>
        </button>
    </div>
{%- endblock password_widget %}

{# Date widget — single_text variant gets the flatpickr Stimulus controller automatically #}
{% block date_widget -%}
    {% if widget == 'single_text' -%}
        {% set existing = attr['data-controller']|default('') %}
        {% set attr = attr|merge({
            'data-controller': (existing ~ ' datepicker')|trim,
        }) %}
        {{- block('form_widget_simple') -}}
    {%- else -%}
        {{- parent() -}}
    {%- endif %}
{%- endblock date_widget %}

{# Textarea widget #}
{% block textarea_widget -%}
    {% set attr = attr|merge({
        class: (attr.class|default('') ~ ' form-input' ~ (errors|length ? ' form-input-error' : ''))|trim
    }) -%}
    <textarea {{ block('widget_attributes') }}>{{ value }}</textarea>
{%- endblock textarea_widget %}

{# Choice widget (select) #}
{% block choice_widget_collapsed -%}
    {% set attr = attr|merge({
        class: (attr.class|default('') ~ ' form-input' ~ (errors|length ? ' form-input-error' : ''))|trim
    }) -%}
    <select {{ block('widget_attributes') }}{% if multiple %} multiple="multiple"{% endif %}>
        {% if placeholder is not none -%}
            <option value=""{% if required and value is empty %} selected="selected"{% endif %}>{{ placeholder != '' ? (translation_domain is same as(false) ? placeholder : placeholder|trans({}, translation_domain)) }}</option>
        {%- endif %}
        {%- if preferred_choices|length > 0 -%}
            {% set options = preferred_choices %}
            {% set render_preferred_choices = true %}
            {{- block('choice_widget_options') -}}
            {% if choices|length > 0 and separator is not none -%}
                <option disabled="disabled">{{ separator }}</option>
            {%- endif %}
        {%- endif -%}
        {% set options = choices -%}
        {{- block('choice_widget_options') -}}
    </select>
{%- endblock choice_widget_collapsed %}

{# Checkbox row - override to prevent label duplication #}
{% block checkbox_row -%}
    <div class="form-group">
        <div class="flex items-center">
            {{- form_widget(form) -}}
            {% if label is not same as(false) -%}
                <label for="{{ id }}" class="ml-2 text-sm text-gray-700 cursor-pointer">
                    {%- if label is empty -%}
                        {{- name|humanize -}}
                    {%- elseif label_html|default(false) -%}
                        {{- translation_domain is same as(false) ? label|raw : label|trans(label_translation_parameters, translation_domain)|raw -}}
                    {%- else -%}
                        {{- translation_domain is same as(false) ? label : label|trans(label_translation_parameters, translation_domain) -}}
                    {%- endif -%}
                </label>
            {%- endif %}
        </div>
        {{- form_errors(form) -}}
        {{- form_help(form) -}}
    </div>
{%- endblock checkbox_row %}

{# Checkbox widget #}
{% block checkbox_widget -%}
    {% set attr = attr|merge({
        class: (attr.class|default('') ~ ' h-4 w-4 text-accent focus:ring-accent border-gray-300 rounded' ~ (errors|length ? ' border-red-300' : ''))|trim
    }) -%}
    <input type="checkbox" {{ block('widget_attributes') }}{% if value is defined %} value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %} />
{%- endblock checkbox_widget %}

{# Radio row - override to prevent label duplication #}
{% block radio_row -%}
    <div class="form-group">
        <div class="flex items-center">
            {{- form_widget(form) -}}
            {% if label is not same as(false) -%}
                <label for="{{ id }}" class="ml-2 text-sm text-gray-700 cursor-pointer">
                    {%- if label is empty -%}
                        {{- name|humanize -}}
                    {%- else -%}
                        {{- translation_domain is same as(false) ? label : label|trans(label_translation_parameters, translation_domain) -}}
                    {%- endif -%}
                </label>
            {%- endif %}
        </div>
        {{- form_errors(form) -}}
        {{- form_help(form) -}}
    </div>
{%- endblock radio_row %}

{# Radio widget #}
{% block radio_widget -%}
    {% set attr = attr|merge({
        class: (attr.class|default('') ~ ' h-4 w-4 text-accent focus:ring-accent border-gray-300' ~ (errors|length ? ' border-red-300' : ''))|trim
    }) -%}
    <input type="radio" {{ block('widget_attributes') }}{% if value is defined %} value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %} />
{%- endblock radio_widget %}

{# Expanded choice widget (radio buttons or checkboxes in a group) #}
{% block choice_widget_expanded -%}
    <div {{ block('widget_container_attributes') }} class="space-y-3">
        {%- for child in form %}
            <div class="flex items-center">
                {{- form_widget(child) -}}
                <label for="{{ child.vars.id }}" class="ml-3 text-sm text-gray-700 cursor-pointer">
                    {{- child.vars.label is not same as(false) ? (translation_domain is same as(false) ? child.vars.label : child.vars.label|trans({}, translation_domain)) -}}
                </label>
            </div>
        {% endfor -%}
    </div>
{%- endblock choice_widget_expanded %}

{# Form errors #}
{% block form_errors -%}
    {% if errors|length > 0 -%}
        <div class="form-error">
            {%- for error in errors -%}
                {{ error.message }}
                {%- if not loop.last %}<br>{% endif -%}
            {%- endfor -%}
        </div>
    {%- endif %}
{%- endblock form_errors %}

{# Form help #}
{% block form_help -%}
    {%- if help is not empty -%}
        <div class="form-help">
            {{- translation_domain is same as(false) ? help : help|trans({}, translation_domain) -}}
        </div>
    {%- endif -%}
{%- endblock form_help %}

{# Button widget #}
{% block button_widget -%}
    {% set attr = attr|merge({
        class: (attr.class|default('') ~ ' btn btn-primary')|trim
    }) -%}
    <button type="{{ type|default('button') }}" {{ block('button_attributes') }}>
        {{- translation_domain is same as(false) ? label : label|trans(label_translation_parameters, translation_domain) -}}
    </button>
{%- endblock button_widget %}

{# Submit button #}
{% block submit_widget -%}
    {% set attr = attr|merge({
        class: (attr.class|default('') ~ ' btn btn-primary')|trim
    }) -%}
    {{- block('button_widget') -}}
{%- endblock submit_widget %}
