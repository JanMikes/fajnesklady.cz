{% import 'components/_address_override.html.twig' as addr %}
{% set formData = form.vars.data %}
{% set invoiceToCompany = formData.invoiceToCompany ?? false %}
{% set rentalType = formData.rentalType %}
{% set rentalIsLimited = rentalType is null or rentalType.value == 'limited' %}
{% set paymentMethod = formData.paymentMethod %}
{% set paymentFrequency = formData.paymentFrequency %}
{% set isYearly = paymentFrequency is not null and paymentFrequency.value == 'yearly' %}
{% set monthlyPriceMode = formData.monthlyPriceMode %}
{% set isExternallyPrepaid = formData.isExternallyPrepaid ?? false %}
{% set isBankTransfer = paymentMethod is not null and paymentMethod.value == 'bank_transfer' %}

<div {{ attributes.defaults({
    'data-controller': 'admin-onboarding-bridge live-form-scroll',
    'data-action': 'storage-map:select->admin-onboarding-bridge#handleStorageSelect',
}) }}>
    {{ form_start(form, {attr: {novalidate: 'novalidate', 'data-turbo': 'false'}}) }}

    <div class="space-y-8 max-w-4xl">
        {% if this.submitError %}
            <div class="rounded-lg border border-red-300 bg-red-50 p-4 text-sm text-red-800">
                {{ this.submitError }}
            </div>
        {% endif %}
        {# 1. Kontaktní údaje zákazníka #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Kontaktní údaje zákazníka</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {{ form_row(form.email) }}
                    {{ form_row(form.firstName) }}
                    {{ form_row(form.lastName) }}
                    {{ form_row(form.phone) }}
                    {% if not invoiceToCompany %}
                        {{ form_row(form.birthDate, {attr: {
                            'data-action': 'blur->live#action',
                            'data-live-action-param': 'validateField',
                            'data-live-field-param': 'birthDate',
                        }}) }}
                    {% else %}
                        {% do form.birthDate.setRendered %}
                    {% endif %}
                </div>
            </div>
        </div>

        {# 2. Fakturační údaje #}
        <div class="card overflow-visible" data-controller="ares-lookup">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Fakturační údaje</h2>
                {{ form_row(form.invoiceToCompany) }}

                {% if invoiceToCompany %}
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                        <div>
                            {{ form_label(form.companyId, null, {label_attr: {class: 'form-label-required'}}) }}
                            <div class="flex">
                                {{ form_widget(form.companyId, {attr: {
                                    'class': 'flex-1 min-w-0 rounded-r-none!',
                                }}) }}
                                {% include 'components/ares_lookup_button.html.twig' %}
                            </div>
                            <p data-ares-lookup-target="status" class="text-sm mt-2" aria-live="polite" data-live-ignore></p>
                            {{ form_errors(form.companyId) }}
                        </div>
                        <div>
                            {{ form_row(form.companyName, {label_attr: {class: 'form-label-required'}}) }}
                        </div>
                        <div>
                            {{ form_row(form.companyVatId) }}
                        </div>
                    </div>
                {% else %}
                    {% do form.companyId.setRendered %}
                    {% do form.companyName.setRendered %}
                    {% do form.companyVatId.setRendered %}
                {% endif %}

                <h3 class="font-semibold text-gray-800 mt-6 mb-3">{{ invoiceToCompany ? 'Sídlo společnosti' : 'Fakturační adresa' }}</h3>
                {{ addr.render_live(form, false) }}
            </div>
        </div>

        {# 3. Typ pronájmu #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Typ pronájmu</h2>
                <div class="space-y-4">
                    {{ form_row(form.rentalType) }}
                    {% if rentalType is not null and rentalType.value == 'unlimited' %}
                        {{ form_row(form.expectedDuration) }}
                    {% else %}
                        {% do form.expectedDuration.setRendered %}
                    {% endif %}
                </div>
            </div>
        </div>

        {# 4. Datum #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Datum</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {{ form_row(form.startDate) }}
                    {% if rentalIsLimited %}
                        <div data-controller="duration-preset"
                             data-duration-preset-min-gap-days-value="7"
                             data-duration-preset-max-months-value="0">
                            {{ form_row(form.endDate) }}
                        </div>
                    {% else %}
                        {% do form.endDate.setRendered %}
                    {% endif %}
                </div>
            </div>
        </div>

        {# 5. Pobočka #}
        <div class="card" data-form-error-section>
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Pobočka</h2>
                {% if this.storageError %}
                    <p class="form-error mb-3" data-live-error role="alert">{{ this.storageError }}</p>
                {% endif %}
                <div>
                    <label for="admin-onboarding-place" class="form-label">Pobočka</label>
                    <select id="admin-onboarding-place"
                            data-model="norender|placeId"
                            data-action="change->live#action"
                            data-live-action-param="onPlaceChange"
                            class="form-input w-full">
                        <option value="">-- Vyberte pobočku --</option>
                        {% for place in this.places %}
                            <option value="{{ place.id }}" {{ this.placeId == place.id.toRfc4122() ? 'selected' }}>
                                {{ place.name }}{% if place.city %} ({{ place.city }}){% endif %}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>

        {# 6. Typ skladovací jednotky #}
        {% if this.placeId %}
            <div class="card">
                <div class="card-body">
                    <h2 class="text-lg font-bold text-gray-900 mb-4">Typ skladovací jednotky</h2>
                    <div>
                        <label for="admin-onboarding-storage-type" class="form-label">Typ</label>
                        <select id="admin-onboarding-storage-type"
                                data-model="norender|storageTypeId"
                                data-action="change->live#action"
                                data-live-action-param="onStorageTypeChange"
                                class="form-input w-full">
                            <option value="">-- Vyberte typ --</option>
                            {% for type in this.storageTypes %}
                                <option value="{{ type.id }}" {{ this.storageTypeId == type.id.toRfc4122() ? 'selected' }}>
                                    {{ type.name }} ({{ type.dimensionsInMeters }})
                                    — {{ (type.defaultPricePerMonthLongTerm / 100)|number_format(0, ',', ' ') }} Kč/měs
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
            </div>
        {% endif %}

        {# 7. Mapa skladu #}
        {% set selectedPlace = this.selectedPlace %}
        {% set selectedStorageType = this.selectedStorageType %}
        {% if selectedPlace and selectedStorageType and selectedPlace.mapImagePath and this.hasValidWindow() %}
            <div class="card">
                <div class="card-body">
                    <h2 class="text-lg font-bold text-gray-900 mb-4">Výběr skladové jednotky</h2>
                    <p class="text-sm text-gray-600 mb-4">Klikněte na dostupnou (zelenou) skladovou jednotku na mapě.</p>
                    <div data-controller="storage-map"
                         data-storage-map-map-image-value="{{ asset('uploads/' ~ selectedPlace.mapImagePath) }}"
                         data-storage-map-storages-value="{{ this.storagesJson|e('html_attr') }}"
                         data-storage-map-place-id-value="{{ this.placeId }}"
                         data-storage-map-current-storage-type-id-value="{{ this.storageTypeId }}"
                         data-storage-map-select-mode-value="true"
                         data-storage-map-highlight-storage-value="{{ this.storageId ?? '' }}">
                        <div data-storage-map-target="container" data-live-ignore
                             class="border border-gray-300 rounded-lg w-full" style="min-height: 400px;"></div>
                        <div data-storage-map-target="minimap"
                             class="hidden absolute bottom-2 right-2 border border-gray-400 rounded-md bg-white shadow-md"
                             data-live-ignore></div>
                        <div data-storage-map-target="tooltip"
                             class="hidden fixed z-50 pointer-events-none bg-white border border-gray-200 rounded-md shadow-lg p-3 text-xs max-w-xs"></div>
                    </div>
                </div>
            </div>
        {% elseif selectedPlace and selectedStorageType and selectedPlace.mapImagePath %}
            {# Place + type + map are ready, but the availability query has no rental window yet.
               Rendering the map now would paint every unit as greyed-out "nedostupný" (reads as broken),
               so hold it back behind a concise prompt until a rental type + date are chosen. #}
            <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
                Nejdříve zvolte typ pronájmu a termín — poté se zobrazí mapa s dostupností skladových jednotek.
            </div>
        {% elseif selectedPlace and selectedStorageType and not selectedPlace.mapImagePath %}
            <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
                Tato pobočka nemá nahrán mapový podklad. Skladovou jednotku nelze vybrat z mapy.
            </div>
        {% endif %}

        {# 8. Vybraná skladová jednotka #}
        {% set selectedStorage = this.selectedStorage %}
        {% if selectedStorage %}
            <div class="card border-green-200 bg-green-50">
                <div class="card-body">
                    <h2 class="text-lg font-bold text-green-900 mb-2">Vybraná skladová jednotka</h2>
                    <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
                        <div>
                            <dt class="text-green-700">Číslo</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.number }}</dd>
                        </div>
                        <div>
                            <dt class="text-green-700">Rozměry</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.storageType.dimensionsInMeters }}</dd>
                        </div>
                        <div>
                            <dt class="text-green-700">Týdenní sazba</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.effectivePricePerWeekInCzk|number_format(0, ',', ' ') }} Kč</dd>
                        </div>
                        <div>
                            <dt class="text-green-700">Krátkodobá měs. (1–6)</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.effectivePricePerMonthInCzk|number_format(0, ',', ' ') }} Kč</dd>
                        </div>
                        <div>
                            <dt class="text-green-700">Dlouhodobá měs. (6+)</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.effectivePricePerMonthLongTermInCzk|number_format(0, ',', ' ') }} Kč</dd>
                        </div>
                        <div>
                            <dt class="text-green-700">Roční sazba</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.effectivePricePerYearInCzk|number_format(0, ',', ' ') }} Kč</dd>
                        </div>
                    </dl>
                </div>
            </div>
        {% endif %}

        {# Payment schedule preview #}
        {% set schedule = this.paymentSchedule %}
        {% if schedule %}
            <div class="card">
                <div class="card-body">
                    <h2 class="text-lg font-bold text-gray-900 mb-2">Kalkulace plateb</h2>
                    <p class="text-sm font-semibold text-green-700 mb-3">
                        {% if schedule.isYearly and schedule.yearlyAmount %}
                            Roční platba: {{ (schedule.yearlyAmount / 100)|number_format(0, ',', ' ') }} Kč / rok
                        {% elseif schedule.monthlyAmount %}
                            Měsíční platba: {{ (schedule.monthlyAmount / 100)|number_format(0, ',', ' ') }} Kč / měsíc
                        {% endif %}
                    </p>
                    {% if schedule.entries is not empty %}
                        <ul class="text-xs text-gray-600 space-y-1 max-h-40 overflow-y-auto">
                            {% for entry in schedule.entries %}
                                <li class="flex justify-between">
                                    <span>{{ entry.chargeDate|date('d.m.Y') }}</span>
                                    <span class="font-medium">{{ (entry.amount / 100)|number_format(0, ',', ' ') }} Kč</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        {% endif %}

        {# 9. Cenový model #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Cenový model</h2>
                {{ form_row(form.monthlyPriceMode) }}
                {% if monthlyPriceMode == 'custom' %}
                    {{ form_row(form.customMonthlyPriceInCzk) }}
                {% else %}
                    {% do form.customMonthlyPriceInCzk.setRendered %}
                {% endif %}
            </div>
        </div>

        {# 10. Platební metoda #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Platební metoda</h2>
                {{ form_row(form.paymentMethod) }}

                {% if isBankTransfer %}
                    <div class="mt-3 p-3 bg-amber-50 border border-amber-200 rounded-lg">
                        <p class="text-sm text-amber-800">
                            Při platbě bankovním převodem je účtován příplatek {{ this.getBankTransferSurchargeInCzk()|number_format(0, ',', ' ') }} Kč za každé fakturační období.
                        </p>
                    </div>
                    {{ form_row(form.variableSymbol) }}
                {% else %}
                    {% do form.variableSymbol.setRendered %}
                {% endif %}
            </div>
        </div>

        {# 11. Frekvence a způsob plateb #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Frekvence a způsob plateb</h2>
                {{ form_row(form.paymentFrequency) }}

                {% if isYearly or isBankTransfer %}
                    {% if isYearly %}
                        <div class="mt-3 bg-blue-50 border border-blue-200 rounded-lg p-4">
                            <p class="text-sm text-blue-900">
                                <strong>Roční platba se vždy odbavuje ručně.</strong>
                                Kartu si neukládáme — další platbu obdržíte e-mailem před vypršením roku.
                            </p>
                        </div>
                    {% endif %}
                    {% if isBankTransfer and not isYearly %}
                        <div class="mt-3 bg-blue-50 border border-blue-200 rounded-lg p-4">
                            <p class="text-sm text-blue-900">
                                Bankovní převod — zákazník obdrží fakturu e-mailem, platba je vždy ruční.
                            </p>
                        </div>
                    {% endif %}
                    {% do form.billingMode.setRendered %}
                {% else %}
                    {{ form_row(form.billingMode) }}
                {% endif %}
            </div>
        </div>

        {# 12. Externí předplatné #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Externí předplatné</h2>
                {% set paidThroughAttr = {
                    'data-action': 'blur->live#action',
                    'data-live-action-param': 'validateField',
                    'data-live-field-param': 'paidThroughDate',
                } %}
                {% if formData.startsInPast and monthlyPriceMode != 'free' %}
                    <div class="mb-3 bg-amber-50 border border-amber-200 rounded-lg p-4">
                        <p class="text-sm text-amber-800">
                            Datum začátku je v minulosti, proto je externí předplatné automaticky zapnuto.
                            Zadejte datum, do kdy má zákazník předplaceno (musí být dnes nebo v budoucnosti).
                        </p>
                    </div>
                    {% do form.isExternallyPrepaid.setRendered %}
                    {{ form_row(form.paidThroughDate, {attr: paidThroughAttr}) }}
                {% else %}
                    {{ form_row(form.isExternallyPrepaid) }}
                    {% if isExternallyPrepaid %}
                        {{ form_row(form.paidThroughDate, {attr: paidThroughAttr}) }}
                    {% else %}
                        {% do form.paidThroughDate.setRendered %}
                    {% endif %}
                {% endif %}
            </div>
        </div>

        {# 13. Existující smlouva #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Existující smlouva</h2>
                <p class="text-sm text-gray-600 mb-3">
                    Pokud má zákazník již podepsanou papírovou smlouvu, nahrajte ji sem.
                    Zákazník pak podepisuje pouze VOP.
                </p>
                {{ form_row(form.contractDocument) }}
            </div>
        </div>

        {# 14. Dluh z předchozí smlouvy #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Dluh z předchozí smlouvy</h2>
                <p class="text-sm text-gray-600 mb-3">
                    Pokud má zákazník nevyplacený dluh z předchozí smlouvy, zadejte částku.
                    Zákazník musí dluh uhradit před zahájením nového pronájmu.
                </p>
                {{ form_row(form.debtAmountInCzk) }}
            </div>
        </div>

        {# 15. Submit — never disabled; submit() validates and surfaces a scroll-to-error
           (live-form-scroll). data-loading locks the button while the request is in flight
           to prevent a double submit. #}
        <div class="flex justify-end">
            <button type="button"
                    data-action="live#action live-form-scroll#markSubmit"
                    data-live-action-param="submit"
                    data-loading="action(submit)|addAttribute(disabled)"
                    class="btn btn-primary btn-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="hidden animate-spin h-5 w-5 mr-2" data-loading="action(submit)|removeClass(hidden)" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                Vytvořit onboarding
            </button>
        </div>
    </div>

    {{ form_end(form) }}
</div>
