{% import 'components/_address_override.html.twig' as addr %}
{% set formData = form.vars.data %}
{% set invoiceToCompany = formData.invoiceToCompany ?? false %}
{% set paymentMethod = formData.paymentMethod %}
{% set paymentFrequency = formData.paymentFrequency %}
{% set isYearly = paymentFrequency is not null and paymentFrequency.value == 'yearly' %}
{% set isOneTimeUpfront = paymentFrequency is not null and paymentFrequency.value == 'one_time' %}
{% set monthlyPriceMode = formData.monthlyPriceMode %}
{% set isExternallyPrepaid = formData.isExternallyPrepaid ?? false %}
{% set isBankTransfer = paymentMethod is not null and paymentMethod.value == 'bank_transfer' %}
{% set isGopay = paymentMethod is not null and paymentMethod.value == 'gopay' %}
{% set isExternal = paymentMethod is not null and paymentMethod.value == 'external' %}
{% set bankTransferSurchargeInCzk = this.getBankTransferSurchargeInCzk() %}

<div {{ attributes.defaults({
    'data-controller': 'admin-onboarding-bridge live-form-scroll',
    'data-action': 'storage-map:select->admin-onboarding-bridge#handleStorageSelect',
}) }}>
    {{ form_start(form, {attr: {novalidate: 'novalidate', 'data-turbo': 'false'}}) }}

    <div class="space-y-8 max-w-4xl">
        {% if this.submitError %}
            <div class="rounded-lg border border-red-300 bg-red-50 p-4 text-sm text-red-800">
                {{ this.submitError }}
            </div>
        {% endif %}
        {# 1. Kontaktní údaje zákazníka #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Kontaktní údaje zákazníka</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {{ form_row(form.email) }}
                    {{ form_row(form.firstName) }}
                    {{ form_row(form.lastName) }}
                    {{ form_row(form.phone) }}
                    {% if not invoiceToCompany %}
                        {{ form_row(form.birthDate, {attr: {
                            'data-action': 'blur->live#action',
                            'data-live-action-param': 'validateField',
                            'data-live-field-param': 'birthDate',
                        }}) }}
                    {% else %}
                        {% do form.birthDate.setRendered %}
                    {% endif %}
                </div>
            </div>
        </div>

        {# 2. Fakturační údaje #}
        <div class="card overflow-visible" data-controller="ares-lookup">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Fakturační údaje</h2>
                {{ form_row(form.invoiceToCompany) }}

                {% if invoiceToCompany %}
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-4">
                        <div>
                            {{ form_label(form.companyId, null, {label_attr: {class: 'form-label-required'}}) }}
                            <div class="flex">
                                {{ form_widget(form.companyId, {attr: {
                                    'class': 'flex-1 min-w-0 rounded-r-none!',
                                }}) }}
                                {% include 'components/ares_lookup_button.html.twig' %}
                            </div>
                            <p data-ares-lookup-target="status" class="text-sm mt-2" aria-live="polite" data-live-ignore></p>
                            {{ form_errors(form.companyId) }}
                        </div>
                        <div>
                            {{ form_row(form.companyName, {label_attr: {class: 'form-label-required'}}) }}
                        </div>
                        <div>
                            {{ form_row(form.companyVatId) }}
                        </div>
                    </div>
                {% else %}
                    {% do form.companyId.setRendered %}
                    {% do form.companyName.setRendered %}
                    {% do form.companyVatId.setRendered %}
                {% endif %}

                <h3 class="font-semibold text-gray-800 mt-6 mb-1">{{ invoiceToCompany ? 'Sídlo společnosti' : 'Fakturační adresa' }}</h3>
                {# The card opens with the company checkbox, so without this hint the
                   address reads as company-only — it is required for every customer. #}
                <p class="text-sm text-gray-500 mb-3">{{ invoiceToCompany ? 'Adresa sídla z obchodního rejstříku.' : 'Adresa zákazníka pro smlouvu a fakturaci — povinný údaj.' }}</p>
                {{ addr.render_live(form, false) }}
            </div>
        </div>

        {# 3. Datum #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Datum</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {{ form_row(form.startDate) }}
                    <div data-controller="duration-preset"
                         data-duration-preset-min-gap-days-value="7"
                         data-duration-preset-max-months-value="0">
                        {{ form_row(form.endDate) }}

                        <div class="mt-2 flex flex-wrap gap-2">
                            <span class="text-xs text-gray-500 self-center mr-1">Rychlá volba:</span>
                            {% for months in [3, 6, 12] %}
                                <button type="button"
                                        data-duration-preset-target="button"
                                        data-action="duration-preset#apply"
                                        data-months="{{ months }}"
                                        class="btn btn-outline btn-sm">
                                    {{ months == 12 ? '1 rok' : (months >= 5 ? months ~ ' měsíců' : months ~ ' měsíce') }}
                                </button>
                            {% endfor %}
                        </div>

                        <p data-duration-preset-target="hint" class="text-xs text-gray-500 mt-1" hidden>
                            Nejdříve zvolte datum začátku.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        {# 5. Pobočka #}
        <div class="card" data-form-error-section>
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Pobočka</h2>
                {% if this.storageError %}
                    <p class="form-error mb-3" data-live-error role="alert">{{ this.storageError }}</p>
                {% endif %}
                <div>
                    <label for="admin-onboarding-place" class="form-label">Pobočka</label>
                    <select id="admin-onboarding-place"
                            data-model="norender|placeId"
                            data-action="change->live#action"
                            data-live-action-param="onPlaceChange"
                            class="form-input w-full">
                        <option value="">-- Vyberte pobočku --</option>
                        {% for place in this.places %}
                            <option value="{{ place.id }}" {{ this.placeId == place.id.toRfc4122() ? 'selected' }}>
                                {{ place.name }}{% if place.city %} ({{ place.city }}){% endif %}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </div>
        </div>

        {# 6. Typ skladovací jednotky #}
        {% if this.placeId %}
            <div class="card">
                <div class="card-body">
                    <h2 class="text-lg font-bold text-gray-900 mb-4">Typ skladovací jednotky</h2>
                    <div>
                        <label for="admin-onboarding-storage-type" class="form-label">Typ</label>
                        <select id="admin-onboarding-storage-type"
                                data-model="norender|storageTypeId"
                                data-action="change->live#action"
                                data-live-action-param="onStorageTypeChange"
                                class="form-input w-full">
                            <option value="">-- Vyberte typ --</option>
                            {% for type in this.storageTypes %}
                                <option value="{{ type.id }}" {{ this.storageTypeId == type.id.toRfc4122() ? 'selected' }}>
                                    {{ type.name }} ({{ type.dimensionsInMeters }})
                                    — {{ (type.defaultPricePerMonthLongTerm / 100)|number_format(0, ',', ' ') }} Kč/měs
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
            </div>
        {% endif %}

        {# 7. Mapa skladu #}
        {% set selectedPlace = this.selectedPlace %}
        {% set selectedStorageType = this.selectedStorageType %}
        {% if selectedPlace and selectedStorageType and selectedPlace.mapImagePath and this.hasValidWindow() %}
            <div class="card">
                <div class="card-body">
                    <h2 class="text-lg font-bold text-gray-900 mb-4">Výběr skladové jednotky</h2>
                    <p class="text-sm text-gray-600 mb-4">Klikněte na dostupnou (zelenou) skladovou jednotku na mapě.</p>
                    <div data-controller="storage-map"
                         data-storage-map-map-image-value="{{ asset('uploads/' ~ selectedPlace.mapImagePath) }}"
                         data-storage-map-storages-value="{{ this.storagesJson|e('html_attr') }}"
                         data-storage-map-place-id-value="{{ this.placeId }}"
                         data-storage-map-current-storage-type-id-value="{{ this.storageTypeId }}"
                         data-storage-map-select-mode-value="true"
                         data-storage-map-highlight-storage-value="{{ this.storageId ?? '' }}">
                        <div data-storage-map-target="container" data-live-ignore
                             class="border border-gray-300 rounded-lg w-full" style="min-height: 400px;"></div>
                        <div data-storage-map-target="minimap"
                             class="hidden absolute bottom-2 right-2 border border-gray-400 rounded-md bg-white shadow-md"
                             data-live-ignore></div>
                        <div data-storage-map-target="tooltip"
                             class="hidden fixed z-50 pointer-events-none bg-white border border-gray-200 rounded-md shadow-lg p-3 text-xs max-w-xs"></div>
                    </div>
                </div>
            </div>
        {% elseif selectedPlace and selectedStorageType and selectedPlace.mapImagePath %}
            {# Place + type + map are ready, but the availability query has no rental window yet.
               Rendering the map now would paint every unit as greyed-out "nedostupný" (reads as broken),
               so hold it back behind a concise prompt until the dates are chosen. #}
            <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
                Nejdříve zvolte termín pronájmu — poté se zobrazí mapa s dostupností skladových jednotek.
            </div>
        {% elseif selectedPlace and selectedStorageType and not selectedPlace.mapImagePath %}
            <div class="rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
                Tato pobočka nemá nahrán mapový podklad. Skladovou jednotku nelze vybrat z mapy.
            </div>
        {% endif %}

        {# 8. Vybraná skladová jednotka #}
        {% set selectedStorage = this.selectedStorage %}
        {% if selectedStorage %}
            <div class="card border-green-200 bg-green-50">
                <div class="card-body">
                    <h2 class="text-lg font-bold text-green-900 mb-2">Vybraná skladová jednotka</h2>
                    <dl class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
                        <div>
                            <dt class="text-green-700">Číslo</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.number }}</dd>
                        </div>
                        <div>
                            <dt class="text-green-700">Rozměry</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.storageType.dimensionsInMeters }}</dd>
                        </div>
                        <div>
                            <dt class="text-green-700">Týdenní sazba</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.effectivePricePerWeekInCzk|number_format(0, ',', ' ') }} Kč <span class="font-normal text-xs text-green-700">za týden</span></dd>
                        </div>
                        <div>
                            <dt class="text-green-700">Sazba na 1–6 měs.</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.effectivePricePerMonthInCzk|number_format(0, ',', ' ') }} Kč <span class="font-normal text-xs text-green-700">za měsíc</span></dd>
                        </div>
                        <div>
                            <dt class="text-green-700">Sazba na 6+ měs.</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.effectivePricePerMonthLongTermInCzk|number_format(0, ',', ' ') }} Kč <span class="font-normal text-xs text-green-700">za měsíc</span></dd>
                        </div>
                        <div>
                            <dt class="text-green-700">Sazba roční předem</dt>
                            <dd class="font-semibold text-green-900">{{ selectedStorage.effectivePricePerYearInCzk|number_format(0, ',', ' ') }} Kč <span class="font-normal text-xs text-green-700">za rok</span></dd>
                        </div>
                    </dl>
                </div>
            </div>
        {% endif %}

        {# 9. Platební metoda — metoda se volí PRVNÍ; karta frekvence níže se jí přizpůsobuje. #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Platební metoda</h2>
                {{ form_row(form.paymentMethod) }}

                {% if isGopay %}
                    {# Karta = vždy automatická měsíční platba (spec 076) — vysvětluje, proč se nezobrazuje volba frekvence. #}
                    <div class="mt-3 bg-blue-50 border border-blue-200 rounded-lg p-4">
                        <p class="text-sm text-blue-900">
                            GoPay — zákazník při podpisu nastaví automatickou měsíční platbu kartou.
                            Frekvence platby je vždy automatická měsíční, není potřeba ji volit.
                        </p>
                    </div>
                {% endif %}

                {% if isBankTransfer %}
                    {% if bankTransferSurchargeInCzk > 0 %}
                        <div class="mt-3 p-3 bg-amber-50 border border-amber-200 rounded-lg">
                            <p class="text-sm text-amber-800">
                                Při platbě bankovním převodem je účtován příplatek {{ bankTransferSurchargeInCzk|number_format(0, ',', ' ') }} Kč za každé fakturační období.
                            </p>
                        </div>
                    {% endif %}
                    {{ form_row(form.variableSymbol) }}
                {% else %}
                    {% do form.variableSymbol.setRendered %}
                {% endif %}
            </div>
        </div>

        {# 10. Frekvence plateb — billing mode je odvozený (spec 076): karta = automatická
           měsíční, převod/externí = ruční, roční = vždy ruční převodem. Pro GoPay se karta
           skrývá úplně (frekvenci není co volit) a AdminOnboardingFormType::PRE_SUBMIT
           normalizuje odeslanou frekvenci na MONTHLY, takže skrytá zastaralá hodnota
           nikdy nespustí GOPAY violaci. #}
        {% if isGopay %}
            {% do form.paymentFrequency.setRendered %}
        {% else %}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Frekvence plateb</h2>

                {# Ruční smyčka radio voleb: každá nabízená volba nese vlastní popis.
                   ONE_TIME se pro EXTERNAL nenabízí (použijte „Externí předplatné" /
                   „Předplaceno do") — validátor ve FormData je pojistkou pro zastaralou
                   odeslanou hodnotu. #}
                {% set upfrontTranched = this.isUpfrontSplitIntoTranches() %}
                {% set frequencyChoices = [] %}
                {% for child in form.paymentFrequency %}
                    {% if isExternal and child.vars.value == 'one_time' %}
                        {% do child.setRendered %}
                    {% else %}
                        {% set frequencyChoices = frequencyChoices|merge([child]) %}
                    {% endif %}
                {% endfor %}

                <div class="space-y-3">
                    {% for child in frequencyChoices %}
                        <div class="flex items-start">
                            {{ form_widget(child, {attr: {'class': 'mt-0.5'}}) }}
                            <label for="{{ child.vars.id }}" class="ml-3 text-sm text-gray-700 cursor-pointer">
                                {{ child.vars.label }}
                                <span class="block text-xs text-gray-500 mt-0.5">
                                    {% if child.vars.value == 'monthly' %}
                                        Platba každý měsíc — u bankovního převodu na základě e-mailové výzvy.
                                    {% elseif child.vars.value == 'yearly' %}
                                        Jedna platba předem na každý rok pronájmu se slevou 10 % — platí se převodem nebo externě, účtuje se ručně.
                                    {% elseif upfrontTranched %}
                                        Celý pronájem předem — první platba pokryje prvních 12 měsíců, zbytek se platí po roce na základě e-mailové výzvy.
                                    {% else %}
                                        Celý pronájem předem jedním bankovním převodem.
                                    {% endif %}
                                </span>
                            </label>
                        </div>
                    {% endfor %}
                </div>
                {{ form_errors(form.paymentFrequency) }}

                {% if frequencyChoices|length == 1 %}
                    <p class="text-xs text-gray-500 mt-3">
                        Další možnosti frekvence platby se zobrazí podle zvolené délky pronájmu.
                    </p>
                {% endif %}

                {% if isYearly %}
                    <div class="mt-3 bg-blue-50 border border-blue-200 rounded-lg p-4">
                        <p class="text-sm text-blue-900">
                            <strong>Roční platba se vždy odbavuje ručně a platí se převodem nebo externě.</strong>
                            Karta se neukládá — výzvu k další platbě obdrží zákazník e-mailem před vypršením roku.
                        </p>
                    </div>
                {% elseif isOneTimeUpfront %}
                    <div class="mt-3 bg-blue-50 border border-blue-200 rounded-lg p-4">
                        {% if upfrontTranched %}
                            {# Spec 078 tranches: > 12 měsíců → jedna platba za každých započatých 12 měsíců. #}
                            <p class="text-sm text-blue-900">
                                <strong>Pronájem delší než 12 měsíců zákazník zaplatí předem v ročních platbách</strong>
                                — nyní prvních 12 měsíců, další vždy na začátku dalších 12 měsíců bankovním převodem.
                            </p>
                        {% else %}
                            <p class="text-sm text-blue-900">
                                <strong>Celou částku za pronájem zákazník zaplatí předem jedním bankovním převodem.</strong>
                                Žádné další platby v průběhu pronájmu.
                            </p>
                        {% endif %}
                    </div>
                {% elseif isBankTransfer %}
                    <div class="mt-3 bg-blue-50 border border-blue-200 rounded-lg p-4">
                        <p class="text-sm text-blue-900">
                            Bankovní převod — zákazník obdrží před každou platbou e-mail s platebními údaji a QR kódem.
                        </p>
                    </div>
                {% endif %}
            </div>
        </div>
        {% endif %}

        {# 11. Cenový model — až za metodou a frekvencí: individuální cena je
           měsíční / roční / celková podle zvolené frekvence a popisek pole se
           jí přizpůsobuje, takže admin nejdřív volí JAK se platí a teprve pak
           KOLIK. #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Cenový model</h2>
                {{ form_row(form.monthlyPriceMode) }}
                {% if monthlyPriceMode == 'custom' %}
                    {{ form_row(form.customMonthlyPriceInCzk) }}
                {% else %}
                    {% do form.customMonthlyPriceInCzk.setRendered %}
                {% endif %}
            </div>
        </div>

        {# Kalkulace plateb — hned pod cenovým modelem: přepočítává se živě podle
           VŠECH vstupů (cenový model včetně individuální ceny, frekvence, metoda,
           externí předplatné). Obsah dodává OnboardingSchedulePreview. #}
        {% set preview = this.schedulePreview %}
        {% if preview %}
            <div class="card">
                <div class="card-body">
                    <h2 class="text-lg font-bold text-gray-900 mb-2">Kalkulace plateb</h2>
                    {% if preview.isFree %}
                        <p class="text-sm font-semibold text-green-700">
                            Smlouva je zdarma — zákazníkovi se nebude účtovat žádná platba.
                        </p>
                    {% elseif preview.isFullyPrepaid %}
                        <p class="text-sm font-semibold text-green-700">
                            Celý pronájem je předplacen externě do {{ preview.prepaidUntil|date('d.m.Y') }} — nebude se účtovat žádná platba.
                        </p>
                    {% elseif preview.schedule %}
                        {% set schedule = preview.schedule %}
                        {% if preview.customPriceFallback == 'missing' %}
                            <p class="text-xs text-amber-700 mb-2">
                                Zadejte individuální cenu — kalkulace níže zatím vychází ze standardního ceníku.
                            </p>
                        {% elseif preview.customPriceFallback == 'upfront_tranches' %}
                            <p class="text-xs text-amber-700 mb-2">
                                Individuální celková cena je možná jen u jednorázové platby do 12 měsíců — kalkulace níže vychází ze standardního ceníku.
                            </p>
                        {% endif %}
                        <p class="text-sm font-semibold text-green-700 mb-3">
                            {% if schedule.isYearly %}
                                Roční platba: {{ (schedule.yearlyAmount / 100)|number_format(0, ',', ' ') }} Kč / rok
                            {% elseif not schedule.isRecurring %}
                                {# Spec 078 upfront: whole-rental prepay; > 12 months splits into
                                   yearly tranches (rozpis níže). monthlyAmount is only the equivalence
                                   rate — an individual upfront total has none. #}
                                {% if schedule.entryCount > 1 %}
                                    Platba předem ve {{ schedule.entryCount }} platbách (po 12 měsících): první {{ schedule.firstPayment.amountInCzk|number_format(0, ',', ' ') }} Kč{% if schedule.monthlyAmount %} (odpovídá {{ (schedule.monthlyAmount / 100)|number_format(0, ',', ' ') }} Kč / měsíc){% endif %}
                                {% else %}
                                    Jednorázová platba{{ isOneTimeUpfront ? ' předem' }}: {{ schedule.firstPayment.amountInCzk|number_format(0, ',', ' ') }} Kč{% if schedule.monthlyAmount %} (odpovídá {{ (schedule.monthlyAmount / 100)|number_format(0, ',', ' ') }} Kč / měsíc){% endif %}
                                {% endif %}
                            {% elseif schedule.monthlyAmount %}
                                Měsíční platba: {{ (schedule.monthlyAmount / 100)|number_format(0, ',', ' ') }} Kč / měsíc
                            {% endif %}
                        </p>
                        {% if preview.prepaidUntil %}
                            <p class="text-xs text-blue-700 mb-2">
                                {% if preview.isAnchoredAtPaidThrough %}
                                    Zákazník má předplaceno do {{ preview.prepaidUntil|date('d.m.Y') }} — kalkulace zobrazuje až platby od tohoto data.
                                {% else %}
                                    Zákazník má předplaceno do {{ preview.prepaidUntil|date('d.m.Y') }}.
                                {% endif %}
                            </p>
                        {% endif %}
                        {% if schedule.entries is not empty %}
                            <ul class="text-xs text-gray-600 space-y-1 max-h-40 overflow-y-auto">
                                {% for entry in schedule.entries %}
                                    <li class="flex justify-between">
                                        <span>{{ entry.chargeDate|date('d.m.Y') }}</span>
                                        <span class="font-medium">{{ (entry.amount / 100)|number_format(0, ',', ' ') }} Kč</span>
                                    </li>
                                {% endfor %}
                            </ul>
                            {% if schedule.entryCount > 1 and not schedule.isOpenEnded %}
                                <p class="text-xs text-gray-700 mt-2 pt-2 border-t border-gray-200 flex justify-between font-semibold">
                                    <span>Celkem</span>
                                    <span>{{ schedule.totalKnownAmountInCzk|number_format(0, ',', ' ') }} Kč</span>
                                </p>
                            {% endif %}
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% endif %}

        {# 12. Externí předplatné #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Externí předplatné</h2>
                {% set paidThroughAttr = {
                    'data-action': 'blur->live#action',
                    'data-live-action-param': 'validateField',
                    'data-live-field-param': 'paidThroughDate',
                } %}
                {% if formData.startsInPast and monthlyPriceMode != 'free' %}
                    <div class="mb-3 bg-amber-50 border border-amber-200 rounded-lg p-4">
                        <p class="text-sm text-amber-800">
                            Datum začátku je v minulosti, proto je externí předplatné automaticky zapnuto.
                            Zadejte datum, do kdy má zákazník předplaceno (musí být dnes nebo v budoucnosti).
                        </p>
                    </div>
                    {% do form.isExternallyPrepaid.setRendered %}
                    {{ form_row(form.paidThroughDate, {attr: paidThroughAttr}) }}
                {% else %}
                    {{ form_row(form.isExternallyPrepaid) }}
                    {% if isExternallyPrepaid %}
                        {{ form_row(form.paidThroughDate, {attr: paidThroughAttr}) }}
                    {% else %}
                        {% do form.paidThroughDate.setRendered %}
                    {% endif %}
                {% endif %}
            </div>
        </div>

        {# 13. Existující smlouva #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Existující smlouva</h2>
                <p class="text-sm text-gray-600 mb-3">
                    Pokud má zákazník již podepsanou papírovou smlouvu, nahrajte ji sem.
                    Zákazník pak podepisuje pouze VOP.
                </p>
                {{ form_row(form.contractDocument) }}
            </div>
        </div>

        {# 14. Dluh z předchozí smlouvy #}
        <div class="card">
            <div class="card-body">
                <h2 class="text-lg font-bold text-gray-900 mb-4">Dluh z předchozí smlouvy</h2>
                <p class="text-sm text-gray-600 mb-3">
                    Pokud má zákazník nevyplacený dluh z předchozí smlouvy, zadejte částku.
                    Zákazník musí dluh uhradit před zahájením nového pronájmu.
                </p>
                {{ form_row(form.debtAmountInCzk) }}
            </div>
        </div>

        {# 15. Submit — never disabled; submit() validates and surfaces a scroll-to-error
           (live-form-scroll). data-loading locks the button while the request is in flight
           to prevent a double submit. #}
        <div class="flex justify-end">
            <button type="button"
                    data-action="live#action live-form-scroll#markSubmit"
                    data-live-action-param="submit"
                    data-loading="action(submit)|addAttribute(disabled)"
                    class="btn btn-primary btn-lg">
                <svg xmlns="http://www.w3.org/2000/svg" class="hidden animate-spin h-5 w-5 mr-2" data-loading="action(submit)|removeClass(hidden)" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
                Vytvořit onboarding
            </button>
        </div>
    </div>

    {{ form_end(form) }}
</div>
