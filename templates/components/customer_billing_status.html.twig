{# Customer-facing badge / banner reflecting non-standard billing state.
   Renders nothing for vanilla recurring contracts.

   Inputs:
     contract           Contract|null         — null hides everything
     now                \DateTimeImmutable    — used for the 7-day window calculation
     manualNowVariableSymbol string|null      — variable symbol of a pending unpaid manual-billing cycle (spec 076: paid by bank transfer)
     manualNowBankAccount string|null         — formatted bank account for the pending cycle
     manualNowAmount    int|null              — amount in haler of the pending manual-billing request
     manualNowPeriodStart \DateTimeImmutable|null — period-start date of the pending manual-billing request
     nextManualDate     \DateTimeImmutable|null — date of the next d-7 reminder when no request is open right now

   Free wins over external prepayment when both are set: a zero-priced contract
   has no recurring charge to resume, so the prepayment banner would mislead.
   MANUAL variants take priority over external-prepayment because the
   immediate action (pay-now CTA) is more urgent than the future banner.
#}
{% if contract is not null %}
    {% if contract.isYearly() and not contract.isFree() %}
        {# YEARLY cadence — billed once a year via manual cron. paidThroughDate
           doubles as the next-billing anchor; daysUntilExternalPrepaymentEnds
           explicitly returns null for yearly contracts so the prepayment banner
           never fires here. #}
        <div class="mb-4 rounded-lg border border-teal-200 bg-teal-50 p-4">
            <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-teal-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <div class="flex-1 text-sm text-teal-900">
                    <strong>Platíte ročně.</strong>
                    {% if contract.paidThroughDate %}
                        Předplaceno do {{ contract.paidThroughDate|date('d.m.Y') }}. Před vypršením Vám pošleme e-mail s platebními údaji pro bankovní převod.
                    {% else %}
                        Před každou roční platbou Vám pošleme e-mail s platebními údaji pro bankovní převod.
                    {% endif %}
                </div>
            </div>
        </div>
    {% elseif contract.usesManualBillingTrack() and not contract.isFree() %}
        {# Covers MANUAL_RECURRING cycles and outstanding upfront tranches
           (spec 078: ONE_TIME with a billing anchor) — both are paid by bank
           transfer against a payment-request e-mail. #}
        {% if manualNowVariableSymbol is defined and manualNowVariableSymbol is not null and manualNowAmount is defined and manualNowAmount is not null %}
            <div class="mb-4 rounded-lg border border-amber-300 bg-amber-50 p-4">
                <div class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1" />
                    </svg>
                    <div class="flex-1 text-sm text-amber-900">
                        <strong>Platba k zaplacení:</strong>
                        {{ (manualNowAmount / 100)|number_format(2, ',', ' ') }} Kč vč. DPH — splatná {{ manualNowPeriodStart|date('d.m.Y') }}.
                        <dl class="mt-2 grid grid-cols-[auto_1fr] gap-x-4 gap-y-1">
                            {% if manualNowBankAccount is defined and manualNowBankAccount is not null %}
                                <dt class="text-amber-800">Číslo účtu:</dt>
                                <dd class="font-mono font-semibold">{{ manualNowBankAccount }}</dd>
                            {% endif %}
                            <dt class="text-amber-800">Variabilní symbol:</dt>
                            <dd class="font-mono font-semibold">{{ manualNowVariableSymbol }}</dd>
                        </dl>
                        <img src="{{ path('public_qr_payment_image', {variableSymbol: manualNowVariableSymbol, amountInHaler: manualNowAmount}) }}"
                             alt="QR platba" width="160" height="160" class="mt-3 rounded border border-amber-200 bg-white">
                    </div>
                </div>
            </div>
        {% else %}
            <div class="mb-4 rounded-lg border border-blue-200 bg-blue-50 p-4">
                <div class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <div class="flex-1 text-sm text-blue-900">
                        <strong>Platby probíhají ručně.</strong>
                        Před každou platbou (7 dní předem) Vám pošleme e-mail s platebními údaji a QR kódem pro bankovní převod.
                        {% if nextManualDate is defined and nextManualDate is not null %}
                            Příští: <strong>{{ nextManualDate|date('d.m.Y') }}</strong>.
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endif %}
    {% elseif contract.isFree() %}
        <div class="mb-4 inline-flex items-center gap-2 rounded-md bg-green-50 border border-green-200 px-3 py-2">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800">
                Pronájem zdarma
            </span>
            <span class="text-sm text-green-800">Tato smlouva nepodléhá platbám.</span>
        </div>
    {% else %}
        {% set daysLeft = contract.daysUntilExternalPrepaymentEnds(now) %}
        {% if daysLeft is not null and daysLeft >= 0 %}
            {% if daysLeft <= 7 %}
                <div class="mb-4 rounded-lg border border-amber-200 bg-amber-50 p-4">
                    <div class="flex items-start gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                        <div class="flex-1 text-sm text-amber-900">
                            <strong>Externí předplatné brzy končí.</strong>
                            Předplatné vyprší {{ contract.paidThroughDate|date('d.m.Y') }}.
                            Pro pokračování bez přerušení nás prosím kontaktujte na
                            <a href="mailto:simek@fajnesklady.cz" class="link font-medium">simek@fajnesklady.cz</a>
                            a nastavíme automatickou platbu.
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="mb-4 rounded-lg border border-blue-200 bg-blue-50 p-4">
                    <div class="flex items-start gap-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <div class="flex-1 text-sm text-blue-900">
                            <strong>Předplaceno externě do {{ contract.paidThroughDate|date('d.m.Y') }}.</strong>
                            Po tomto datu se obnoví běžné měsíční platby.
                        </div>
                    </div>
                </div>
            {% endif %}
        {% endif %}
    {% endif %}
{% endif %}
