{% set selectedStorage = this.selectedStorage %}
{% set storageType = this.storageType %}
{% set place = this.place %}
{% set weeklyPrice = selectedStorage.getEffectivePricePerWeekInCzk() %}
{% set monthlyPrice = selectedStorage.getEffectivePricePerMonthInCzk() %}
{% set longTermMonthlyPrice = selectedStorage.getEffectivePricePerMonthLongTermInCzk() %}
{% set yearlyPrice = selectedStorage.getEffectivePricePerYearInCzk() %}
{% set isAutoSelection = this.selectionMode == 'auto' %}
{% import 'components/_address_override.html.twig' as addr %}
{# Show/hide of conditional sections is server-driven (not Alpine x-show) so it survives Live UX morphing. #}
{% set invoiceToCompany = form.vars.data.invoiceToCompany ?? false %}
{% set rentalIsLimited = form.vars.data.rentalType is null or form.vars.data.rentalType.value == 'limited' %}
{% set isYearly = form.vars.data.paymentFrequency is defined and form.vars.data.paymentFrequency.value == 'yearly' and this.isEligibleForFrequencyChoice() %}
{# Availability map data — derived for the chosen window by the SAME checker enforcement uses; re-rendered on every date/type change so the map repaints reactively. #}
{% set mapStoragesJson = this.getStoragesJson() %}

<div {{ attributes.defaults({
    'data-controller': 'live-form-scroll order-map-bridge order-selection-mode',
    'data-action': 'storage-map:select->order-map-bridge#selectStorage',
}) }}>
    <div class="grid lg:grid-cols-3 gap-8">
        {# Order Form #}
        <div class="lg:col-span-2 order-2 lg:order-1">
            <div class="card">
                <div class="card-body">
                    <h1 class="text-2xl font-bold text-gray-900 mb-6">Vytvořit objednávku</h1>

                    {{ form_start(form, {attr: {
                        'novalidate': 'novalidate',
                        'class': 'space-y-8',
                        'data-action': 'submit->live#action:prevent live-form-scroll#markSubmit',
                        'data-live-action-param': 'submit',
                    }}) }}

                        {# Contact Information #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                Kontaktní údaje
                            </h2>

                            <div class="grid md:grid-cols-2 gap-4">
                                <div>
                                    {{ form_row(form.firstName, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'firstName',
                                    }}) }}
                                </div>
                                <div>
                                    {{ form_row(form.lastName, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'lastName',
                                    }}) }}
                                </div>
                            </div>

                            <div class="grid md:grid-cols-2 gap-4">
                                <div>
                                    {{ form_row(form.email, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'email',
                                    }}) }}
                                </div>
                                <div>
                                    {{ form_row(form.phone, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'phone',
                                    }}) }}
                                </div>
                            </div>

                            {% if not invoiceToCompany %}
                                <div class="grid md:grid-cols-2 gap-4">
                                    <div>
                                        {{ form_row(form.birthDate, {attr: {
                                            'data-action': 'blur->live#action',
                                            'data-live-action-param': 'validateField',
                                            'data-live-field-param': 'birthDate',
                                        }}) }}
                                    </div>
                                </div>
                            {% else %}
                                {# Suppress form_end's auto-render of unrendered fields. validateBirthDate skips when invoiceToCompany is true. #}
                                {% do form.birthDate.setRendered %}
                            {% endif %}

                            {% if not app.user %}
                                {% if this.emailExistsInSystem %}
                                    <div class="mt-4 rounded-lg bg-blue-50 border border-blue-200 p-4 text-sm text-blue-800">
                                        <div class="flex items-start">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 mt-0.5 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                            </svg>
                                            <span>Účet s tímto e-mailem již existuje. Objednávka bude přiřazena k vašemu účtu a naleznete ji v portálu po přihlášení.</span>
                                        </div>
                                    </div>
                                    {% do form.plainPassword.setRendered %}
                                {% else %}
                                    <div class="mt-4">
                                        {{ form_row(form.plainPassword, {attr: {
                                            'data-action': 'blur->live#action',
                                            'data-live-action-param': 'validateField',
                                            'data-live-field-param': 'plainPassword',
                                        }}) }}
                                    </div>
                                {% endif %}
                            {% else %}
                                {% do form.plainPassword.setRendered %}
                            {% endif %}
                        </div>

                        <div data-controller="ares-lookup" class="space-y-8">
                        {# Company Information #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                                </svg>
                                Firemní údaje
                            </h2>

                            <div class="mb-4">
                                <label class="flex items-center cursor-pointer">
                                    {{ form_widget(form.invoiceToCompany, {attr: {'class': 'mr-3'}}) }}
                                    <span class="text-sm font-medium text-gray-700">Nájemce je společnost / OSVČ</span>
                                </label>
                            </div>

                            {% if invoiceToCompany %}
                                <div class="space-y-4">
                                    <div>
                                        {{ form_label(form.companyId, null, {label_attr: {class: 'form-label-required'}}) }}
                                        <div class="flex">
                                            {{ form_widget(form.companyId, {attr: {
                                                'class': 'flex-1 min-w-0 rounded-r-none!',
                                                'data-action': 'blur->live#action',
                                                'data-live-action-param': 'validateField',
                                                'data-live-field-param': 'companyId',
                                            }}) }}
                                            {% include 'components/ares_lookup_button.html.twig' %}
                                        </div>
                                        {# data-live-ignore: the ARES Stimulus controller writes the status text/colour
                                           client-side; without this the message is wiped on every Live UX re-render. #}
                                        <p data-ares-lookup-target="status" class="text-sm mt-2" aria-live="polite" data-live-ignore></p>
                                        {{ form_errors(form.companyId) }}
                                    </div>

                                    <div class="grid md:grid-cols-2 gap-4">
                                        <div>
                                            {{ form_row(form.companyName, {label_attr: {class: 'form-label-required'}, attr: {
                                                'data-action': 'blur->live#action',
                                                'data-live-action-param': 'validateField',
                                                'data-live-field-param': 'companyName',
                                            }}) }}
                                        </div>
                                        <div>
                                            {{ form_row(form.companyVatId, {attr: {
                                                'data-action': 'blur->live#action',
                                                'data-live-action-param': 'validateField',
                                                'data-live-field-param': 'companyVatId',
                                            }}) }}
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                {# Suppress form_end's auto-render of unrendered fields. validateCompanyInfo skips when invoiceToCompany is false. #}
                                {% do form.companyId.setRendered %}
                                {% do form.companyName.setRendered %}
                                {% do form.companyVatId.setRendered %}
                            {% endif %}
                        </div>

                        {# Address - always required for the contract #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                <span>{{ invoiceToCompany ? 'Sídlo společnosti' : 'Adresa bydliště' }}</span>
                            </h2>

                            <p class="text-xs text-gray-500 mb-4">Vyžadováno pro účely nájemní smlouvy.</p>

                            {{ addr.render_live(form) }}
                        </div>
                        </div>

                        {# Rental Type #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                Typ pronájmu
                            </h2>

                            <div>
                                {{ form_widget(form.rentalType) }}
                            </div>

                            {% if rentalIsLimited %}
                                <div class="mt-4 p-4 bg-amber-50 border border-amber-200 rounded-lg">
                                    <p class="text-sm text-amber-800">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M5.07 19h13.86a2 2 0 001.74-3L13.74 4a2 2 0 00-3.48 0L3.33 16a2 2 0 001.74 3z" />
                                        </svg>
                                        Negarantujeme dostupnost stejné skladovací jednotky při prodloužení smlouvy – skladovací jednotka může být již rezervovaná.
                                    </p>
                                </div>
                                {# Hidden in LIMITED branch — form_end's setRendered cleanup keeps the unsubmitted field happy. #}
                                {% do form.expectedDuration.setRendered %}
                            {% else %}
                                <div class="mt-4 p-4 bg-accent/10 border border-accent/20 rounded-lg">
                                    <p class="text-sm text-gray-700">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        Pronájem na dobu určitou s automatickým prodlužováním. Opakované platby můžete kdykoliv zrušit — smlouva skončí na konci aktuálně zaplaceného období.
                                    </p>
                                </div>

                                <div class="mt-4">
                                    {{ form_row(form.expectedDuration, {attr: {
                                        'data-action': 'change->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'expectedDuration',
                                    }}) }}
                                </div>
                            {% endif %}
                        </div>

                        {# Dates #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                Období pronájmu
                            </h2>

                            <div class="grid md:grid-cols-2 gap-4">
                                <div>
                                    {{ form_row(form.startDate, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'startDate',
                                    }}) }}
                                </div>
                                {% if rentalIsLimited %}
                                    <div data-controller="duration-preset"
                                         data-duration-preset-min-gap-days-value="7"
                                         data-duration-preset-max-months-value="12">
                                        {{ form_row(form.endDate, {attr: {
                                            'data-action': 'blur->live#action',
                                            'data-live-action-param': 'validateField',
                                            'data-live-field-param': 'endDate',
                                        }}) }}

                                        <div class="mt-2 flex flex-wrap gap-2">
                                            <span class="text-xs text-gray-500 self-center mr-1">Rychlá volba:</span>
                                            {% for months in [1, 3, 6] %}
                                                <button type="button"
                                                        data-duration-preset-target="button"
                                                        data-action="duration-preset#apply"
                                                        data-months="{{ months }}"
                                                        class="btn btn-outline btn-sm">
                                                    {{ months }} {{ months == 1 ? 'měsíc' : (months < 5 ? 'měsíce' : 'měsíců') }}
                                                </button>
                                            {% endfor %}
                                        </div>

                                        <p data-duration-preset-target="hint" class="text-xs text-gray-500 mt-1" hidden>
                                            Nejdříve zvolte datum začátku.
                                        </p>
                                    </div>
                                {% else %}
                                    {# Suppress form_end's auto-render. validateDates skips endDate for unlimited rentals. #}
                                    {% do form.endDate.setRendered %}
                                {% endif %}
                            </div>
                        </div>

                        {% if this.isEligibleForFrequencyChoice() %}
                            <div class="bg-gray-50 rounded-lg p-6">
                                <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    Frekvence platby
                                </h2>
                                {{ form_row(form.paymentFrequency, {attr: {
                                    'data-action': 'change->live#action',
                                    'data-live-action-param': 'validateField',
                                    'data-live-field-param': 'paymentFrequency',
                                }}) }}
                            </div>
                        {% else %}
                            {% do form.paymentFrequency.setRendered %}
                        {% endif %}

                        {% set isBankTransfer = form.vars.data.paymentMethod is not null and form.vars.data.paymentMethod.value == 'bank_transfer' %}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                                </svg>
                                Způsob platby
                            </h2>
                            {{ form_widget(form.paymentMethod) }}
                            {% if isBankTransfer %}
                                <div class="mt-3 p-3 bg-amber-50 border border-amber-200 rounded-lg">
                                    <p class="text-sm text-amber-800">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        Při platbě bankovním převodem je účtován příplatek {{ this.getBankTransferSurchargeInCzk()|number_format(0, ',', ' ') }} Kč za každé fakturační období.
                                    </p>
                                </div>
                            {% endif %}
                        </div>

                        {% if isYearly or isBankTransfer %}
                            {# YEARLY is always MANUAL_RECURRING; BANK_TRANSFER forces MANUAL_RECURRING too — hide the AUTO/MANUAL radio. #}
                            {% if isYearly %}
                                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                                    <p class="text-sm text-blue-900">
                                        <strong>Roční platba se vždy odbavuje ručně.</strong>
                                        Kartu si neukládáme — další platbu obdržíte e-mailem před vypršením roku.
                                    </p>
                                </div>
                            {% endif %}
                            {% do form.billingMode.setRendered %}
                        {% elseif this.isEligibleForBillingModeChoice() %}
                            <div class="space-y-2">
                                {{ form_row(form.billingMode) }}
                            </div>
                        {% else %}
                            {% do form.billingMode.setRendered %}
                        {% endif %}

                        {# Dynamic Pricing — server-rendered via PriceCalculator (same schedule the
                           order acceptance flow + recurring-billing cron use). data-model="on(change)|*"
                           syncs form values on every change, so this re-renders naturally with each
                           date / rental-type tweak. No client-side math, no morph race. #}
                        {% set schedule = this.getPaymentSchedule(selectedStorage) %}
                        {% if schedule %}
                            <div class="bg-accent/5 border border-accent/20 rounded-lg px-4 py-3 space-y-2">
                                {% if schedule.isYearly %}
                                    {# YEARLY — always lead with monthly equivalent (direct spec 045 user brief). #}
                                    <div class="flex items-center justify-between {% if schedule.entries|length > 1 %}border-b border-accent/20 pb-2{% endif %}">
                                        <span class="text-sm text-gray-600">Roční platba</span>
                                        <span class="text-lg font-bold text-accent text-right">
                                            {{ schedule.yearlyMonthlyEquivalentInCzk|number_format(0, ',', ' ') }} Kč / měsíc
                                            <span class="text-xs text-gray-500 font-normal block">účtováno jednou ročně — {{ schedule.yearlyAmountInCzk|number_format(0, ',', ' ') }} Kč vč. DPH</span>
                                        </span>
                                    </div>
                                    {% if schedule.entries|length > 1 %}
                                        <ul class="space-y-1 text-xs text-gray-600">
                                            {% for entry in schedule.entries %}
                                                <li class="flex items-center justify-between">
                                                    <span>Platba na rok {{ loop.index }} <span class="text-gray-400">({{ entry.chargeDate|date('d.m.Y') }})</span></span>
                                                    <span class="font-medium text-gray-800">{{ entry.amountInCzk|number_format(0, ',', ' ') }} Kč</span>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    {% endif %}
                                {% elseif schedule.isOpenEnded %}
                                    {# UNLIMITED — open-ended monthly recurrence #}
                                    <div class="flex items-center justify-between">
                                        <span class="text-sm text-gray-600">Měsíční platba (s automatickým prodlužováním)</span>
                                        <span class="text-lg font-bold text-accent">{{ schedule.monthlyAmountInCzk|number_format(0, ',', ' ') }} Kč / měsíc <span class="text-xs text-gray-500 font-normal">vč. DPH</span></span>
                                    </div>
                                {% elseif not schedule.isRecurring %}
                                    {# SHORT (< 28 dní) — single one-shot charge #}
                                    <div class="flex items-center justify-between">
                                        <span class="text-sm text-gray-600">Jednorázová platba</span>
                                        <span class="text-lg font-bold text-accent">{{ schedule.firstPayment.amountInCzk|number_format(0, ',', ' ') }} Kč <span class="text-xs text-gray-500 font-normal">vč. DPH</span></span>
                                    </div>
                                {% else %}
                                    {# FIXED-END ≥ 28 dní — monthly rate header (no lifetime sum, per spec 042); breakdown below lists individual charges with dates. #}
                                    <div class="flex items-center justify-between border-b border-accent/20 pb-2">
                                        <span class="text-sm text-gray-600">Měsíční platba</span>
                                        <span class="text-lg font-bold text-accent">{{ schedule.monthlyAmountInCzk|number_format(0, ',', ' ') }} Kč / měsíc <span class="text-xs text-gray-500 font-normal">vč. DPH</span></span>
                                    </div>
                                    <ul class="space-y-1 text-xs text-gray-600">
                                        {% for entry in schedule.entries %}
                                            <li class="flex items-center justify-between">
                                                <span>{{ loop.first ? '1. platba' : (loop.last ? 'doplatek' : (loop.index ~ '. platba')) }} <span class="text-gray-400">({{ entry.chargeDate|date('d.m.Y') }})</span></span>
                                                <span class="font-medium text-gray-800">{{ entry.amountInCzk|number_format(0, ',', ' ') }} Kč</span>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                {% endif %}
                            </div>
                        {% endif %}

                        {# Storage Selection Mode — radios are inside the <form> but bind to the
                           `selectionMode` LiveProp via an explicit data-model that overrides the
                           form's wildcard (which would otherwise look for a non-existent form
                           field named "selection_mode" and error out). selectionMode is
                           writable: true on the component, so the change syncs server-side
                           directly; the Stimulus controller only handles the map visibility
                           toggle and the smooth scroll. #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                                </svg>
                                Výběr skladové jednotky
                            </h2>

                            <div class="space-y-3">
                                <div class="flex items-center">
                                    <input type="radio" id="selection-mode-auto" name="selection_mode" value="auto"
                                           {{ isAutoSelection ? 'checked' : '' }}
                                           data-model="on(change)|selectionMode"
                                           data-action="change->order-selection-mode#switch"
                                           class="form-radio">
                                    <label for="selection-mode-auto" class="ml-3 text-sm text-gray-700 cursor-pointer">
                                        Vybrat místo automaticky
                                        <span class="block text-xs text-gray-500">Přidělíme vám první volnou skladovou jednotku tohoto typu.</span>
                                    </label>
                                </div>

                                <div class="flex items-center">
                                    <input type="radio" id="selection-mode-manual" name="selection_mode" value="manual"
                                           {{ isAutoSelection ? '' : 'checked' }}
                                           data-model="on(change)|selectionMode"
                                           data-action="change->order-selection-mode#switch"
                                           class="form-radio">
                                    <label for="selection-mode-manual" class="ml-3 text-sm text-gray-700 cursor-pointer">
                                        Chci si vybrat místo z mapy
                                        <span class="block text-xs text-gray-500">Po výběru se zobrazí mapa pobočky s rozložením skladů.</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        {# Pre-purchase legal-doc links — GoPay underwriting requirement
                           (consumer must reach VOP / withdrawal info / recurring T&C from
                           any sale-describing page). Terse inline list. #}
                        <p class="text-xs text-gray-500 pt-2">
                            Před objednáním si přečtěte:
                            <a href="{{ path('public_terms_and_conditions') }}" target="_blank" class="text-accent hover:underline">VOP</a> ·
                            <a href="{{ path('public_consumer_notice') }}" target="_blank" class="text-accent hover:underline">Poučení spotřebitele</a> ·
                            <a href="{{ path('public_recurring_payments_terms') }}" target="_blank" class="text-accent hover:underline">Podmínky opakovaných plateb</a> ·
                            <a href="{{ path('public_privacy_policy') }}" target="_blank" class="text-accent hover:underline">Ochrana osobních údajů</a>.
                            Ceny jsou uvedeny vč. DPH.
                        </p>

                        {# Submit — this button creates the order request only; binding to
                           payment per § 1826a OZ happens on the next page (order_accept). #}
                        <div class="flex items-center justify-between pt-2 border-t border-gray-200">
                            <a href="{{ app.user ? path('portal_browse_place_detail', {id: place.id}) : path('public_place_detail', {id: place.id}) }}" class="inline-flex items-center text-gray-600 hover:text-gray-900">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                                </svg>
                                Zpět na výběr
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg"
                                    data-loading="action(submit)|addAttribute(disabled)">
                                <svg xmlns="http://www.w3.org/2000/svg" class="hidden animate-spin h-5 w-5 mr-2" data-loading="action(submit)|removeClass(hidden)" fill="none" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                </svg>
                                Pokračovat k podpisu
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                </svg>
                            </button>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        {# Order Summary Sidebar #}
        <div class="lg:col-span-1 order-1 lg:order-2">
            <div class="card sticky top-24">
                <div class="bg-primary text-white p-4">
                    <h2 class="text-lg font-bold">Shrnutí objednávky</h2>
                </div>
                <div class="card-body">
                    {# Storage-type photos — generic, always shown when present. #}
                    {% if storageType.hasPhotos %}
                        <div class="mb-4">
                            {% include 'partials/photo_gallery.html.twig' with {
                                photos: storageType.photos,
                                gallery_key: 'order-type-' ~ storageType.id,
                                caption: 'Typ skladu: ' ~ storageType.name,
                                layout: 'strip',
                                thumb_max_h: 'max-h-24',
                                alt: storageType.name,
                            } only %}
                        </div>
                    {% endif %}

                    {# Storage-specific photos — only meaningful when the user has actively picked a unit. #}
                    {% if not isAutoSelection and selectedStorage.hasPhotos %}
                        <div class="mb-4">
                            <h3 class="text-sm font-semibold text-gray-700 mb-2">Fotografie skladu č. {{ selectedStorage.number }}</h3>
                            {% include 'partials/photo_gallery.html.twig' with {
                                photos: selectedStorage.photos,
                                gallery_key: 'order-storage-' ~ selectedStorage.id,
                                caption: 'Sklad č. ' ~ selectedStorage.number,
                                layout: 'strip',
                                thumb_max_h: 'max-h-24',
                                alt: 'Sklad ' ~ selectedStorage.number,
                            } only %}
                        </div>
                    {% endif %}

                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between">
                            <span class="text-gray-600">Pobočka</span>
                            <span class="font-medium text-gray-900">{{ place.name }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Typ jednotky</span>
                            <span class="font-medium text-gray-900">{{ storageType.name }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Číslo skladu</span>
                            <span class="font-medium text-gray-900">
                                {%- if isAutoSelection -%}
                                    Bude vybráno automaticky
                                {%- else -%}
                                    {{ selectedStorage.number }}
                                {%- endif -%}
                            </span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Rozměry</span>
                            <span class="font-medium text-gray-900">{{ storageType.innerDimensionsInMeters }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Plocha</span>
                            <span class="font-medium text-gray-900">{{ storageType.floorAreaInSquareMeters|number_format(1, ',', ' ') }} m&sup2;</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Objem</span>
                            <span class="font-medium text-gray-900">{{ storageType.volumeInCubicMeters|number_format(1, ',', ' ') }} m&sup3;</span>
                        </div>
                    </div>

                    <hr class="my-4">

                    {% set applicableRate = this.applicableRate %}
                    {% set yearlyEligible = this.isEligibleForFrequencyChoice() %}
                    {% set isUnlimited = form.vars.data.rentalType is not null and form.vars.data.rentalType.value == 'unlimited' %}
                    <div class="space-y-2">
                        <h3 class="font-semibold text-gray-900">Ceník</h3>

                        {% if not isUnlimited and (applicableRate is null or applicableRate == 'weekly') %}
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600">
                                    Týdenní sazba
                                    {% if applicableRate == 'weekly' %}
                                        <span class="ml-1 text-xs font-medium text-accent">(platí pro vás)</span>
                                    {% endif %}
                                </span>
                                <span class="font-semibold {{ applicableRate == 'weekly' ? 'text-accent' : 'text-gray-900' }}">{{ weeklyPrice|number_format(0, ',', ' ') }} Kč <span class="text-xs text-gray-500 font-normal">vč. DPH</span></span>
                            </div>
                        {% endif %}

                        {% if not isUnlimited and (applicableRate is null or applicableRate == 'monthly_short') %}
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600">
                                    Krátkodobá měsíční sazba (1–6 měs.)
                                    {% if applicableRate == 'monthly_short' %}
                                        <span class="ml-1 text-xs font-medium text-accent">(platí pro vás)</span>
                                    {% endif %}
                                </span>
                                <span class="font-semibold {{ applicableRate == 'monthly_short' ? 'text-accent' : 'text-gray-900' }}">{{ monthlyPrice|number_format(0, ',', ' ') }} Kč <span class="text-xs text-gray-500 font-normal">vč. DPH</span></span>
                            </div>
                        {% endif %}

                        {% if applicableRate is null or applicableRate == 'monthly_long' %}
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600">
                                    Dlouhodobá měsíční sazba (6+ měs.)
                                    {% if applicableRate == 'monthly_long' %}
                                        <span class="ml-1 text-xs font-medium text-accent">(platí pro vás)</span>
                                    {% endif %}
                                </span>
                                <span class="font-semibold {{ applicableRate == 'monthly_long' ? 'text-accent' : 'text-gray-900' }}">{{ longTermMonthlyPrice|number_format(0, ',', ' ') }} Kč <span class="text-xs text-gray-500 font-normal">vč. DPH</span></span>
                            </div>
                        {% endif %}

                        {% if yearlyEligible and (applicableRate is null or applicableRate == 'yearly') %}
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-600">
                                    Roční sazba
                                    <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Zvýhodněná cena</span>
                                    {% if applicableRate == 'yearly' %}
                                        <span class="ml-1 text-xs font-medium text-accent">(platí pro vás)</span>
                                    {% endif %}
                                </span>
                                <span class="font-semibold {{ applicableRate == 'yearly' ? 'text-accent' : 'text-gray-900' }} text-right">
                                    {{ yearlyPrice|number_format(0, ',', ' ') }} Kč
                                    <span class="text-xs text-gray-500 font-normal block">≈ {{ this.getYearlyMonthlyEquivalentInCzk(selectedStorage)|number_format(0, ',', ' ') }} Kč / měsíc vč. DPH</span>
                                </span>
                            </div>
                        {% endif %}

                        {% if applicableRate is null %}
                            <p class="text-xs text-gray-500 mt-2 bg-gray-50 p-2 rounded">
                                Pronájem do 30 dnů se účtuje týdenní sazbou. 1–6 měsíců krátkodobou měsíční sazbou, 6 měsíců a déle dlouhodobou měsíční sazbou (výhodnější). Pronájem lze platit i ročně předem za zvýhodněnou cenu.
                            </p>
                        {% endif %}
                    </div>

                    <hr class="my-4">

                    <div class="bg-amber-50 border border-amber-200 p-3 rounded-lg">
                        <p class="text-sm text-amber-800 flex items-start">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>
                                Skladová jednotka bude přiřazena automaticky po vytvoření objednávky.
                                Máte <strong>7 dní</strong> na dokončení platby.
                            </span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Storage Map — lives INSIDE the Live Component so its storages-value re-renders
       on every rental-type/date change and storagesValueChanged() repaints. Visibility
       is server-driven by the selectionMode LiveProp (survives morphing); the
       order-selection-mode controller mirrors it client-side for instant feedback + scroll. #}
    {% if place.mapImagePath or mapStoragesJson != '[]' %}
        <div id="storage-map-card" class="card mt-8 {{ isAutoSelection ? 'hidden' : '' }}"
             data-order-selection-mode-target="map"
             data-controller="storage-map"
             data-storage-map-map-image-value="{{ place.mapImagePath ? asset('uploads/' ~ place.mapImagePath) : '' }}"
             data-storage-map-storages-value="{{ mapStoragesJson|e('html_attr') }}"
             data-storage-map-place-id-value="{{ place.id }}"
             data-storage-map-current-storage-type-id-value="{{ storageType.id }}"
             data-storage-map-select-mode-value="true"
             data-storage-map-highlight-storage-value="{{ this.storageId }}">
            <div class="card-header bg-gray-50 px-4 py-3 border-b">
                <div class="flex items-center justify-between">
                    <h2 class="font-semibold text-gray-900">Mapa skladu</h2>
                    <div class="flex items-center gap-4">
                        <div class="flex items-center gap-1">
                            <button type="button" data-action="click->storage-map#zoomOut" class="btn btn-ghost btn-xs" title="Oddálit">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM13 10H7" />
                                </svg>
                            </button>
                            <button type="button" data-action="click->storage-map#zoomReset" data-storage-map-target="zoomLabel" class="btn btn-ghost btn-xs text-xs min-w-[3rem]" title="Resetovat zoom">100%</button>
                            <button type="button" data-action="click->storage-map#zoomIn" class="btn btn-ghost btn-xs" title="Přiblížit">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7" />
                                </svg>
                            </button>
                        </div>
                        <div class="flex gap-3 text-sm">
                            <div class="flex items-center gap-1">
                                <div class="w-3 h-3 rounded bg-green-500"></div>
                                <span class="text-gray-600">Volný</span>
                            </div>
                            <div class="flex items-center gap-1">
                                <div class="w-3 h-3 rounded bg-gray-400"></div>
                                <span class="text-gray-600">Nedostupný</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="p-4 relative">
                {% if not this.hasValidWindow() %}
                    <div class="mb-3 rounded-lg bg-amber-50 border border-amber-200 p-3 text-sm text-amber-800">
                        Nejdříve zvolte termín pronájmu — dostupnost jednotek se zobrazí podle vybraných dat.
                    </div>
                {% endif %}
                <div data-storage-map-target="container" data-live-ignore class="w-full rounded-lg" style="min-height: 400px;"></div>
                <div data-storage-map-target="minimap"
                     data-live-ignore
                     class="absolute bottom-6 right-6 border-2 border-gray-400 rounded shadow-lg bg-white overflow-hidden"
                     style="width: 180px; height: 120px; display: none; z-index: 10;"></div>
                <div data-storage-map-target="tooltip" class="hidden absolute z-10 bg-white border border-gray-200 shadow-lg rounded-lg p-3 text-sm pointer-events-none max-w-xs"></div>
            </div>
        </div>
    {% endif %}
</div>
