{% set selectedStorage = this.selectedStorage %}
{% set storageType = this.storageType %}
{% set place = this.place %}
{% set weeklyPrice = selectedStorage.getEffectivePricePerWeekInCzk() %}
{% set monthlyPrice = selectedStorage.getEffectivePricePerMonthInCzk() %}
{% set isAutoSelection = this.selectionMode == 'auto' %}
{# Show/hide of conditional sections is server-driven (not Alpine x-show) so it survives Live UX morphing. #}
{% set invoiceToCompany = form.vars.data.invoiceToCompany ?? false %}
{% set rentalIsLimited = form.vars.data.rentalType is null or form.vars.data.rentalType.value == 'limited' %}

<div {{ attributes }}>
    <div class="grid lg:grid-cols-3 gap-8">
        {# Order Form #}
        <div class="lg:col-span-2 order-2 lg:order-1">
            <div class="card">
                <div class="card-body">
                    <h1 class="text-2xl font-bold text-gray-900 mb-6">Vytvořit objednávku</h1>

                    {{ form_start(form, {attr: {
                        'novalidate': 'novalidate',
                        'class': 'space-y-8',
                        'data-action': 'submit->live#action:prevent',
                        'data-live-action-param': 'submit',
                    }}) }}

                        {# Contact Information #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                Kontaktní údaje
                            </h2>

                            <div class="grid md:grid-cols-2 gap-4">
                                <div>
                                    {{ form_row(form.firstName, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'firstName',
                                    }}) }}
                                </div>
                                <div>
                                    {{ form_row(form.lastName, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'lastName',
                                    }}) }}
                                </div>
                            </div>

                            <div class="grid md:grid-cols-2 gap-4">
                                <div>
                                    {{ form_row(form.email, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'email',
                                    }}) }}
                                </div>
                                <div>
                                    {{ form_row(form.phone, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'phone',
                                    }}) }}
                                </div>
                            </div>

                            {% if not invoiceToCompany %}
                                <div class="grid md:grid-cols-2 gap-4">
                                    <div>
                                        {{ form_row(form.birthDate, {attr: {
                                            'data-action': 'blur->live#action',
                                            'data-live-action-param': 'validateField',
                                            'data-live-field-param': 'birthDate',
                                        }}) }}
                                    </div>
                                </div>
                            {% else %}
                                {# Suppress form_end's auto-render of unrendered fields. validateBirthDate skips when invoiceToCompany is true. #}
                                {% do form.birthDate.setRendered %}
                            {% endif %}

                            {% if not app.user %}
                                <div class="mt-4">
                                    {{ form_row(form.plainPassword, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'plainPassword',
                                    }}) }}
                                </div>
                            {% else %}
                                {% do form.plainPassword.setRendered %}
                            {% endif %}
                        </div>

                        <div data-controller="ares-lookup" class="space-y-8">
                        {# Company Information #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                                </svg>
                                Firemní údaje
                            </h2>

                            <div class="mb-4">
                                <label class="flex items-center cursor-pointer">
                                    {{ form_widget(form.invoiceToCompany, {attr: {'class': 'mr-3'}}) }}
                                    <span class="text-sm font-medium text-gray-700">Nájemce je společnost / OSVČ</span>
                                </label>
                            </div>

                            {% if invoiceToCompany %}
                                <div class="space-y-4">
                                    <div>
                                        {{ form_label(form.companyId) }}
                                        <div class="flex">
                                            {{ form_widget(form.companyId, {attr: {
                                                'class': 'flex-1 min-w-0 rounded-r-none!',
                                                'data-action': 'blur->live#action',
                                                'data-live-action-param': 'validateField',
                                                'data-live-field-param': 'companyId',
                                            }}) }}
                                            {% include 'components/ares_lookup_button.html.twig' %}
                                        </div>
                                        {# data-live-ignore: the ARES Stimulus controller writes the status text/colour
                                           client-side; without this the message is wiped on every Live UX re-render. #}
                                        <p data-ares-lookup-target="status" class="text-sm mt-2" aria-live="polite" data-live-ignore></p>
                                        {{ form_errors(form.companyId) }}
                                    </div>

                                    <div class="grid md:grid-cols-2 gap-4">
                                        <div>
                                            {{ form_row(form.companyName, {attr: {
                                                'data-action': 'blur->live#action',
                                                'data-live-action-param': 'validateField',
                                                'data-live-field-param': 'companyName',
                                            }}) }}
                                        </div>
                                        <div>
                                            {{ form_row(form.companyVatId, {attr: {
                                                'data-action': 'blur->live#action',
                                                'data-live-action-param': 'validateField',
                                                'data-live-field-param': 'companyVatId',
                                            }}) }}
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                {# Suppress form_end's auto-render of unrendered fields. validateCompanyInfo skips when invoiceToCompany is false. #}
                                {% do form.companyId.setRendered %}
                                {% do form.companyName.setRendered %}
                                {% do form.companyVatId.setRendered %}
                            {% endif %}
                        </div>

                        {# Address - always required for the contract #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                <span>{{ invoiceToCompany ? 'Sídlo společnosti' : 'Adresa bydliště' }}</span>
                            </h2>

                            <p class="text-xs text-gray-500 mb-4">Vyžadováno pro účely nájemní smlouvy.</p>

                            <div>
                                {{ form_row(form.billingStreet, {attr: {
                                    'data-action': 'blur->live#action',
                                    'data-live-action-param': 'validateField',
                                    'data-live-field-param': 'billingStreet',
                                }}) }}
                            </div>

                            <div class="grid md:grid-cols-2 gap-4">
                                <div>
                                    {{ form_row(form.billingCity, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'billingCity',
                                    }}) }}
                                </div>
                                <div>
                                    {{ form_row(form.billingPostalCode, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'billingPostalCode',
                                    }}) }}
                                </div>
                            </div>
                        </div>
                        </div>

                        {# Rental Type #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                Typ pronájmu
                            </h2>

                            <div>
                                {{ form_widget(form.rentalType) }}
                            </div>

                            {% if not rentalIsLimited %}
                                <div class="mt-4 p-4 bg-accent/10 border border-accent/20 rounded-lg">
                                    <p class="text-sm text-gray-700">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        Pronájem na dobu neurčitou s možností ukončení kdykoliv.
                                    </p>
                                </div>
                            {% endif %}
                        </div>

                        {# Dates #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                Období pronájmu
                            </h2>

                            <div class="grid md:grid-cols-2 gap-4">
                                <div>
                                    {{ form_row(form.startDate, {attr: {
                                        'data-action': 'blur->live#action',
                                        'data-live-action-param': 'validateField',
                                        'data-live-field-param': 'startDate',
                                    }}) }}
                                </div>
                                {% if rentalIsLimited %}
                                    <div>
                                        {{ form_row(form.endDate, {attr: {
                                            'data-action': 'blur->live#action',
                                            'data-live-action-param': 'validateField',
                                            'data-live-field-param': 'endDate',
                                        }}) }}
                                    </div>
                                {% else %}
                                    {# Suppress form_end's auto-render. validateDates skips endDate for unlimited rentals. #}
                                    {% do form.endDate.setRendered %}
                                {% endif %}
                            </div>
                        </div>

                        {# Dynamic Pricing — server-rendered via PriceCalculator (same service the
                           order acceptance flow uses). data-model="on(change)|*" syncs form values
                           on every change, so this re-renders naturally with each date / rental-type
                           tweak. No client-side math, no morph race. #}
                        {% set pricing = this.getPricing(selectedStorage) %}
                        {% if pricing %}
                            <div class="bg-accent/5 border border-accent/20 rounded-lg px-4 py-3 flex items-center justify-between">
                                {% if pricing.type == 'monthly' %}
                                    <span class="text-sm text-gray-600">Měsíční platba</span>
                                    <span class="text-lg font-bold text-accent">{{ pricing.monthly|number_format(0, ',', ' ') }} Kč / měsíc</span>
                                {% elseif pricing.type == 'oneTime' %}
                                    <span class="text-sm text-gray-600">Jednorázová platba ({{ pricing.days }} dní)</span>
                                    <span class="text-lg font-bold text-accent">{{ pricing.total|number_format(0, ',', ' ') }} Kč</span>
                                {% elseif pricing.type == 'recurring' %}
                                    <span class="text-sm text-gray-600">{{ pricing.monthly|number_format(0, ',', ' ') }} Kč / měsíc</span>
                                    <div class="text-right">
                                        <span class="text-lg font-bold text-accent">{{ pricing.total|number_format(0, ',', ' ') }} Kč</span>
                                        <span class="text-xs text-gray-500 ml-1">celkem za {{ pricing.days }} dní</span>
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}

                        {# Storage Selection Mode — radios are inside the <form> but bind to the
                           `selectionMode` LiveProp via an explicit data-model that overrides the
                           form's wildcard (which would otherwise look for a non-existent form
                           field named "selection_mode" and error out). selectionMode is
                           writable: true on the component, so the change syncs server-side
                           directly; the Stimulus controller only handles the map visibility
                           toggle and the smooth scroll. #}
                        <div class="bg-gray-50 rounded-lg p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
                                </svg>
                                Výběr skladové jednotky
                            </h2>

                            <div class="space-y-3">
                                <div class="flex items-center">
                                    <input type="radio" id="selection-mode-auto" name="selection_mode" value="auto"
                                           {{ isAutoSelection ? 'checked' : '' }}
                                           data-model="on(change)|selectionMode"
                                           data-action="change->order-selection-mode#switch"
                                           class="h-4 w-4 text-accent focus:ring-accent border-gray-300">
                                    <label for="selection-mode-auto" class="ml-3 text-sm text-gray-700 cursor-pointer">
                                        Vybrat místo automaticky
                                        <span class="block text-xs text-gray-500">Přidělíme vám první volnou skladovou jednotku tohoto typu.</span>
                                    </label>
                                </div>

                                <div class="flex items-center">
                                    <input type="radio" id="selection-mode-manual" name="selection_mode" value="manual"
                                           {{ isAutoSelection ? '' : 'checked' }}
                                           data-model="on(change)|selectionMode"
                                           data-action="change->order-selection-mode#switch"
                                           class="h-4 w-4 text-accent focus:ring-accent border-gray-300">
                                    <label for="selection-mode-manual" class="ml-3 text-sm text-gray-700 cursor-pointer">
                                        Chci si vybrat místo z mapy
                                        <span class="block text-xs text-gray-500">Po výběru se zobrazí mapa pobočky s rozložením skladů.</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        {# Submit #}
                        <div class="flex items-center justify-between pt-2 border-t border-gray-200">
                            <a href="{{ app.user ? path('portal_browse_place_detail', {id: place.id}) : path('public_place_detail', {id: place.id}) }}" class="inline-flex items-center text-gray-600 hover:text-gray-900">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                                </svg>
                                Zpět na výběr
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                Rekapitulace
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                </svg>
                            </button>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        {# Order Summary Sidebar #}
        <div class="lg:col-span-1 order-1 lg:order-2">
            <div class="card sticky top-24">
                <div class="bg-primary text-white p-4">
                    <h2 class="text-lg font-bold">Shrnutí objednávky</h2>
                </div>
                <div class="card-body">
                    {# Storage-type photos — generic, always shown when present. #}
                    {% if storageType.hasPhotos %}
                        <div class="mb-4">
                            {% include 'partials/photo_gallery.html.twig' with {
                                photos: storageType.photos,
                                gallery_key: 'order-type-' ~ storageType.id,
                                caption: 'Typ skladu: ' ~ storageType.name,
                                layout: 'strip',
                                thumb_max_h: 'max-h-24',
                                alt: storageType.name,
                            } only %}
                        </div>
                    {% endif %}

                    {# Storage-specific photos — only meaningful when the user has actively picked a unit. #}
                    {% if not isAutoSelection and selectedStorage.hasPhotos %}
                        <div class="mb-4">
                            <h3 class="text-sm font-semibold text-gray-700 mb-2">Fotografie skladu č. {{ selectedStorage.number }}</h3>
                            {% include 'partials/photo_gallery.html.twig' with {
                                photos: selectedStorage.photos,
                                gallery_key: 'order-storage-' ~ selectedStorage.id,
                                caption: 'Sklad č. ' ~ selectedStorage.number,
                                layout: 'strip',
                                thumb_max_h: 'max-h-24',
                                alt: 'Sklad ' ~ selectedStorage.number,
                            } only %}
                        </div>
                    {% endif %}

                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between">
                            <span class="text-gray-600">Pobočka</span>
                            <span class="font-medium text-gray-900">{{ place.name }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Typ jednotky</span>
                            <span class="font-medium text-gray-900">{{ storageType.name }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Číslo skladu</span>
                            <span class="font-medium text-gray-900">
                                {%- if isAutoSelection -%}
                                    Bude vybráno automaticky
                                {%- else -%}
                                    {{ selectedStorage.number }}
                                {%- endif -%}
                            </span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Rozměry</span>
                            <span class="font-medium text-gray-900">{{ storageType.innerDimensionsInMeters }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Plocha</span>
                            <span class="font-medium text-gray-900">{{ storageType.floorAreaInSquareMeters|number_format(1, ',', ' ') }} m&sup2;</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Objem</span>
                            <span class="font-medium text-gray-900">{{ storageType.volumeInCubicMeters|number_format(1, ',', ' ') }} m&sup3;</span>
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="space-y-2">
                        <h3 class="font-semibold text-gray-900">Ceník</h3>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-600">Týdenní sazba</span>
                            <span class="font-semibold text-gray-900">{{ weeklyPrice|number_format(0, ',', ' ') }} Kč</span>
                        </div>
                        <div class="flex justify-between text-sm">
                            <span class="text-gray-600">Měsíční sazba</span>
                            <span class="font-semibold text-accent">{{ monthlyPrice|number_format(0, ',', ' ') }} Kč</span>
                        </div>
                        <p class="text-xs text-gray-500 mt-2 bg-gray-50 p-2 rounded">
                            Pronájem kratší než 4 týdny se účtuje týdenní sazbou,
                            delší pronájem měsíční sazbou (výhodnější).
                        </p>
                    </div>

                    <hr class="my-4">

                    <div class="bg-amber-50 border border-amber-200 p-3 rounded-lg">
                        <p class="text-sm text-amber-800 flex items-start">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span>
                                Skladová jednotka bude přiřazena automaticky po vytvoření objednávky.
                                Máte <strong>7 dní</strong> na dokončení platby.
                            </span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
