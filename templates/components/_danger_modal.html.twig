{#
  Reusable password-confirmed destructive-action dialog (GitHub-style "Nebezpečná zóna").

  Params:
    id           – unique DOM id of the <dialog>; open it with showModal()
    title        – heading text
    action       – POST target URL
  Blocks (override in the embed):
    description  – body text shown above the password field
    extra_fields – optional additional form inputs (textarea, radios, ...)
    submit_label – text of the confirm button (default "Potvrdit")

  Trigger button is rendered by the caller, e.g.:
    <button type="button" class="btn btn-error"
            onclick="document.getElementById('<id>').showModal()">…</button>
#}
<dialog id="{{ id }}" class="modal">
    <div class="modal-box">
        <h3 class="text-lg font-bold text-red-700">{{ title }}</h3>
        <div class="py-2 text-sm text-gray-600">{% block description %}{% endblock %}</div>
        <form action="{{ action }}" method="post">
            {% block extra_fields %}{% endblock %}
            <div class="form-group mt-4">
                <label class="form-label" for="{{ id }}__password">Pro potvrzení zadejte své heslo</label>
                <div class="flex" data-controller="password-toggle">
                    <input type="password"
                           name="password"
                           id="{{ id }}__password"
                           required
                           autocomplete="current-password"
                           class="form-input flex-1 min-w-0 rounded-r-none!"
                           data-password-toggle-target="input" />
                    <button type="button"
                            tabindex="-1"
                            class="flex items-center justify-center px-3 border border-l-0 border-gray-300 rounded-r-md bg-gray-50 hover:bg-gray-100 text-gray-400 hover:text-gray-600 focus:outline-none"
                            aria-label="Zobrazit heslo"
                            data-action="click->password-toggle#toggle">
                        {# Eye icon — visible when password is hidden #}
                        <svg data-password-toggle-target="showIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="h-5 w-5">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                        {# Eye-slash icon — visible when password is shown #}
                        <svg data-password-toggle-target="hideIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="h-5 w-5 hidden">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                        </svg>
                    </button>
                </div>
                <p class="form-help">Tuto akci je nutné potvrdit heslem k vašemu účtu.</p>
            </div>
            <div class="modal-action">
                <button type="button" class="btn btn-ghost" onclick="document.getElementById('{{ id }}').close()">Zrušit</button>
                <button type="submit" class="btn btn-error">{% block submit_label %}Potvrdit{% endblock %}</button>
            </div>
        </form>
    </div>
    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>
</dialog>
