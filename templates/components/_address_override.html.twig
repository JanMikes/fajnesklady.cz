{# Address entry: a single Photon-backed search box that, on selection, fills and
   reveals the three real fields (street / city / PSČ) for verification. "Zadat
   ručně" reveals the same fields empty for manual entry. The three fields always
   live in the DOM and are submitted with the form — only their visibility is
   toggled by the `address-autocomplete` Stimulus controller.

   render()      -> plain templates.
   render_live() -> Live Components; adds per-field `blur->live#action validateField`
                    wiring for on-blur server validation, plus the soft-warn override
                    block (spec 037).

   The `browserAutofill` argument is kept for call-site compatibility but is no longer
   used: browser address-autofill is now suppressed on every field (autocomplete=off)
   so it can never collide with our own dropdown — that collision (two dropdowns at
   once) was the core defect of the previous three-autocomplete-fields design. #}

{% macro render(form, browserAutofill = true) %}
    {{ _self.render_inner(form, false) }}
{% endmacro %}

{% macro render_live(form, browserAutofill = true) %}
    {{ _self.render_inner(form, true) }}
{% endmacro %}

{% macro render_inner(form, liveValidate) %}
    {% set streetAttr = {
        'data-address-autocomplete-target': 'streetInput',
        'autocomplete': 'off',
        'data-1p-ignore': 'true',
        'data-lpignore': 'true',
    } %}
    {% set cityAttr = {
        'data-address-autocomplete-target': 'cityInput',
        'autocomplete': 'off',
        'data-1p-ignore': 'true',
        'data-lpignore': 'true',
    } %}
    {% set postalAttr = {
        'data-address-autocomplete-target': 'postalCodeInput',
        'autocomplete': 'off',
        'inputmode': 'numeric',
        'data-1p-ignore': 'true',
        'data-lpignore': 'true',
    } %}

    {% if liveValidate %}
        {% set streetAttr = streetAttr|merge({
            'data-action': 'blur->live#action',
            'data-live-action-param': 'validateField',
            'data-live-field-param': 'billingStreet',
        }) %}
        {% set cityAttr = cityAttr|merge({
            'data-action': 'blur->live#action',
            'data-live-action-param': 'validateField',
            'data-live-field-param': 'billingCity',
        }) %}
        {% set postalAttr = postalAttr|merge({
            'data-action': 'blur->live#action',
            'data-live-action-param': 'validateField',
            'data-live-field-param': 'billingPostalCode',
        }) %}
    {% endif %}

    {# Show the override block only when billingStreet has BOTH a value and a
       violation — the AddressExists validator only fires for non-empty addresses. #}
    {% set streetHasValue = form.billingStreet.vars.value is not empty %}
    {% set streetHasViolation = streetHasValue and form.billingStreet.vars.errors|length > 0 %}

    {# ANY violation on the three fields — including NotBlank on empty fields after a
       submit. Field errors render inside the manual section, so a violation must
       always reveal it: otherwise the form 422s with no visible error anywhere. #}
    {% set addressHasViolation =
        form.billingStreet.vars.errors|length > 0
        or form.billingCity.vars.errors|length > 0
        or form.billingPostalCode.vars.errors|length > 0 %}

    {% set addressHasValue =
        form.billingStreet.vars.value is not empty
        or form.billingCity.vars.value is not empty
        or form.billingPostalCode.vars.value is not empty %}

    {# Reveal the three fields (vs. the search box) whenever the address is already
       populated or erroring. The Stimulus controller renders the SAME condition (it
       receives the violation state via the hasViolation value), so a Live morph
       re-renders a consistent state. #}
    {% set addressPrefilled = addressHasValue or addressHasViolation %}

    {% set searchId = 'address-search-' ~ form.billingStreet.vars.id %}

    <div {{ stimulus_controller('address-autocomplete', { hasViolation: addressHasViolation }) }} class="space-y-4">
        {# --- Search box --------------------------------------------------- #}
        <div data-address-autocomplete-target="searchSection" class="{{ addressPrefilled ? 'hidden ' : '' }}space-y-1">
            {# Required marker follows the underlying street field — the macro also
               serves forms where the address is optional (e.g. admin user edit). #}
            <label for="{{ searchId }}" class="form-label{{ form.billingStreet.vars.required ? ' form-label-required' : '' }}">Adresa</label>

            {# data-live-ignore: this whole search UI (typed text, spinner, dropdown)
               is client-owned and has no server representation — keep morphs away. #}
            <div class="relative" data-live-ignore>
                <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-gray-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </span>
                <input type="text"
                       id="{{ searchId }}"
                       data-address-autocomplete-target="searchInput"
                       class="form-input pl-10! pr-10!"
                       placeholder="Začněte psát ulici a město…"
                       autocomplete="off"
                       autocapitalize="off"
                       spellcheck="false"
                       data-1p-ignore="true"
                       data-lpignore="true"
                       role="combobox"
                       aria-autocomplete="list"
                       aria-expanded="false"
                       aria-controls="{{ searchId }}-listbox">
                <span data-address-autocomplete-target="spinner"
                      class="hidden absolute inset-y-0 right-0 flex items-center pr-3 text-accent"
                      aria-hidden="true">
                    <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                </span>
            </div>

            <p class="text-xs text-gray-500">
                Vyhledejte adresu, nebo ji
                <button type="button" data-action="address-autocomplete#showManual" class="text-accent hover:underline">zadejte ručně</button>.
            </p>

            {# The NotBlank errors live on the three fields in the (hidden) manual
               section. If the user explicitly switched back to the search box and then
               submitted, this hint is the only visible trace of the failed validation. #}
            {% if addressHasViolation and not addressHasValue %}
                <p class="form-error">Vyplňte prosím fakturační adresu — vyhledejte ji, nebo ji zadejte ručně.</p>
            {% endif %}
        </div>

        {# --- The three real fields (revealed after a pick, or for manual entry) --- #}
        <div data-address-autocomplete-target="manualSection" class="{{ addressPrefilled ? '' : 'hidden ' }}space-y-4">
            <div class="flex items-center justify-between gap-2">
                {# data-live-ignore: the controller sets the "filled from search"
                   confirmation client-side; a morph must not wipe it. #}
                <p data-address-autocomplete-target="statusText"
                   class="text-sm text-green-700 min-h-5"
                   aria-live="polite"
                   data-live-ignore></p>
                <button type="button" data-action="address-autocomplete#showSearch" class="shrink-0 text-sm text-accent hover:underline">
                    Vyhledat adresu
                </button>
            </div>

            <div>
                {{ form_row(form.billingStreet, {
                    label_attr: {class: 'form-label-required'},
                    attr: streetAttr,
                }) }}
            </div>

            <div class="grid md:grid-cols-2 gap-4">
                <div>
                    {{ form_row(form.billingCity, {
                        label_attr: {class: 'form-label-required'},
                        attr: cityAttr,
                    }) }}
                </div>
                <div>
                    {{ form_row(form.billingPostalCode, {
                        label_attr: {class: 'form-label-required'},
                        attr: postalAttr,
                    }) }}
                </div>
            </div>

            {# Soft-warn override: surfaces when the server-side AddressExists check
               could not match the address (violation lands at path 'billingStreet').
               Hidden until a violation lands so the customer can confirm an edge-case
               address the Photon registry doesn't recognise. #}
            <div data-address-autocomplete-target="overrideContainer"
                 class="{{ streetHasViolation ? '' : 'hidden ' }}rounded border border-amber-300 bg-amber-50 p-3 text-sm text-amber-900">
                <p class="font-medium mb-1">Tuto adresu se nepodařilo ověřit v registru.</p>
                <p class="mb-2 text-amber-800">Zkontrolujte ulici, město i PSČ. Pokud je adresa správná, pokračujte zaškrtnutím níže.</p>
                <label class="flex items-center cursor-pointer">
                    {{ form_widget(form.addressOverride, {attr: {
                        'data-address-autocomplete-target': 'overrideCheckbox',
                        'class': 'mr-2',
                    }}) }}
                    <span>{{ form.addressOverride.vars.label|default('Adresa je správná, pokračovat') }}</span>
                </label>
            </div>
        </div>
    </div>
{% endmacro %}
