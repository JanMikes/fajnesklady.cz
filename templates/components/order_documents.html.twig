{#
   "Vaše dokumenty" card for the authenticated portal user order detail.
   The public order-status permalink uses `order_status_documents.html.twig`
   with pre-signed URLs.

   Inputs:
   - order: Order
   - contract: ?Contract
   - invoices: list<Invoice>
   - place: Place
   - handoverProtocol: ?HandoverProtocol  (only the COMPLETED state renders a row)

   Always invoked from a logged-in context — the shared layout already
   guards on ROLE_USER, so per-invoice `portal_user_invoice_pdf` and the
   place-scoped uploader URLs are always reachable.
#}

{% set isRecurring = order.endDate is null %}

<div class="card">
    <div class="card-body">
        <h2 class="text-lg font-bold text-gray-900 mb-1 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Vaše dokumenty
        </h2>
        <p class="text-sm text-gray-500 mb-5">Dokumenty si můžete <span class="font-medium">zobrazit v prohlížeči</span> nebo <span class="font-medium">stáhnout</span>.</p>

        {# Smluvní dokumenty: smlouva + faktury #}
        <div class="mb-6">
            <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Smluvní dokumenty</h3>
            <ul class="divide-y divide-gray-100 border border-gray-100 rounded-lg">
                {% if contract and contract.hasDocument %}
                    {# Portal contract is served as DOCX (no in-browser view) —
                       offer download only. The public order-status page serves a
                       converted PDF and exposes both view + download. #}
                    {{ _self.documentRow(
                        null,
                        path('portal_user_contract_download', {id: contract.id}),
                        'Nájemní smlouva',
                        'Podepsaná smlouva o pronájmu skladové jednotky',
                        'pdf'
                    ) }}
                {% elseif contract %}
                    {{ _self.documentRow(
                        null,
                        null,
                        'Nájemní smlouva',
                        'Dokument se připravuje, bude doručen e-mailem',
                        'pdf'
                    ) }}
                {% endif %}

                {% if handoverProtocol is defined and handoverProtocol and handoverProtocol.isFullyCompleted %}
                    {{ _self.documentRow(
                        path('portal_user_handover_view', {id: handoverProtocol.id}),
                        null,
                        'Předávací protokol',
                        'Vyplněn ' ~ handoverProtocol.completedAt|date('d.m.Y'),
                        'pdf'
                    ) }}
                {% endif %}

                {% for invoice in invoices %}
                    {% if invoice.hasPdf() %}
                        {{ _self.documentRow(
                            path('portal_user_invoice_pdf', {id: invoice.id}),
                            path('portal_user_invoice_pdf', {id: invoice.id, download: 1}),
                            'Faktura č. ' ~ invoice.invoiceNumber,
                            'Daňový doklad za platbu ' ~ ((invoice.amount / 100)|number_format(2, ',', ' ')) ~ ' Kč',
                            'pdf'
                        ) }}
                    {% else %}
                        {{ _self.documentRow(
                            null,
                            null,
                            'Faktura č. ' ~ invoice.invoiceNumber,
                            'PDF se připravuje, bude doručeno e-mailem',
                            'pdf'
                        ) }}
                    {% endif %}
                {% endfor %}
            </ul>
        </div>

        {# Pobočka: provozní řád + návod + mapa #}
        {% if place.operatingRulesPath or place.instructionsPath %}
            <div class="mb-6">
                <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Pobočka</h3>
                <ul class="divide-y divide-gray-100 border border-gray-100 rounded-lg">
                    {% if place.operatingRulesPath %}
                        {{ _self.documentRow(
                            upload_url(place.operatingRulesPath),
                            upload_url(place.operatingRulesPath),
                            'Provozní řád pobočky',
                            'Pravidla pro užívání skladu a pobočky',
                            'pdf'
                        ) }}
                    {% endif %}
                    {% if place.instructionsPath %}
                        {{ _self.documentRow(
                            upload_url(place.instructionsPath),
                            upload_url(place.instructionsPath),
                            'Návod pro zákazníky',
                            'Praktický návod k používání skladu a pobočky',
                            'pdf'
                        ) }}
                    {% endif %}
                </ul>
            </div>
        {% endif %}

        {# Právní a obchodní dokumenty #}
        <div>
            <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Právní a obchodní dokumenty</h3>
            <ul class="divide-y divide-gray-100 border border-gray-100 rounded-lg">
                {{ _self.documentRow(
                    path('portal_user_order_vop_pdf', {id: order.id}),
                    path('portal_user_order_vop_pdf', {id: order.id, download: 1}),
                    'Všeobecné obchodní podmínky (VOP)',
                    'Podpis na každé straně, platné v době uzavření smlouvy',
                    'pdf'
                ) }}
                {{ _self.documentRow(
                    asset('documents/pouceni-spotrebitele.pdf'),
                    asset('documents/pouceni-spotrebitele.pdf'),
                    'Poučení spotřebitele',
                    'Vaše práva při uzavření smlouvy distančním způsobem',
                    'pdf'
                ) }}
                {% if isRecurring %}
                    {{ _self.documentRow(
                        asset('documents/podminky-opakovanych-plateb.pdf'),
                        asset('documents/podminky-opakovanych-plateb.pdf'),
                        'Podmínky opakovaných plateb',
                        'Pravidla pro opakované strhávání platby z karty',
                        'pdf'
                    ) }}
                {% endif %}
                {{ _self.documentRow(
                    asset('documents/formular-odstoupeni-od-smlouvy.pdf'),
                    asset('documents/formular-odstoupeni-od-smlouvy.pdf'),
                    'Formulář pro odstoupení od smlouvy',
                    'Pro uplatnění práva na odstoupení (14denní lhůta)',
                    'pdf'
                ) }}
                {{ _self.documentRow(
                    asset('documents/reklamacni-formular.pdf'),
                    asset('documents/reklamacni-formular.pdf'),
                    'Reklamační formulář',
                    'Pro uplatnění reklamace služby',
                    'pdf'
                ) }}
            </ul>
        </div>
    </div>
</div>

{#
   Renders a single document row. Two optional actions on the right:
   - viewHref: opens inline in a new tab (eye icon)
   - downloadHref: forces save (download arrow icon; uses HTML5 `download`
     attribute so static assets without server-side Content-Disposition
     still save instead of opening)
   If both hrefs are null the row is rendered in a disabled / placeholder
   state (used for "PDF se připravuje" cases).
#}
{% macro documentRow(viewHref, downloadHref, name, description, kind) %}
    {% set isDisabled = viewHref is null and downloadHref is null %}
    <li>
        <div class="flex items-center gap-3 px-4 py-3 {% if isDisabled %}opacity-60{% else %}hover:bg-gray-50 transition-colors{% endif %}">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center {% if isDisabled %}bg-gray-100 text-gray-400{% elseif kind == 'image' %}bg-blue-50 text-blue-600{% else %}bg-red-50 text-red-600{% endif %}">
                {% if kind == 'image' %}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                {% else %}
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                {% endif %}
            </div>
            <div class="flex-1 min-w-0">
                <div class="font-medium {% if isDisabled %}text-gray-700{% else %}text-gray-900{% endif %}">{{ name }}</div>
                <div class="text-xs text-gray-500">{{ description }}</div>
            </div>
            {% if not isDisabled %}
                <div class="flex-shrink-0 flex items-center gap-1">
                    {% if viewHref %}
                        <a href="{{ viewHref }}" target="_blank" rel="noopener"
                           title="Zobrazit v prohlížeči" aria-label="Zobrazit v prohlížeči"
                           class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-gray-500 hover:text-accent hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-1 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </a>
                    {% endif %}
                    {% if downloadHref %}
                        <a href="{{ downloadHref }}" download
                           title="Stáhnout" aria-label="Stáhnout"
                           class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-gray-500 hover:text-accent hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-1 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                            </svg>
                        </a>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </li>
{% endmacro %}
