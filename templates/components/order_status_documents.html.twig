{#
   "Vaše dokumenty" panel for the public order-status permalink.
   Inputs:
   - vm: OrderStatusViewModel

   All download URLs are pre-signed by OrderStatusUrlGenerator and carried
   on the view model — no `path()` calls for the four hardened routes here.
#}

{% set isRecurring = vm.isRecurring %}
{% set hasContractRow = vm.contract is not null %}

<div class="card">
    <div class="card-body">
        <h2 class="text-lg font-bold text-gray-900 mb-1 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Vaše dokumenty
        </h2>
        <p class="text-sm text-gray-500 mb-5">Všechny dokumenty související s objednávkou si zde můžete kdykoli stáhnout.</p>

        {% if hasContractRow or vm.invoiceDownloads is not empty %}
            <div class="mb-6">
                <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Smluvní dokumenty</h3>
                <ul class="divide-y divide-gray-100 border border-gray-100 rounded-lg">
                    {% if hasContractRow %}
                        {{ _self.documentRow(
                            vm.contractDownloadUrl,
                            'Nájemní smlouva',
                            vm.contractDownloadUrl ? 'Podepsaná smlouva o pronájmu skladové jednotky' : 'Dokument se připravuje, bude doručen e-mailem',
                            'pdf'
                        ) }}
                    {% endif %}

                    {% for invoice in vm.invoiceDownloads %}
                        {{ _self.documentRow(
                            invoice.hasPdf ? invoice.url : null,
                            invoice.name,
                            invoice.hasPdf
                                ? 'Daňový doklad za platbu ' ~ (invoice.amountCzk|number_format(2, ',', ' ')) ~ ' Kč'
                                : 'PDF se připravuje, bude doručeno e-mailem',
                            'pdf'
                        ) }}
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {% if vm.place.operatingRulesPath or vm.place.instructionsPath or vm.mapDownloadUrl %}
            <div class="mb-6">
                <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Pobočka</h3>
                <ul class="divide-y divide-gray-100 border border-gray-100 rounded-lg">
                    {% if vm.place.operatingRulesPath %}
                        {{ _self.documentRow(
                            upload_url(vm.place.operatingRulesPath),
                            'Provozní řád pobočky',
                            'Pravidla pro užívání skladu a pobočky',
                            'pdf'
                        ) }}
                    {% endif %}
                    {% if vm.place.instructionsPath %}
                        {{ _self.documentRow(
                            upload_url(vm.place.instructionsPath),
                            'Návod pro zákazníky',
                            'Praktický návod k používání skladu a pobočky',
                            'pdf'
                        ) }}
                    {% endif %}
                    {% if vm.mapDownloadUrl %}
                        {{ _self.documentRow(
                            vm.mapDownloadUrl,
                            'Mapa pobočky',
                            'Vaše skladová jednotka vyznačená v mapě',
                            'image'
                        ) }}
                    {% endif %}
                </ul>
            </div>
        {% endif %}

        <div>
            <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-2">Právní a obchodní dokumenty</h3>
            <ul class="divide-y divide-gray-100 border border-gray-100 rounded-lg">
                {{ _self.documentRow(
                    vm.vopDownloadUrl,
                    'Všeobecné obchodní podmínky (VOP)',
                    'Podpis na každé straně, platné v době uzavření smlouvy',
                    'pdf'
                ) }}
                {{ _self.documentRow(
                    asset('documents/pouceni-spotrebitele.pdf'),
                    'Poučení spotřebitele',
                    'Vaše práva při uzavření smlouvy distančním způsobem',
                    'pdf'
                ) }}
                {% if isRecurring %}
                    {{ _self.documentRow(
                        asset('documents/podminky-opakovanych-plateb.pdf'),
                        'Podmínky opakovaných plateb',
                        'Pravidla pro opakované strhávání platby z karty',
                        'pdf'
                    ) }}
                {% endif %}
                {{ _self.documentRow(
                    asset('documents/formular-odstoupeni-od-smlouvy.pdf'),
                    'Formulář pro odstoupení od smlouvy',
                    'Pro uplatnění práva na odstoupení (14denní lhůta)',
                    'pdf'
                ) }}
                {{ _self.documentRow(
                    asset('documents/reklamacni-formular.pdf'),
                    'Reklamační formulář',
                    'Pro uplatnění reklamace služby',
                    'pdf'
                ) }}
            </ul>
        </div>
    </div>
</div>

{% macro documentRow(href, name, description, kind) %}
    <li>
        {% if href %}
            <a href="{{ href }}" target="_blank" rel="noopener" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors group">
                <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center {% if kind == 'image' %}bg-blue-50 text-blue-600{% else %}bg-red-50 text-red-600{% endif %}">
                    {% if kind == 'image' %}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    {% else %}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    {% endif %}
                </div>
                <div class="flex-1 min-w-0">
                    <div class="font-medium text-gray-900 group-hover:text-accent transition-colors">{{ name }}</div>
                    <div class="text-xs text-gray-500">{{ description }}</div>
                </div>
                <div class="flex-shrink-0 text-gray-400 group-hover:text-accent transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                </div>
            </a>
        {% else %}
            <div class="flex items-center gap-3 px-4 py-3 opacity-60">
                <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center bg-gray-100 text-gray-400">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="font-medium text-gray-700">{{ name }}</div>
                    <div class="text-xs text-gray-500">{{ description }}</div>
                </div>
            </div>
        {% endif %}
    </li>
{% endmacro %}
