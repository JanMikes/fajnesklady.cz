{% import 'components/_address_override.html.twig' as addr %}

<div {{ attributes }}>
    {{ form_start(form) }}
        <div class="space-y-4" data-controller="ares-lookup">
            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">IČO</label>
                <div class="flex">
                    {{ form_widget(form.companyId, {
                        attr: {
                            'placeholder': '12345678',
                            'class': 'flex-1 min-w-0 rounded-r-none!'
                        }
                    }) }}
                    {% include 'components/ares_lookup_button.html.twig' %}
                </div>
                <p data-ares-lookup-target="status" class="text-sm mt-2" aria-live="polite"></p>
                {{ form_errors(form.companyId) }}
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Název firmy</label>
                {{ form_widget(form.companyName, {
                    attr: {'placeholder': 'Firma s.r.o.'}
                }) }}
                {{ form_errors(form.companyName) }}
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">DIČ</label>
                {{ form_widget(form.companyVatId, {
                    attr: {'placeholder': 'CZ12345678'}
                }) }}
                {{ form_errors(form.companyVatId) }}
            </div>

            <hr class="my-4 border-t border-gray-200">
            <h3 class="text-lg font-semibold">Fakturační adresa</h3>

            {{ addr.render(form) }}
        </div>

        <div class="flex justify-end gap-2 mt-6">
            <a href="{{ path('portal_profile') }}" class="btn btn-ghost">Zrušit</a>
            <button type="submit" class="btn btn-primary">Uložit fakturační údaje</button>
        </div>
    {{ form_end(form) }}
</div>
