{% extends 'user/layout.html.twig' %}

{% block title %}Nastavení platby kartou - Fajnesklady.cz{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto">
    <div class="card">
        <div class="card-body">
            {% if state == 'ineligible' %}
                <div class="text-center">
                    <div class="inline-flex items-center justify-center w-16 h-16 bg-gray-100 rounded-full mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <h1 class="text-2xl font-bold text-gray-900 mb-2">Přechod na platbu kartou není dostupný</h1>
                    <p class="text-gray-600 mb-6">
                        Pro tuto smlouvu nelze automatickou platbu kartou nastavit — buď již nastavená je,
                        nebo se smlouva platí jinak (roční platba, pronájem zdarma), případně už skončila.
                    </p>
                    <a href="{{ statusUrl }}" class="btn btn-primary">Zobrazit stav objednávky</a>
                </div>
            {% else %}
                <h1 class="text-2xl font-bold text-gray-900 mb-2">Nastavení automatické platby kartou</h1>
                <p class="text-sm text-gray-600 mb-6">
                    Skladová jednotka č. <strong>{{ storage.number }}</strong> ({{ storage.storageType.name }}),
                    {{ place.name }} — smlouva platí do <strong>{{ contract.endDate|date('d.m.Y') }}</strong>.
                </p>

                <div class="mb-6 rounded-lg border border-green-200 bg-green-50 p-4">
                    <p class="text-sm text-green-900 font-semibold">
                        Při volbě automatické platby kartou garantujeme dostupnost Vaší skladovací jednotky
                        v případě potřeby prodloužení pronájmu.
                    </p>
                </div>

                <p class="text-sm text-gray-700 mb-6">
                    Nyní zaplatíte kartou platbu za nadcházející období
                    (<strong>{{ amountInCzk|number_format(0, ',', ' ') }} Kč vč. DPH</strong>, splatnou {{ nextBillingDate|date('d.m.Y') }}).
                    Tím se karta uloží na bráně GoPay a další platby se již strhávají automaticky.
                </p>

                {# Parameters card + dedicated consent — GoPay compliance, mirrors
                   order_accept.html.twig. Labels and order match the reviewer
                   checklist verbatim; do not reword (see .claude/COMPLIANCE.md). #}
                <div id="setup-recurring" class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
                    <h2 class="font-semibold text-gray-900 mb-3 flex items-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                        Parametry opakované platby
                    </h2>

                    <div class="space-y-2 text-sm">
                        <div class="flex justify-between gap-3">
                            <span class="text-gray-600 shrink-0">Účel platby</span>
                            <span class="font-medium text-right">Pronájem skladovací jednotky</span>
                        </div>
                        <div class="flex justify-between gap-3">
                            <span class="text-gray-600 shrink-0">Maximální částka opakované platby</span>
                            <span class="font-medium text-right">{{ recurringPaymentLegalMaxInCzk|number_format(0, ',', ' ') }} Kč</span>
                        </div>
                        <div class="flex justify-between gap-3">
                            <span class="text-gray-600 shrink-0">Částka jednotlivé platby</span>
                            <span class="font-medium text-right">
                                <strong>Fixní</strong>, {{ monthlyAmountInCzk|number_format(0, ',', ' ') }} Kč / měsíc <span class="text-xs text-gray-500 font-normal">vč. DPH</span>
                                <br><span class="text-xs text-gray-500 font-normal">Poslední doplatek bude prorátován podle počtu zbývajících dní.</span>
                            </span>
                        </div>
                        <div class="flex justify-between gap-3">
                            <span class="text-gray-600 shrink-0">Frekvence a den strhávání</span>
                            <span class="font-medium text-right">
                                <strong>Fixní</strong>, měsíční — vždy ke stejnému dni v měsíci jako tato platba<br>
                                <span class="text-xs text-gray-500 font-normal">Pokud připadne na nepracovní den, strhne se následující pracovní den.</span>
                            </span>
                        </div>
                        <div class="flex justify-between gap-3">
                            <span class="text-gray-600 shrink-0">Doba trvání</span>
                            <span class="font-medium text-right">{{ remainingCharges }} platby do {{ contract.endDate|date('d.m.Y') }}</span>
                        </div>
                        <div class="flex justify-between gap-3">
                            <span class="text-gray-600 shrink-0">Forma komunikace pro změnu nastavení</span>
                            <span class="font-medium text-right"><a href="mailto:simek@fajnesklady.cz" class="text-accent hover:underline">simek@fajnesklady.cz</a></span>
                        </div>
                        <div class="flex justify-between gap-3">
                            <span class="text-gray-600 shrink-0">Zrušení a storno opakované platby</span>
                            <span class="font-medium text-right">
                                <a href="mailto:simek@fajnesklady.cz" class="text-accent hover:underline">simek@fajnesklady.cz</a> — kdykoli, bez sankce<br>
                                <span class="text-xs text-gray-500 font-normal">Podrobně viz <a href="{{ path('public_recurring_payments_terms') }}" target="_blank" class="text-accent hover:underline">Podmínky opakovaných plateb</a>, čl. VI.</span>
                            </span>
                        </div>
                    </div>

                    {# Dedicated consent checkbox — REQUIRED to be separate (GoPay rule + Podmínky čl. I). #}
                    <label class="mt-4 pt-3 border-t border-amber-200 flex items-start gap-3 cursor-pointer">
                        <input type="checkbox" id="consent-recurring" class="form-checkbox h-5 w-5 mt-0.5 border-amber-300 shrink-0">
                        <span class="text-sm text-gray-800">
                            <strong>Souhlasím s opakovanou platbou</strong> v parametrech uvedených výše a s uložením platebních údajů na bráně GoPay.
                        </span>
                    </label>

                    {# PCI-DSS Level 1 disclosure — must be visible AT the consent point. #}
                    <p class="mt-3 text-xs text-gray-500">
                        Společnost <strong>GOPAY s.r.o.</strong> nakládá s údaji Vaší platební karty podle mezinárodního bezpečnostního standardu <strong>PCI-DSS Level 1</strong> — nejvyšší úroveň datové bezpečnosti ve finančním sektoru. Čísla karet ani CVV s námi GoPay nesdílí a Pronajímatel k nim nemá přístup.
                    </p>
                </div>

                {# Payment card logos + SSL/3DS notice (GoPay compliance). #}
                <div class="flex flex-col items-center gap-2 py-2 mb-4">
                    {% include 'components/payment_logos.html.twig' %}
                    <p class="text-xs text-gray-500 flex items-center gap-1">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                        </svg>
                        Vaše platba je zabezpečena 256-bit SSL/TLS šifrováním a 3D Secure 2.0.
                    </p>
                </div>

                <div id="setup-error" class="hidden mb-4 rounded-lg border border-red-300 bg-red-50 p-4 text-sm text-red-800" role="alert">
                    <span id="setup-error-text"></span>
                </div>
                <div id="setup-loading" class="hidden mb-4 text-sm text-gray-600">Připravujeme platbu…</div>

                <div id="setup-actions" class="flex items-center justify-between pt-2 border-t border-gray-200">
                    <a href="{{ statusUrl }}" class="inline-flex items-center text-gray-600 hover:text-gray-900">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                        </svg>
                        Zpět
                    </a>
                    <button type="button" id="setup-pay-button" class="btn btn-primary btn-lg">
                        Zaplatit a nastavit kartu
                    </button>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if state == 'form' %}
    <script src="{{ goPayEmbedJs }}" async></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const payButton = document.getElementById('setup-pay-button');
            const consentEl = document.getElementById('consent-recurring');
            const loadingEl = document.getElementById('setup-loading');
            const errorEl = document.getElementById('setup-error');
            const errorTextEl = document.getElementById('setup-error-text');
            const actionsEl = document.getElementById('setup-actions');

            function showError(message) {
                errorTextEl.textContent = message;
                errorEl.classList.remove('hidden');
                loadingEl.classList.add('hidden');
                actionsEl.classList.remove('hidden');
            }

            payButton.addEventListener('click', async function() {
                errorEl.classList.add('hidden');

                if (!consentEl.checked) {
                    showError('Potvrďte prosím souhlas s opakovanou platbou.');
                    document.getElementById('setup-recurring').scrollIntoView({behavior: 'smooth', block: 'center'});
                    return;
                }

                loadingEl.classList.remove('hidden');
                actionsEl.classList.add('hidden');

                try {
                    const response = await fetch('{{ initiateUrl|e('js') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({consent: true})
                    });

                    const data = await response.json();

                    if (!response.ok) {
                        showError(data.error || 'Došlo k chybě při vytváření platby.');
                        return;
                    }

                    loadingEl.classList.add('hidden');

                    if (typeof _gopay === 'undefined') {
                        showError('Platební brána se načítá. Zkuste to prosím znovu za moment.');
                        return;
                    }

                    _gopay.checkout({
                        gatewayUrl: data.gwUrl,
                        inline: true
                    });
                } catch (error) {
                    console.error('Payment error:', error);
                    showError('Došlo k chybě při komunikaci se serverem. Zkuste to prosím znovu.');
                }
            });
        });
    </script>
    {% endif %}
{% endblock %}
