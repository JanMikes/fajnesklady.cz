{% extends app.user ? 'portal/layout.html.twig' : 'user/layout.html.twig' %}

{% block title %}Objednávka dokončena - Fajnesklady.cz{% endblock %}

{% block content %}
    <div class="max-w-4xl mx-auto">
        {# Success Header #}
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-green-100 rounded-full mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <h1 class="text-3xl font-bold text-gray-900 mb-2">Objednávka dokončena!</h1>
            <p class="text-gray-600">Děkujeme za Vaši objednávku. Skladová jednotka je připravena k užívání.</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            {# Left column: order summary + documents (spans 2) #}
            <div class="lg:col-span-2 space-y-6">

                {# Order Summary #}
                <div class="card">
                    <div class="card-body">
                        <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                            </svg>
                            Detail objednávky
                        </h2>

                        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
                            {% if contract %}
                                <div>
                                    <dt class="text-gray-500">Číslo smlouvy</dt>
                                    <dd class="font-mono font-medium text-gray-900">{{ contract.id|slice(0, 8)|upper }}</dd>
                                </div>
                            {% endif %}
                            <div>
                                <dt class="text-gray-500">Pobočka</dt>
                                <dd class="font-medium text-gray-900">{{ place.name }}</dd>
                            </div>
                            <div class="sm:col-span-2">
                                <dt class="text-gray-500">Adresa</dt>
                                <dd class="font-medium text-gray-900">{{ place.address }}, {{ place.postalCode }} {{ place.city }}</dd>
                            </div>
                            <div>
                                <dt class="text-gray-500">Skladová jednotka</dt>
                                <dd class="font-medium text-gray-900">{{ storageType.name }} – {{ storage.number }}</dd>
                            </div>
                            <div>
                                <dt class="text-gray-500">Rozměry</dt>
                                <dd class="font-medium text-gray-900">{{ storageType.dimensionsInMeters }}</dd>
                            </div>
                            <div>
                                <dt class="text-gray-500">Datum začátku</dt>
                                <dd class="font-medium text-gray-900">{{ order.startDate|date('d.m.Y') }}</dd>
                            </div>
                            <div>
                                <dt class="text-gray-500">Datum konce</dt>
                                <dd class="font-medium text-gray-900">
                                    {% if order.endDate %}
                                        {{ order.endDate|date('d.m.Y') }}
                                    {% else %}
                                        Na dobu neurčitou
                                    {% endif %}
                                </dd>
                            </div>
                            <div class="sm:col-span-2 pt-3 mt-1 border-t border-gray-100">
                                <dt class="text-gray-500">Zaplaceno</dt>
                                <dd class="font-bold text-lg text-green-600">{{ order.totalPriceInCzk|number_format(2, ',', ' ') }} Kč <span class="text-xs font-normal text-gray-500">vč. DPH</span></dd>
                            </div>
                        </dl>
                    </div>
                </div>

                {# Map preview #}
                {% if place.mapImagePath %}
                    <div class="card">
                        <div class="card-body">
                            <div class="flex items-start justify-between mb-4 gap-4">
                                <div>
                                    <h2 class="text-lg font-bold text-gray-900 mb-1 flex items-center gap-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                                        </svg>
                                        Mapa pobočky
                                    </h2>
                                    <p class="text-sm text-gray-500">Vaše skladová jednotka <strong>{{ storage.number }}</strong> v rámci pobočky.</p>
                                </div>
                                <a href="{{ path('public_order_map_download', {id: order.id, download: 1}) }}"
                                   class="btn btn-ghost btn-sm shrink-0"
                                   title="Stáhnout obrázek mapy">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                                    </svg>
                                    Stáhnout
                                </a>
                            </div>
                            <a href="{{ path('public_order_map_download', {id: order.id}) }}" target="_blank" class="block group">
                                <div class="rounded-lg overflow-hidden border border-gray-200 bg-gray-50">
                                    <img src="{{ path('public_order_map_download', {id: order.id}) }}"
                                         alt="Mapa pobočky {{ place.name }} s vyznačenou skladovou jednotkou"
                                         class="w-full h-auto group-hover:opacity-95 transition-opacity">
                                </div>
                            </a>
                        </div>
                    </div>
                {% endif %}

                {# Documents #}
                <div id="dokumenty">
                    {% include 'components/order_documents.html.twig' with {order, contract, invoices, place} only %}
                </div>

                {# What's Next #}
                <div class="card">
                    <div class="card-body">
                        <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                            </svg>
                            Co dál?
                        </h2>

                        <ol class="space-y-4">
                            <li class="flex items-start">
                                <div class="flex-shrink-0 w-8 h-8 bg-accent/10 rounded-full flex items-center justify-center mr-3 mt-0.5">
                                    <span class="text-accent font-bold text-sm">1</span>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-900">Navštivte pobočku</h3>
                                    <p class="text-sm text-gray-600">
                                        Přijďte na adresu {{ place.address }}, {{ place.city }} a vyzvedněte si klíč
                                        od skladové jednotky.
                                    </p>
                                </div>
                            </li>
                            <li class="flex items-start">
                                <div class="flex-shrink-0 w-8 h-8 bg-accent/10 rounded-full flex items-center justify-center mr-3 mt-0.5">
                                    <span class="text-accent font-bold text-sm">2</span>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-900">Připravte si vlastní zámek</h3>
                                    <p class="text-sm text-gray-600">
                                        Pro zabezpečení své skladové jednotky si přineste vlastní visací zámek.
                                    </p>
                                </div>
                            </li>
                            <li class="flex items-start">
                                <div class="flex-shrink-0 w-8 h-8 bg-accent/10 rounded-full flex items-center justify-center mr-3 mt-0.5">
                                    <span class="text-accent font-bold text-sm">3</span>
                                </div>
                                <div>
                                    <h3 class="font-semibold text-gray-900">Přístup 24/7</h3>
                                    <p class="text-sm text-gray-600">
                                        Ke skladové jednotce máte přístup kdykoliv. Dostanete vlastní ovladač k bráně.
                                    </p>
                                </div>
                            </li>
                        </ol>
                    </div>
                </div>
            </div>

            {# Right column: sidebar #}
            <div class="space-y-6">

                {# Email Notice #}
                <div class="card">
                    <div class="card-body text-center">
                        <div class="inline-flex items-center justify-center w-12 h-12 bg-accent/10 rounded-full mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <h3 class="font-semibold text-gray-900 mb-1">Vše máme i v e-mailu</h3>
                        <p class="text-sm text-gray-600">
                            Potvrzení objednávky včetně všech dokumentů jsme Vám poslali na e-mail.
                        </p>
                    </div>
                </div>

                {# Navigation #}
                {% if place.latitude and place.longitude %}
                    <a href="https://maps.google.com/?q={{ place.latitude }},{{ place.longitude }}"
                       target="_blank"
                       class="btn btn-secondary w-full justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
                        </svg>
                        Navigovat na pobočku
                    </a>
                {% endif %}

                {# Contact Information #}
                <div class="bg-accent/5 rounded-lg p-4 border border-accent/10">
                    <h3 class="font-semibold text-gray-900 mb-2">Potřebujete pomoc?</h3>
                    <p class="text-sm text-gray-600 mb-3">
                        V případě dotazů nás neváhejte kontaktovat:
                    </p>
                    <a href="tel:+420605522566" class="link inline-flex items-center text-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                        +420 605 522 566
                    </a>
                </div>

                {# Back link #}
                <a href="{{ app.user ? path('portal_browse_places') : path('app_home') }}" class="btn btn-ghost w-full justify-center">
                    {{ app.user ? 'Zpět do portálu' : 'Zpět na hlavní stránku' }}
                </a>
            </div>
        </div>
    </div>
{% endblock %}

