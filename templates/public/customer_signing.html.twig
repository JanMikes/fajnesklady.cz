{% extends 'user/layout.html.twig' %}

{% set customerFullName = (order.user.firstName ~ ' ' ~ order.user.lastName)|trim %}

{% block title %}Podpis smlouvy - Fajné Sklady{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Great+Vibes&family=Pacifico&family=Satisfy&display=swap" rel="stylesheet">
{% endblock %}

{% block content %}
    <div class="max-w-2xl mx-auto"
         x-data="{
             modalOpen: false,
             signed: false,
             acceptContract: false,
             signatureConsent: false,
             signingPlace: '',
             acceptVop: false,
             acceptGdpr: false,
         }"
         @signature:signed.window="signed = true; modalOpen = false"
         data-controller="signature"
         data-signature-customer-name-value="{{ customerFullName }}">
        <div class="card">
            <div class="card-body">
                <h1 class="text-2xl font-bold text-gray-900 mb-6">Podpis smlouvy</h1>

                <p class="text-sm text-gray-600 mb-6">
                    Zkontrolujte prosím údaje smlouvy a podepište ji elektronicky.
                </p>

                {# Order Summary #}
                <div class="bg-gray-50 rounded-lg p-4 mb-6">
                    <h2 class="font-semibold text-gray-900 mb-3">Shrnutí smlouvy</h2>

                    <div class="space-y-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-gray-600">Pobočka:</span>
                            <span class="font-medium">{{ place.name }}, {{ place.city }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Skladová jednotka:</span>
                            <span class="font-medium">{{ storageType.name }} ({{ storage.number }})</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Rozměry:</span>
                            <span class="font-medium">{{ storageType.getDimensionsInMeters() }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Typ pronájmu:</span>
                            <span class="font-medium">{{ order.rentalType.value == 'unlimited' ? 'Doba neurčitá' : 'Doba určitá' }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Začátek:</span>
                            <span class="font-medium">{{ order.startDate|date('d.m.Y') }}</span>
                        </div>
                        {% if order.endDate %}
                        <div class="flex justify-between">
                            <span class="text-gray-600">Konec:</span>
                            <span class="font-medium">{{ order.endDate|date('d.m.Y') }}</span>
                        </div>
                        {% endif %}
                        <hr class="border-gray-200 my-2">
                        <div class="flex justify-between font-semibold">
                            <span>{{ isRecurring ? 'Měsíční platba:' : 'Celková cena:' }}</span>
                            <span>{{ (totalPrice / 100)|number_format(0, ',', ' ') }} Kč</span>
                        </div>
                    </div>
                </div>

                {# Customer Info #}
                <div class="bg-gray-50 rounded-lg p-4 mb-6">
                    <h2 class="font-semibold text-gray-900 mb-3">Údaje nájemce</h2>
                    <div class="space-y-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-gray-600">Jméno:</span>
                            <span class="font-medium">{{ customerFullName }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">E-mail:</span>
                            <span class="font-medium">{{ order.user.email }}</span>
                        </div>
                        {% if order.user.phone %}
                        <div class="flex justify-between">
                            <span class="text-gray-600">Telefon:</span>
                            <span class="font-medium">{{ order.user.phone }}</span>
                        </div>
                        {% endif %}
                    </div>
                </div>

                {# Signing Form #}
                <form method="post" id="signing-form">
                    {# Consents #}
                    <div class="space-y-3 mb-6">
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" name="accept_contract" value="1" x-model="acceptContract"
                                   class="h-4 w-4 mt-1 text-accent focus:ring-accent border-gray-300 rounded">
                            <span class="text-sm text-gray-700">Souhlasím se smluvními podmínkami pronájmu skladové jednotky.</span>
                        </label>
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" name="accept_vop" value="1" x-model="acceptVop"
                                   class="h-4 w-4 mt-1 text-accent focus:ring-accent border-gray-300 rounded">
                            <span class="text-sm text-gray-700">Souhlasím s všeobecnými obchodními podmínkami.</span>
                        </label>
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" name="accept_gdpr" value="1" x-model="acceptGdpr"
                                   class="h-4 w-4 mt-1 text-accent focus:ring-accent border-gray-300 rounded">
                            <span class="text-sm text-gray-700">Souhlasím se zpracováním osobních údajů.</span>
                        </label>
                    </div>

                    <hr class="my-6 border-t border-gray-200">

                    {# Signing Place #}
                    <div class="mb-4">
                        <label for="signing_place" class="block text-sm font-medium text-gray-700 mb-1">Místo podpisu</label>
                        <input type="text" name="signing_place" id="signing_place" x-model="signingPlace"
                               class="input input-bordered w-full" placeholder="např. Praha">
                    </div>

                    {# Signature #}
                    <div class="mb-4">
                        <h3 class="text-sm font-medium text-gray-700 mb-2">Elektronický podpis</h3>

                        <div x-show="!signed" class="text-center py-8 border-2 border-dashed border-gray-300 rounded-lg cursor-pointer hover:border-accent transition-colors"
                             @click="modalOpen = true">
                            <svg class="mx-auto h-12 w-12 text-gray-400 mb-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                            </svg>
                            <p class="text-sm text-gray-600">Klikněte pro přidání podpisu</p>
                        </div>

                        <div x-show="signed" class="text-center">
                            <div class="inline-block p-4 border border-green-200 bg-green-50 rounded-lg">
                                <p class="text-sm text-green-700 font-medium">Podpis přidán</p>
                                <img data-signature-target="preview" class="max-h-20 mx-auto mt-2" alt="Podpis">
                            </div>
                            <button type="button" @click="signed = false; modalOpen = true" class="block mx-auto mt-2 text-sm text-accent hover:underline">Změnit podpis</button>
                        </div>

                        <input type="hidden" name="signature_data" data-signature-target="dataField" value="">
                        <input type="hidden" name="signing_method" data-signature-target="methodField" value="">
                        <input type="hidden" name="typed_name" data-signature-target="typedNameField" value="">
                        <input type="hidden" name="style_id" data-signature-target="styleIdField" value="">
                    </div>

                    {# Signature Consent #}
                    <label class="flex items-start gap-3 cursor-pointer mb-6">
                        <input type="checkbox" name="signature_consent" value="1" x-model="signatureConsent"
                               class="h-4 w-4 mt-1 text-accent focus:ring-accent border-gray-300 rounded">
                        <span class="text-sm text-gray-700">Potvrzuji, že souhlasím s použitím elektronického podpisu pro uzavření smlouvy.</span>
                    </label>

                    {# Submit #}
                    <button type="submit"
                            class="btn btn-primary w-full"
                            :disabled="!acceptContract || !acceptVop || !acceptGdpr || !signed || !signatureConsent || signingPlace.trim() === ''">
                        Podepsat smlouvu
                    </button>
                </form>
            </div>
        </div>

        {# Signature Modal #}
        <div x-show="modalOpen"
             x-cloak
             class="fixed inset-0 z-50 overflow-y-auto"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0">
            <div class="flex items-center justify-center min-h-screen px-4">
                <div class="fixed inset-0 bg-black/70" @click="modalOpen = false"></div>
                <div class="relative bg-white rounded-xl shadow-xl max-w-lg w-full p-6 z-10" @click.stop>
                    <div class="flex items-center justify-between mb-4">
                        <h3 class="text-lg font-semibold text-gray-900">Elektronický podpis</h3>
                        <button type="button" @click="modalOpen = false" class="text-gray-400 hover:text-gray-600">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                    <div class="border-b border-gray-200 mb-4">
                        <nav class="-mb-px flex space-x-4">
                            <button type="button" data-signature-target="drawTab" data-action="click->signature#switchToDraw"
                                    class="py-2 px-1 border-b-2 border-accent text-accent text-sm font-medium">Nakreslit</button>
                            <button type="button" data-signature-target="typedTab" data-action="click->signature#switchToTyped"
                                    class="py-2 px-1 border-b-2 border-transparent text-gray-500 hover:text-gray-700 text-sm font-medium">Napsat</button>
                        </nav>
                    </div>
                    <div data-signature-target="drawPanel">
                        <p class="text-xs text-gray-500 mb-2">Nakreslete svůj podpis do pole níže:</p>
                        <canvas data-signature-target="drawCanvas" class="w-full h-52 border border-gray-300 rounded-lg cursor-crosshair bg-white"></canvas>
                    </div>
                    <div data-signature-target="typedPanel" class="hidden">
                        <p class="text-xs text-gray-500 mb-2">Vyberte styl podpisu:</p>
                        <div class="grid grid-cols-2 gap-2 mb-3">
                            <button type="button" data-action="click->signature#selectStyle" data-style-id="dancing-script" data-style-btn
                                    class="p-3 border border-gray-200 rounded-lg text-center hover:border-accent ring-2 ring-accent"
                                    style="font-family: 'Dancing Script', cursive; font-size: 20px;">{{ customerFullName }}</button>
                            <button type="button" data-action="click->signature#selectStyle" data-style-id="great-vibes" data-style-btn
                                    class="p-3 border border-gray-200 rounded-lg text-center hover:border-accent"
                                    style="font-family: 'Great Vibes', cursive; font-size: 20px;">{{ customerFullName }}</button>
                            <button type="button" data-action="click->signature#selectStyle" data-style-id="satisfy" data-style-btn
                                    class="p-3 border border-gray-200 rounded-lg text-center hover:border-accent"
                                    style="font-family: 'Satisfy', cursive; font-size: 20px;">{{ customerFullName }}</button>
                            <button type="button" data-action="click->signature#selectStyle" data-style-id="pacifico" data-style-btn
                                    class="p-3 border border-gray-200 rounded-lg text-center hover:border-accent"
                                    style="font-family: 'Pacifico', cursive; font-size: 20px;">{{ customerFullName }}</button>
                        </div>
                        <canvas data-signature-target="typedCanvas" class="w-full h-36 border border-gray-300 rounded-lg bg-white"></canvas>
                    </div>
                    <div class="flex justify-between mt-4">
                        <button type="button" data-action="click->signature#clear" class="btn btn-secondary btn-sm">Vymazat</button>
                        <button type="button" data-signature-target="confirmBtn" data-action="click->signature#confirm" class="btn btn-primary btn-sm">Potvrdit podpis</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
