{% extends app.user ? 'portal/layout.html.twig' : 'user/layout.html.twig' %}

{% set customerFullName = (formData.firstName ~ ' ' ~ formData.lastName)|trim %}
{% set signatureStyles = [
    { id: 'dancing-script', family: 'Dancing Script' },
    { id: 'great-vibes', family: 'Great Vibes' },
    { id: 'satisfy', family: 'Satisfy' },
    { id: 'pacifico', family: 'Pacifico' },
] %}

{% block title %}Přijetí smlouvy - Fajnesklady.cz{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@700&family=Great+Vibes&family=Pacifico&family=Satisfy&display=swap" rel="stylesheet">
{% endblock %}

{% block content %}
    {# Breadcrumb #}
    <nav class="mb-6">
        <ol class="flex items-center space-x-2 text-sm text-gray-600">
            <li><a href="{{ app.user ? path('portal_browse_places') : path('app_home') }}" class="hover:text-accent">{{ app.user ? 'Pobočky' : 'Domů' }}</a></li>
            <li><span class="mx-2">/</span></li>
            <li><a href="{{ app.user ? path('portal_browse_place_detail', {id: place.id}) : path('public_place_detail', {id: place.id}) }}" class="hover:text-accent">{{ place.name }}</a></li>
            <li><span class="mx-2">/</span></li>
            <li class="text-gray-900 font-medium">Přijetí smlouvy</li>
        </ol>
    </nav>

    {# acceptRecurring defaults to true when there's no recurring payment so the
       submit gating expression stays a single conjunction; the dedicated
       checkbox flips it to false on render only when isRecurring.

       Submitted values flow back through `submitted` so a server-side
       validation re-render keeps the user's typed place and ticked
       checkboxes — they shouldn't have to refill the form. #}
    {# json_encode is HTML-attribute-escaped so the JSON's double quotes
       don't collide with the surrounding x-data="…" double quotes — that
       collision silently breaks the Alpine state and leaves the submit
       button permanently disabled. #}
    <div class="max-w-4xl mx-auto"
         x-data="{
            signed: false,
            signingPlace: {{ (submitted.signingPlace ?? '')|json_encode|e('html_attr') }},
            acceptAll: {{ (submitted.acceptAll ?? false) ? 'true' : 'false' }},
            acceptRecurring: {{ (isRecurring and formData.billingMode.value == 'auto_recurring') ? ((submitted.acceptRecurring ?? false) ? 'true' : 'false') : 'true' }}
         }"
         @signature:signed.window="signed = true"
         @signature:cleared.window="signed = false">
      <div data-controller="signature"
           data-signature-customer-name-value="{{ customerFullName }}">
        <div class="card">
            <div class="card-body">
                <h1 class="text-2xl font-bold text-gray-900 mb-6">Rekapitulace a přijetí smlouvy</h1>

                <p class="text-sm text-gray-600 mb-6">
                    Zkontrolujte prosím údaje objednávky. Pokud chcete něco změnit, vraťte se zpět na formulář.
                </p>

                {# Order Summary — text rows + compact photo strips below. #}
                <div class="bg-gray-50 rounded-lg p-4 mb-6">
                    <h2 class="font-semibold text-gray-900 mb-3">Shrnutí objednávky</h2>

                    <div class="space-y-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-gray-600">Pobočka</span>
                            <span class="font-medium">{{ place.name }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Adresa</span>
                            <span class="font-medium">{% include 'components/place_address.html.twig' with {place: place, inline: true} only %}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Skladová jednotka</span>
                            <span class="font-medium">{{ storageType.name }} - {{ storage.number }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Rozměry</span>
                            <span class="font-medium">{{ storageType.dimensionsInMeters }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Období pronájmu</span>
                            <span class="font-medium">
                                {% if formData.endDate %}
                                    {{ formData.startDate|date('d.m.Y') }} - {{ formData.endDate|date('d.m.Y') }}
                                {% else %}
                                    Na dobu neurčitou, od {{ formData.startDate|date('d.m.Y') }}
                                {% endif %}
                            </span>
                        </div>
                        {# Cena. Customer never sees a lifetime sum across recurring charges
                           (spec 021); the partial renders "Měsíční platba: X Kč / měsíc" for
                           any recurring schedule and "Celková cena: X Kč" for one-shot.
                           The "Parametry opakované platby" block further down still spells
                           out cadence, max amount and stop conditions for compliance. #}
                        <div class="flex justify-between">
                            {% include '_price_label.html.twig' with {
                                isRecurring: paymentSchedule.isRecurring,
                                priceCzk: paymentSchedule.firstPayment.amountInCzk,
                                labelClass: 'text-gray-600',
                                valueClass: 'font-medium text-accent',
                            } only %}
                        </div>
                        <p class="text-xs text-gray-500 text-right">vč. DPH</p>
                    </div>

                    {% if storage.hasPhotos %}
                        <div class="mt-4">
                            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Fotografie skladu č. {{ storage.number }}</h3>
                            {% include 'partials/photo_gallery.html.twig' with {
                                photos: storage.photos,
                                gallery_key: 'recap-storage-' ~ storage.id,
                                caption: 'Sklad č. ' ~ storage.number,
                                thumb_max_h: 'max-h-20',
                                layout: 'strip',
                                alt: 'Sklad ' ~ storage.number,
                            } only %}
                        </div>
                    {% endif %}
                    {% if storageType.hasPhotos %}
                        <div class="mt-3">
                            <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Fotografie typu — {{ storageType.name }}</h3>
                            {% include 'partials/photo_gallery.html.twig' with {
                                photos: storageType.photos,
                                gallery_key: 'recap-type-' ~ storageType.id,
                                caption: 'Typ skladu: ' ~ storageType.name,
                                thumb_max_h: 'max-h-20',
                                layout: 'strip',
                                alt: storageType.name,
                            } only %}
                        </div>
                    {% endif %}
                </div>

                {# Own-padlock reminder — insurance coverage depends on it, so
                   surface it before the customer signs the contract. #}
                <div class="mb-6">
                    {% include 'components/lock_disclaimer.html.twig' %}
                </div>

                {# Customer Info #}
                <div class="bg-blue-50 rounded-lg p-4 mb-6">
                    <h2 class="font-semibold text-gray-900 mb-3">Vaše údaje</h2>

                    <div class="space-y-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-gray-600">Jméno</span>
                            <span class="font-medium">{{ customerFullName }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">E-mail</span>
                            <span class="font-medium">{{ formData.email }}</span>
                        </div>
                        {% if formData.phone %}
                            <div class="flex justify-between">
                                <span class="text-gray-600">Telefon</span>
                                <span class="font-medium">{{ formData.phone }}</span>
                            </div>
                        {% endif %}
                        {% if formData.companyName %}
                            <div class="flex justify-between">
                                <span class="text-gray-600">Společnost</span>
                                <span class="font-medium">{{ formData.companyName }}</span>
                            </div>
                            {% if formData.companyId %}
                                <div class="flex justify-between">
                                    <span class="text-gray-600">IČO</span>
                                    <span class="font-medium">{{ formData.companyId }}</span>
                                </div>
                            {% endif %}
                        {% endif %}
                    </div>

                    <p class="text-xs text-gray-500 mt-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Na e-mail <strong>{{ formData.email }}</strong> vám budou zasílány informace o objednávce a přístupové údaje.
                    </p>
                </div>

                {# Contract Terms - matches the real Smlouva.docx; flows in the page (no inner scroller). #}
                <div class="border border-gray-200 rounded-lg p-4 mb-6 bg-white">
                    <h3 class="font-semibold text-gray-900 mb-3">Smlouva o nájmu</h3>

                    <div class="text-xs text-gray-600 [&>h4]:mt-4 [&>h4]:mb-1 [&>h4]:text-sm [&>h4]:font-bold [&>h4]:text-gray-900 [&>p]:my-1 [&>ul]:my-1 [&>ul]:list-disc [&>ul]:pl-5">
                        <h4>Pronajímatel:</h4>
                        <p>Obchodní firma: Mekmann s.r.o.<br>
                           IČO: 11678631<br>
                           DIČ: CZ11678631<br>
                           Sídlem: Dvořákova 780, Frýdlant, 739 11 Frýdlant nad Ostravicí<br>
                           Zapsána: Krajský soud v Ostravě, C 86521</p>

                        <h4>Nájemce:</h4>
                        {% if formData.invoiceToCompany and formData.companyName %}
                            <p>Společnost: {{ formData.companyName }}, zastoupena {{ customerFullName }}<br>
                               IČO: {{ formData.companyId }}<br>
                               {% if formData.companyVatId %}DIČ: {{ formData.companyVatId }}<br>{% endif %}
                               Sídlem: {{ formData.billingStreet }}, {{ formData.billingPostalCode }} {{ formData.billingCity }}<br>
                               Email: {{ formData.email }}</p>
                        {% else %}
                            <p>Jméno: {{ customerFullName }}<br>
                               {% if formData.birthDate %}Nar. {{ formData.birthDate|date('d.m.Y') }}<br>{% endif %}
                               Bytem: {{ formData.billingStreet }}, {{ formData.billingPostalCode }} {{ formData.billingCity }}<br>
                               Email: {{ formData.email }}</p>
                        {% endif %}

                        <h4>I. Předmět smlouvy</h4>
                        <p>Pronajímatel výslovně prohlašuje, že je výlučným vlastníkem níže specifikované movité věci:</p>
                        <p><strong>{{ storageType.name }} č. {{ storage.number }} ({{ storageType.innerWidth }} × {{ storageType.innerHeight }} × {{ storageType.innerLength }} cm)</strong>, a to v počtu 1 Ks (dále jen „Předmět nájmu")</p>
                        <p>Pronajímatel tímto přenechává Nájemci Předmět nájmu k dočasnému užívání za úplatu, a to za podmínek dále stanovených zde v této Smlouvě nebo ve všeobecných obchodních podmínkách Pronajímatele (dále jen „VOP"), které tvoří nedílnou součást této Smlouvy.</p>

                        <h4>II. Doba nájmu a předání</h4>
                        <p>
                            {% if formData.endDate %}
                                Nájem se sjednává na dobu určitou, a to od {{ formData.startDate|date('d.m.Y') }} do {{ formData.endDate|date('d.m.Y') }}
                            {% else %}
                                Nájem se sjednává na dobu neurčitou, a to od {{ formData.startDate|date('d.m.Y') }}
                            {% endif %}
                        </p>
                        <p>Pokud nájem má začít okamžitě, respektive v době před uplynutím 14 dní, ve kterých může Nájemce, který je spotřebitelem od Smlouvy odstoupit, pak tímto Nájemce výslovně žádá, aby bylo započato s plněním. Současně prohlašuje, že rozumí a chápe, že ztrácí právo na odstoupení od Smlouvy.</p>
                        <p>Nájemce je povinen nejpozději ke dni skončení nájmu zaslat fotografii zachycující stav Předmětu nájmu, který musí být vyklizený a čistý. Do okamžiku zaslání fotografie se má za to, že Předmět nájmu není řádně předaný.</p>

                        <h4>III. Cena nájmu a splatnost</h4>
                        <p>Smluvní strany se dohodly, že cena za nájem Předmět nájmu je určena Ceníkem, který je nedílnou součástí této Smlouvy (dále jen „cena nájmu" nebo „nájemné").</p>

                        <h4>IV. Smluvní sankce</h4>
                        <p>Pokud Nájemce Předmět nájmu vrátí znečištěný, je Pronajímatel oprávněn požadovat po Nájemci smluvní pokutu ve výši 6 000,- Kč.</p>
                        <p>Pokud Nájemce Předmět nájmu nevrátí nejpozději ke dni skončení nájmu, je Pronajímatel oprávněn požadovat po Nájemci smluvní pokutu ve výši 2 000,- Kč denně.</p>
                        <p>V případě prodlení Nájemce s úhradou jakéhokoliv peněžitého závazku, je Nájemce povinen uhradit Pronajímateli smluvní pokutu ve výši 0,25 % denně dlužné částky za každý, byť jen započatý, den prodlení, a to až do úplného zaplacení, minimálně však částku 250,- Kč denně.</p>

                        <h4>V. Jistota</h4>
                        <p>Po Nájemci není požadována žádná jistota.</p>
                        <p>Pronajímatel je oprávněn jistotu jednostranně započítat oproti všem finančním nárokům vůči Nájemci vyplývajícím ze Smlouvy.</p>

                        <h4>VI. Závěrečná ustanovení</h4>
                        <p>Smlouva je vyhotovena ve 2 stejnopisech, každý s platností originálu, z nichž každá smluvní strana obdrží jedno vyhotovení.</p>
                        <p>Nedílnou součástí Smlouvy jsou i následující přílohy:</p>
                        <ul>
                            <li>VOP</li>
                            <li>Spotřebitelská poučení a formuláře</li>
                            <li>Provozní řád areálu</li>
                            <li>Ceník</li>
                        </ul>
                        <p>Smluvní strany prohlašují, že Smlouva byla sepsána na základě jejich svobodné, shodné a vážné vůle, nebyla sepsána v tísni za nápadně nevýhodných podmínek, že si smlouvu před podpisem přečetly, že byla sepsána podle pravdivých údajů a že souhlasí s jejím obsahem.</p>
                    </div>
                </div>

                {# Signing Date & Place #}
                <div class="border border-gray-200 rounded-lg p-4 mb-6">
                    <h3 class="font-semibold text-gray-900 mb-3">Datum a místo podpisu</h3>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Datum podpisu</label>
                            <div class="px-3 py-2 bg-gray-100 border border-gray-200 rounded-md text-sm text-gray-900">
                                {{ now|date('d.m.Y') }}
                            </div>
                        </div>
                        <div>
                            <label for="signing_place" class="form-label-required block text-sm font-medium text-gray-700 mb-1">Místo podpisu</label>
                            <input type="text"
                                   id="signing_place"
                                   x-model="signingPlace"
                                   placeholder="např. Praha"
                                   required
                                   class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:ring-accent focus:border-accent">
                        </div>
                    </div>
                </div>

                {# Inline signature — manual draw on the left, ready-made styled
                   variants on the right. Each is its own radio so picking a
                   typed style implies signing method = "typed" with that style. #}
                <div class="border border-gray-200 rounded-lg p-4 mb-6"
                     x-data="{ choice: '' }">
                    <h3 class="font-semibold text-gray-900 mb-3">Způsob podpisu</h3>
                    <p x-show="!choice" class="text-xs text-gray-500 mb-3">Vyberte jednu z níže uvedených variant — buď nakreslete vlastní podpis, nebo zvolte hotový styl.</p>

                    <div class="grid lg:grid-cols-2 gap-4">
                        {# Left: manual draw — no wrapper border; the canvas
                           itself gets a black border when this choice is active.
                           "Vymazat" sits right under the canvas where it belongs. #}
                        <label class="block cursor-pointer">
                            <div class="flex items-center gap-3 mb-3">
                                <input type="radio" name="signature_choice" value="draw" x-model="choice"
                                       data-action="change->signature#selectDraw"
                                       class="h-4 w-4 text-accent focus:ring-accent border-gray-300">
                                <span class="text-sm font-medium">Nakreslit podpis</span>
                            </div>
                            <div class="transition-opacity"
                                 :class="choice === 'draw' ? 'opacity-100' : 'opacity-50 pointer-events-none'">
                                <canvas data-signature-target="drawCanvas"
                                        class="w-full h-40 border-2 rounded-lg cursor-crosshair bg-white transition-colors"
                                        :class="choice === 'draw' ? 'border-black' : 'border-gray-300'"></canvas>
                                <div class="mt-2 flex justify-end">
                                    <button type="button"
                                            data-action="click->signature#clear"
                                            data-signature-mode-param="draw"
                                            class="btn btn-secondary btn-sm">
                                        Vymazat
                                    </button>
                                </div>
                            </div>
                        </label>

                        {# Right: ready-made styles, one radio each #}
                        <div class="space-y-2">
                            {% for style in signatureStyles %}
                                <label class="flex items-center gap-3 p-3 border rounded-lg cursor-pointer transition-colors"
                                       :class="choice === '{{ style.id }}' ? 'border-accent bg-accent/5' : 'border-gray-200 hover:border-gray-300'">
                                    <input type="radio" name="signature_choice" value="{{ style.id }}" x-model="choice"
                                           data-action="change->signature#selectStyle"
                                           data-style-id="{{ style.id }}"
                                           class="h-4 w-4 text-accent focus:ring-accent border-gray-300 shrink-0">
                                    <span class="flex-1 text-center truncate" style="font-family: '{{ style.family }}', cursive; font-size: 24px;">{{ customerFullName }}</span>
                                </label>
                            {% endfor %}
                        </div>
                    </div>

                    {# Off-screen canvas used to render+capture the typed signature.
                       Keeps non-zero dimensions so SignaturePad and getBoundingClientRect work. #}
                    <canvas data-signature-target="typedCanvas"
                            width="600" height="160"
                            style="position: absolute; left: -9999px; top: 0; width: 600px; height: 160px;"></canvas>

                    <div x-show="signed" x-cloak class="mt-4 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <span class="text-sm text-green-700">Podpis přidán</span>
                    </div>
                </div>

                {# Accept Form #}
                <form method="post">
                    <input type="hidden" name="signature_data" data-signature-target="dataField" value="">
                    <input type="hidden" name="signing_method" data-signature-target="methodField" value="">
                    <input type="hidden" name="typed_name" data-signature-target="typedNameField" value="">
                    <input type="hidden" name="style_id" data-signature-target="styleIdField" value="">
                    <input type="hidden" name="signing_place" :value="signingPlace">

                    {# Single consolidated consent. Per-consent fields are mirrored
                       as hidden inputs that submit "1" only when the master
                       checkbox is on, so the controller's per-field validation
                       needs no change. #}
                    <div class="border border-gray-200 rounded-lg p-4 mb-6">
                        <label class="flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" x-model="acceptAll"
                                   class="mt-1 h-5 w-5 text-accent border-gray-300 rounded focus:ring-accent shrink-0">
                            <span class="text-sm text-gray-800">
                                <strong>Souhlasím se všemi níže uvedenými podmínkami a dokumenty</strong>
                                a potvrzuji, že jsem si je přečetl/a:
                            </span>
                        </label>

                        {# Mirror the lead-in's flex layout (w-5 + gap-3) so the
                           bullet text lines up with the lead-in column exactly. #}
                        <ul class="mt-3 list-none text-xs text-gray-600 space-y-1">
                            <li class="flex items-start gap-3"><span class="w-5 shrink-0 text-center text-gray-400" aria-hidden="true">•</span><span>smluvními podmínkami uvedenými výše v této smlouvě;</span></li>
                            <li class="flex items-start gap-3"><span class="w-5 shrink-0 text-center text-gray-400" aria-hidden="true">•</span><span><button type="button" @click.prevent="$store.modal.show('vop')" class="text-accent hover:underline">všeobecnými obchodními podmínkami</button>;</span></li>
                            {% if place.operatingRulesPath %}
                                <li class="flex items-start gap-3"><span class="w-5 shrink-0 text-center text-gray-400" aria-hidden="true">•</span><span><a href="{{ upload_url(place.operatingRulesPath) }}" target="_blank" class="text-accent hover:underline">provozním řádem pobočky</a>;</span></li>
                            {% endif %}
                            <li class="flex items-start gap-3"><span class="w-5 shrink-0 text-center text-gray-400" aria-hidden="true">•</span><span><button type="button" @click.prevent="$store.modal.show('consumer')" class="text-accent hover:underline">poučením o právech spotřebitele</button>;</span></li>
                            <li class="flex items-start gap-3"><span class="w-5 shrink-0 text-center text-gray-400" aria-hidden="true">•</span><span><button type="button" @click.prevent="$store.modal.show('gdpr')" class="text-accent hover:underline">zpracováním osobních údajů</button> pro obchodní účely;</span></li>
                            <li class="flex items-start gap-3"><span class="w-5 shrink-0 text-center text-gray-400" aria-hidden="true">•</span><span>použitím elektronického podpisu jako platného a závazného právního úkonu;</span></li>
                            {# Recurring-payment consent intentionally NOT listed here — it lives in its own dedicated checkbox above (GoPay rule). #}
                            {% if requiresEarlyStartWaiver %}
                                <li class="flex items-start gap-3"><span class="w-5 shrink-0 text-center text-gray-400" aria-hidden="true">•</span><span>výslovným započetím plnění před uplynutím 14denní lhůty pro odstoupení od smlouvy a beru na vědomí, že tím ztrácím právo odstoupit od smlouvy.</span></li>
                            {% endif %}
                        </ul>

                        <input type="hidden" name="accept_contract" value="1" :disabled="!acceptAll">
                        <input type="hidden" name="accept_vop" value="1" :disabled="!acceptAll">
                        <input type="hidden" name="accept_consumer_notice" value="1" :disabled="!acceptAll">
                        <input type="hidden" name="accept_gdpr" value="1" :disabled="!acceptAll">
                        <input type="hidden" name="signature_consent" value="1" :disabled="!acceptAll">
                        {% if place.operatingRulesPath %}
                            <input type="hidden" name="accept_operating_rules" value="1" :disabled="!acceptAll">
                        {% endif %}
                        {# accept_recurring_payments hidden input lives inside the dedicated recurring card below. #}
                        {% if requiresEarlyStartWaiver %}
                            <input type="hidden" name="accept_early_start_waiver" value="1" :disabled="!acceptAll">
                        {% endif %}
                    </div>

                    {# MANUAL_RECURRING information card. Replaces the AUTO recurring-
                       payment disclosure + consent block when the customer chose to be
                       reminded by e-mail before each cycle (spec 036). No "Parametry
                       opakované platby" card and no dedicated GoPay-consent checkbox
                       because there is no token stored. The master T&C consent above
                       still applies to each one-time payment. #}
                    {% if formData.billingMode.value == 'manual_recurring' %}
                    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
                        <h2 class="font-semibold text-gray-900 mb-2 flex items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-blue-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            Ručně schvalovaná platba
                        </h2>
                        <p class="text-sm text-gray-700">
                            První platbu zaplatíte hned po podpisu. Před každou další platbou Vám 7 dní předem pošleme e-mail s odkazem k zaplacení.
                            <strong>Žádné údaje o platební kartě se neukládají.</strong>
                        </p>
                    </div>
                    {% endif %}

                    {# Recurring-payment block — parameters + dedicated consent in one
                       visually unified card. Placed here, just above the submit
                       button, so the dedicated checkbox sits adjacent to the master
                       T&C checkbox and the price/cadence is visible right above the
                       payment button (Visa/Mastercard requirement). GoPay rule:
                       parameters MUST sit on a visible place SEPARATE from the
                       general T&C, and consent for recurring payments MUST be a
                       dedicated checkbox (not folded into the master "I agree").
                       See .claude/COMPLIANCE.md.

                       Shown only when billingMode is AUTO_RECURRING — for MANUAL
                       the information card above takes its place (no token, no
                       silent debit, no GoPay-managed parameters to disclose). #}
                    {% if isRecurring and formData.billingMode.value == 'auto_recurring' %}
                    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
                        <h2 class="font-semibold text-gray-900 mb-3 flex items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                            </svg>
                            Parametry opakované platby
                        </h2>

                        {# Parameters list per GoPay rule "Jaké informace musím prezentovat
                           pro opakované platby" — every row is required and must be
                           visible OUTSIDE of obchodní podmínky. Order and labels match
                           the GoPay reviewer checklist verbatim; do not reword without
                           re-reading the source. #}
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between gap-3">
                                <span class="text-gray-600 shrink-0">Účel platby</span>
                                <span class="font-medium text-right">Pronájem skladovací jednotky</span>
                            </div>
                            <div class="flex justify-between gap-3">
                                <span class="text-gray-600 shrink-0">Maximální částka opakované platby</span>
                                <span class="font-medium text-right">{{ recurringPaymentLegalMaxInCzk|number_format(0, ',', ' ') }} Kč</span>
                            </div>
                            <div class="flex justify-between gap-3">
                                <span class="text-gray-600 shrink-0">Částka jednotlivé platby</span>
                                <span class="font-medium text-right">
                                    <strong>Fixní</strong>, {{ paymentSchedule.monthlyAmountInCzk|number_format(0, ',', ' ') }} Kč / měsíc <span class="text-xs text-gray-500 font-normal">vč. DPH</span>
                                    {% if not paymentSchedule.isOpenEnded %}
                                        <br><span class="text-xs text-gray-500 font-normal">Poslední doplatek bude prorátován podle počtu zbývajících dní (jen u smluv na dobu určitou).</span>
                                    {% endif %}
                                </span>
                            </div>
                            <div class="flex justify-between gap-3">
                                <span class="text-gray-600 shrink-0">Frekvence a den strhávání</span>
                                <span class="font-medium text-right">
                                    <strong>Fixní</strong>, měsíční — vždy ke stejnému dni v měsíci jako první platba<br>
                                    <span class="text-xs text-gray-500 font-normal">Pokud připadne na nepracovní den, strhne se následující pracovní den.</span>
                                </span>
                            </div>
                            <div class="flex justify-between gap-3">
                                <span class="text-gray-600 shrink-0">Doba trvání</span>
                                <span class="font-medium text-right">
                                    {% if paymentSchedule.isOpenEnded %}
                                        Po celou dobu trvání nájmu / do odvolání souhlasu zákazníkem
                                    {% else %}
                                        {{ paymentSchedule.entryCount }} platby do {{ formData.endDate|date('d.m.Y') }}
                                    {% endif %}
                                </span>
                            </div>
                            <div class="flex justify-between gap-3">
                                <span class="text-gray-600 shrink-0">Forma komunikace pro změnu nastavení</span>
                                <span class="font-medium text-right"><a href="mailto:simek@fajnesklady.cz" class="text-accent hover:underline">simek@fajnesklady.cz</a></span>
                            </div>
                            <div class="flex justify-between gap-3">
                                <span class="text-gray-600 shrink-0">Zrušení a storno opakované platby</span>
                                <span class="font-medium text-right">
                                    <a href="mailto:simek@fajnesklady.cz" class="text-accent hover:underline">simek@fajnesklady.cz</a> — kdykoli, bez sankce<br>
                                    <span class="text-xs text-gray-500 font-normal">Podrobně viz Podmínky opakovaných plateb, čl. VI.</span>
                                </span>
                            </div>
                        </div>

                        <p class="text-xs text-gray-500 mt-3">
                            Úplné znění naleznete v <button type="button" @click.prevent="$store.modal.show('recurring')" class="text-accent hover:underline font-medium">Podmínkách opakovaných plateb</button>.
                            Souhlas potvrzujete zaškrtnutím pole níže — ten je dle pravidel GoPay vyžadován samostatně.
                        </p>

                        {# Dedicated consent checkbox — REQUIRED to be separate from
                           the master T&C consent above (GoPay rule + Podmínky čl. I). #}
                        <label class="mt-4 pt-3 border-t border-amber-200 flex items-start gap-3 cursor-pointer">
                            <input type="checkbox" x-model="acceptRecurring"
                                   class="mt-0.5 h-5 w-5 text-accent border-amber-300 rounded focus:ring-accent shrink-0">
                            <span class="text-sm text-gray-800">
                                <strong>Souhlasím s opakovanou platbou</strong> v parametrech uvedených výše a s uložením platebních údajů na bráně GoPay.
                            </span>
                        </label>
                        <input type="hidden" name="accept_recurring_payments" value="1" :disabled="!acceptRecurring">

                        {# PCI-DSS Level 1 disclosure — GoPay rule requires this be
                           visible AT the consent point, not just buried in the linked
                           Podmínky modal. Keep adjacent to the checkbox. #}
                        <p class="mt-3 text-xs text-gray-500">
                            Společnost <strong>GOPAY s.r.o.</strong> nakládá s údaji Vaší platební karty podle mezinárodního bezpečnostního standardu <strong>PCI-DSS Level 1</strong> — nejvyšší úroveň datové bezpečnosti ve finančním sektoru. Čísla karet ani CVV s námi GoPay nesdílí a Pronajímatel k nim nemá přístup.
                        </p>
                    </div>
                    {% endif %}

                    {# Payment card logos + SSL/3DS notice (GoPay compliance). #}
                    <div class="flex flex-col items-center gap-2 py-2">
                        {% include 'components/payment_logos.html.twig' %}
                        <p class="text-xs text-gray-500 flex items-center gap-1">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                            </svg>
                            Vaše platba je zabezpečena 256-bit SSL/TLS šifrováním a 3D Secure 2.0.
                        </p>
                    </div>

                    {# Pre-contract binding-payment disclosure (§ 1826a odst. 2 OZ). #}
                    <p class="text-xs text-gray-600 mt-3 mb-2">
                        Kliknutím na tlačítko <strong>OBJEDNÁVÁM a zaplatím</strong> odesíláte závaznou objednávku, která zavazuje k zaplacení sjednané ceny.
                    </p>

                    <div class="flex items-center justify-between pt-2">
                        <a href="{{ path('public_order_create', {placeId: place.id, storageTypeId: storageType.id, storageId: storage.id}) }}" class="inline-flex items-center text-gray-600 hover:text-gray-900">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                            </svg>
                            Zpět na formulář
                        </a>
                        <button type="submit"
                                class="btn btn-primary btn-lg"
                                :disabled="!(signed && acceptAll && acceptRecurring && signingPlace.trim())"
                                :class="{'opacity-50 cursor-not-allowed': !(signed && acceptAll && acceptRecurring && signingPlace.trim())}">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                            </svg>
                            OBJEDNÁVÁM a zaplatím
                        </button>
                    </div>
                </form>
            </div>
        </div>
      </div>{# /signature controller root #}

        {# Term modals — driven by the global Alpine $store.modal.open. #}
        {% embed 'public/_term_modal.html.twig' with { id: 'vop', title: 'Všeobecné obchodní podmínky' } %}
            {% block body %}{% include 'public/_terms_and_conditions_content.html.twig' %}{% endblock %}
        {% endembed %}
        {% embed 'public/_term_modal.html.twig' with { id: 'consumer', title: 'Poučení o právech Spotřebitele' } %}
            {% block body %}{% include 'public/_consumer_notice_content.html.twig' %}{% endblock %}
        {% endembed %}
        {% embed 'public/_term_modal.html.twig' with { id: 'gdpr', title: 'Ochrana osobních údajů' } %}
            {% block body %}{% include 'public/_privacy_policy_content.html.twig' %}{% endblock %}
        {% endembed %}
        {% if isRecurring %}
            {% embed 'public/_term_modal.html.twig' with { id: 'recurring', title: 'Podmínky opakovaných plateb' } %}
                {% block body %}{% include 'public/_recurring_payments_terms_content.html.twig' %}{% endblock %}
            {% endembed %}
        {% endif %}
    </div>
{% endblock %}
