{% extends app.user ? 'portal/layout.html.twig' : 'user/layout.html.twig' %}

{% block title %}Úhrada dluhu - Fajnesklady.cz{% endblock %}

{% macro bank_transfer_block(bankAccount, variableSymbol, debtAmountCzk, remainingDebtCzk, qrCodeDataUri) %}
    <div class="border border-gray-200 rounded-lg p-4 mb-6">
        <h2 class="font-semibold text-gray-900 mb-3">Zaplatit bankovním převodem</h2>

        {% if remainingDebtCzk is not null %}
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 mb-4">
                <p class="text-sm text-amber-800">
                    Část dluhu už evidujeme jako uhrazenou. Zbývá doplatit
                    <strong>{{ remainingDebtCzk|number_format(0, ',', ' ') }} Kč</strong>.
                </p>
            </div>
        {% endif %}

        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4">
            <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="text-gray-600">Číslo účtu</span>
                    <span class="font-mono font-bold text-gray-900">{{ bankAccount }}</span>
                </div>
                {% if variableSymbol %}
                    <div class="flex justify-between">
                        <span class="text-gray-600">Variabilní symbol</span>
                        <span class="font-mono font-bold text-gray-900">{{ variableSymbol }}</span>
                    </div>
                {% endif %}
                <div class="flex justify-between">
                    <span class="text-gray-600">Částka</span>
                    <span class="font-bold text-gray-900">
                        {{ (remainingDebtCzk ?? debtAmountCzk)|number_format(0, ',', ' ') }} Kč
                    </span>
                </div>
            </div>
        </div>

        {% if qrCodeDataUri %}
            <div class="text-center mb-4">
                <p class="text-sm text-gray-600 mb-2">QR kód pro platbu</p>
                <img src="{{ qrCodeDataUri }}" alt="QR platba" class="mx-auto" style="width: 200px; height: 200px;">
            </div>
        {% endif %}

        <p class="text-sm text-gray-600">
            Po přijetí platby na náš účet bude dluh automaticky označen jako uhrazený
            a budete moci pokračovat k platbě prvního nájemného.
        </p>
    </div>
{% endmacro %}

{% macro gopay_block(debtAmountCzk, remainingDebtCzk) %}
    <div class="border border-gray-200 rounded-lg p-4 mb-6">
        <h2 class="font-semibold text-gray-900 mb-3">Zaplatit kartou online</h2>

        <div class="bg-accent/5 border border-accent/20 rounded-lg p-4 mb-4">
            <div class="flex items-start">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-accent mt-0.5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
                <div>
                    <p class="text-sm text-gray-700">
                        <strong>Bezpečná platba</strong><br>
                        Platba je zpracována platební bránou GoPay. Vaše údaje jsou zabezpečeny 256-bit SSL/TLS šifrováním a 3D Secure 2.0.
                    </p>
                    <div class="mt-3">
                        {% include 'components/payment_logos.html.twig' %}
                    </div>
                </div>
            </div>
        </div>

        {# GoPay Inline Gateway Container #}
        <div id="gopay-gateway-container" class="hidden mb-6">
            <div class="border border-gray-200 rounded-lg overflow-hidden">
                <div id="gopay-inline-form"></div>
            </div>
        </div>

        {# Error Message Container #}
        <div id="payment-error" class="hidden bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
            <div class="flex items-start">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-600 mt-0.5 mr-2 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="text-sm text-red-800" id="payment-error-text"></p>
            </div>
        </div>

        {# Loading State #}
        <div id="payment-loading" class="hidden text-center py-6 mb-6">
            <div class="inline-flex items-center">
                <svg class="animate-spin h-5 w-5 text-accent mr-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span class="text-gray-600">Připravuji platební bránu...</span>
            </div>
        </div>

        {# Pay button #}
        <div id="payment-actions">
            <button type="button" id="pay-button" class="btn btn-primary btn-lg w-full bg-red-600 hover:bg-red-700">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                </svg>
                Zaplatit dluh {{ (remainingDebtCzk ?? debtAmountCzk)|number_format(0, ',', ' ') }} Kč
            </button>
        </div>
    </div>
{% endmacro %}

{% block content %}
    {% import _self as blocks %}

    <div class="max-w-2xl mx-auto">
        <div class="card">
            <div class="card-body">
                <h1 class="text-2xl font-bold text-gray-900 mb-2">Úhrada dluhu z předchozí smlouvy</h1>
                <p class="text-gray-600 mb-6">
                    Před zahájením nového pronájmu je třeba uhradit dluh z předchozí smlouvy.
                </p>

                {# Debt amount #}
                <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
                    <div class="flex justify-between items-center">
                        <span class="font-semibold text-red-800">Dluh k úhradě</span>
                        <span class="text-2xl font-bold text-red-700">{{ debtAmountCzk|number_format(0, ',', ' ') }} Kč</span>
                    </div>
                </div>

                {# Order Summary #}
                <div class="bg-gray-50 rounded-lg p-4 mb-6">
                    <h2 class="font-semibold text-gray-900 mb-3">Objednávka</h2>
                    <div class="space-y-2 text-sm">
                        <div class="flex justify-between">
                            <span class="text-gray-600">Pobočka</span>
                            <span class="font-medium">{{ place.name }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Skladová jednotka</span>
                            <span class="font-medium">{{ storageType.name }} ({{ storage.number }})</span>
                        </div>
                    </div>
                </div>

                <p class="text-gray-600 mb-4">
                    Dluh můžete uhradit kartou online nebo bankovním převodem — vyberte si, co vám vyhovuje.
                </p>

                {% if bankFirst %}
                    {{ blocks.bank_transfer_block(bankAccount, order.variableSymbol, debtAmountCzk, remainingDebtCzk, qrCodeDataUri) }}
                    {{ blocks.gopay_block(debtAmountCzk, remainingDebtCzk) }}
                {% else %}
                    {{ blocks.gopay_block(debtAmountCzk, remainingDebtCzk) }}
                    {{ blocks.bank_transfer_block(bankAccount, order.variableSymbol, debtAmountCzk, remainingDebtCzk, qrCodeDataUri) }}
                {% endif %}

                {# Pronajímatel identification #}
                <div class="bg-white border border-gray-200 rounded-lg p-4 mb-6 mt-6 text-xs text-gray-600">
                    <p class="font-semibold text-gray-800 mb-1">Pronajímatel</p>
                    <p>
                        Mekmann s.r.o., IČO 11678631, DIČ CZ11678631<br>
                        Sídlo: Dvořákova 780, 739 11 Frýdlant nad Ostravicí<br>
                        Zápis: Krajský soud v Ostravě, oddíl C, vložka 86521<br>
                        Kontakt: <a href="tel:+420605522566" class="text-accent hover:underline">+420 605 522 566</a> · <a href="mailto:skladmistr@fajnesklady.cz" class="text-accent hover:underline">skladmistr@fajnesklady.cz</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if goPayEmbedJs %}
    <script src="{{ goPayEmbedJs }}" async></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const payButton = document.getElementById('pay-button');
            const loadingEl = document.getElementById('payment-loading');
            const errorEl = document.getElementById('payment-error');
            const errorTextEl = document.getElementById('payment-error-text');
            const actionsEl = document.getElementById('payment-actions');

            function showError(message) {
                errorTextEl.textContent = message;
                errorEl.classList.remove('hidden');
                loadingEl.classList.add('hidden');
                actionsEl.classList.remove('hidden');
            }

            function hideError() {
                errorEl.classList.add('hidden');
            }

            payButton.addEventListener('click', async function() {
                hideError();
                loadingEl.classList.remove('hidden');
                actionsEl.classList.add('hidden');

                try {
                    const response = await fetch('{{ path('public_debt_payment_initiate', {id: order.id}) }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    const data = await response.json();

                    if (!response.ok) {
                        showError(data.error || 'Došlo k chybě při vytváření platby.');
                        return;
                    }

                    loadingEl.classList.add('hidden');

                    if (typeof _gopay === 'undefined') {
                        showError('Platební brána se načítá. Zkuste to prosím znovu za moment.');
                        actionsEl.classList.remove('hidden');
                        return;
                    }

                    _gopay.checkout({
                        gatewayUrl: data.gwUrl,
                        inline: true
                    });

                } catch (error) {
                    console.error('Payment error:', error);
                    showError('Došlo k chybě při komunikaci se serverem. Zkuste to prosím znovu.');
                }
            });
        });
    </script>
    {% endif %}
{% endblock %}
