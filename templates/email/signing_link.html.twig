<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ content.subject }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }
        .header {
            background-color: #570df8;
            color: white;
            padding: 20px;
            text-align: center;
            border-radius: 5px 5px 0 0;
        }
        .content {
            background-color: #f9f9f9;
            padding: 30px;
            border: 1px solid #ddd;
            border-top: none;
        }
        .summary {
            background-color: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            padding: 16px 20px;
            margin: 16px 0 24px;
        }
        .summary h3 {
            margin: 0 0 12px;
            font-size: 16px;
        }
        .summary table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }
        .summary td {
            padding: 4px 0;
            vertical-align: top;
        }
        .summary td.label {
            color: #6b7280;
            width: 45%;
        }
        .banner {
            border-radius: 6px;
            padding: 14px 18px;
            text-align: center;
            margin: 16px 0 24px;
        }
        .banner-green {
            background-color: #ecfdf5;
            border: 2px solid #6ee7b7;
            color: #065f46;
        }
        .button {
            display: inline-block;
            background-color: #570df8;
            color: white !important;
            padding: 12px 30px;
            text-decoration: none;
            border-radius: 5px;
            margin: 20px 0;
            font-weight: bold;
        }
        .footer {
            text-align: center;
            padding: 20px;
            font-size: 12px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>{{ content.headline }}</h1>
    </div>

    <div class="content">
        <h2>Dobrý den, {{ name }}!</h2>

        {% if content.situation.value == 'externally_prepaid' %}
            <div class="banner banner-green">
                <strong>Pronájem je již předplacen externě do {{ content.paidThroughDate|date('d.m.Y') }}</strong>
                <br>
                <span style="font-size: 13px;">Po podpisu smlouvy nyní nic neplatíte.</span>
                {% if content.futureBillingLine %}
                    <br>
                    <span style="font-size: 13px;">{{ content.futureBillingLine }}</span>
                {% endif %}
            </div>
        {% elseif content.situation.value == 'free' %}
            <div class="banner banner-green">
                <strong>Bezplatný pronájem</strong>
                <br>
                <span style="font-size: 13px;">U této smlouvy se neúčtuje žádné nájemné. Po podpisu smlouvy nemusíte nic platit.</span>
            </div>
        {% endif %}

        {% if order.hasDebt() %}
            <div style="background-color: #fffbeb; border: 2px solid #fbbf24; border-radius: 6px; padding: 14px 18px; margin: 16px 0 24px;">
                <strong style="color: #92400e;">Upozornění:</strong>
                <span style="color: #92400e;">K této objednávce evidujeme dluh z předchozí smlouvy ve výši {{ (order.onboardingDebtInHaler / 100)|number_format(0, ',', ' ') }} Kč.
                Po podpisu smlouvy budete nejprve vyzváni k úhradě tohoto dluhu.</span>
            </div>
        {% endif %}

        <p>{{ content.nextStepLine }}</p>

        <div class="summary">
            <h3>Shrnutí objednávky</h3>
            <table>
                <tr>
                    <td class="label">Pobočka:</td>
                    <td><strong>{{ place.name }}</strong></td>
                </tr>
                {% if placeAddress %}
                <tr>
                    <td class="label">Adresa:</td>
                    <td>{{ placeAddress }}</td>
                </tr>
                {% endif %}
                <tr>
                    <td class="label">Skladová jednotka:</td>
                    <td>{{ storageType.name }} ({{ storage.number }})</td>
                </tr>
                <tr>
                    <td class="label">Začátek:</td>
                    <td>{{ order.startDate|date('d.m.Y') }}</td>
                </tr>
                {% if order.endDate %}
                <tr>
                    <td class="label">Konec:</td>
                    <td>{{ order.endDate|date('d.m.Y') }}</td>
                </tr>
                {% endif %}
                {% if content.situation.value == 'gopay_first_charge' %}
                <tr>
                    <td class="label">{{ order.isRecurring() ? 'Měsíční platba:' : (order.isPaidInUpfrontTranches() ? 'První platba:' : 'Celková cena:') }}</td>
                    <td><strong>{{ (content.monthlyPriceInHaler / 100)|number_format(0, ',', ' ') }} Kč{% if order.isRecurring() %} / měsíc{% endif %}</strong></td>
                </tr>
                {% elseif content.situation.value == 'externally_prepaid' and content.billingResumesOn is not null %}
                <tr>
                    <td class="label">{{ content.cadenceLabel == 'rok' ? 'Roční' : 'Měsíční' }} platba od {{ content.billingResumesOn|date('d.m.Y') }}:</td>
                    <td><strong>{{ (content.monthlyPriceInHaler / 100)|number_format(0, ',', ' ') }} Kč / {{ content.cadenceLabel }}</strong> vč. DPH</td>
                </tr>
                {% endif %}
            </table>
        </div>

        <div style="text-align: center;">
            <a href="{{ signingUrl }}" class="button">{{ content.buttonLabel }}</a>
        </div>

        <p style="font-size: 13px; color: #666;">
            Pokud tlačítko nefunguje, zkopírujte tento odkaz do prohlížeče:<br>
            <a href="{{ signingUrl }}" style="color: #570df8; word-break: break-all;">{{ signingUrl }}</a>
        </p>

        <p>Pokud jste tuto žádost neočekávali, můžete tento e-mail ignorovat.</p>

        <p>S pozdravem,<br>
        <strong>Tým Fajnesklady.cz</strong></p>
    </div>

    <div class="footer">
        <p>Toto je automaticky generovaný e-mail. Prosím neodpovídejte na tuto zprávu.</p>
        <p>&copy; {{ 'now'|date('Y') }} Fajnesklady.cz. Všechna práva vyhrazena.</p>
    </div>
</body>
</html>
