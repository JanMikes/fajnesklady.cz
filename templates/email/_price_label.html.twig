{# Inputs:
     isRecurring     bool
     priceCzk        float|int  (monthly rate for recurring; one-shot total otherwise)
     yearlyAmountCzk float|null  optional — when present we lead with monthly
                                  equivalent + small "(účtováno jednou ročně, X Kč)"
                                  annotation. Spec 045.
     isUpfrontTranches bool      optional — spec 078 tranches: upfront rental
                                  > 12 months paid in yearly tranches; priceCzk
                                  is only the FIRST tranche, label must not
                                  claim "Celková cena".
   Used by order_confirmation, order_cancelled. Renders a <td>/<td> row body. #}
{% set isYearly = yearlyAmountCzk is defined and yearlyAmountCzk is not null and yearlyAmountCzk > 0 %}
{% set displayMonthlyCzk = isYearly ? yearlyAmountCzk / 12 : priceCzk %}
{% set formattedMonthly = displayMonthlyCzk|number_format(0, ',', ' ') ~ ' Kč' %}
{% set formattedPrice = priceCzk|number_format(0, ',', ' ') ~ ' Kč' %}
{% if isRecurring %}
    <td>Měsíční platba:</td>
    <td>
        <strong>{{ formattedMonthly }} / měsíc</strong>
        {% if isYearly %}
            <br><small style="color:#6b7280;">účtováno jednou ročně, {{ yearlyAmountCzk|number_format(0, ',', ' ') }} Kč</small>
        {% endif %}
    </td>
{% else %}
    <td>{{ isUpfrontTranches is defined and isUpfrontTranches ? 'První platba:' : 'Celková cena:' }}</td>
    <td><strong>{{ formattedPrice }}</strong></td>
{% endif %}
