{% extends 'portal/layout.html.twig' %}

{% block title %}Detail objednávky - Admin{% endblock %}

{% block breadcrumb %}
    {% include 'components/breadcrumb.html.twig' with {breadcrumb_items: [
        {label: 'Objednávky', url: path('admin_orders_list')},
        {label: 'Detail'},
    ]} %}
{% endblock %}

{% block content %}
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Detail objednávky (Admin)</h1>
        <div class="flex items-center space-x-3">
            {% set statusClass = {
                'created': 'bg-gray-100 text-gray-800',
                'reserved': 'bg-yellow-100 text-yellow-800',
                'awaiting_payment': 'bg-amber-100 text-amber-800',
                'paid': 'bg-green-100 text-green-800',
                'completed': 'bg-green-100 text-green-800',
                'cancelled': 'bg-red-100 text-red-800',
                'expired': 'bg-gray-100 text-gray-800'
            } %}
            {% set statusLabel = {
                'created': 'Vytvořeno',
                'reserved': 'Rezervováno',
                'awaiting_payment': 'Čeká na platbu',
                'paid': 'Zaplaceno',
                'completed': 'Dokončeno',
                'cancelled': 'Zrušeno',
                'expired': 'Expirováno'
            } %}
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium {{ statusClass[order.status.value] ?? 'bg-gray-100 text-gray-800' }}">
                {{ statusLabel[order.status.value] ?? order.status.value }}
            </span>
            {% if contract %}
                {% set isContractActive = contract.terminatedAt is null and (contract.endDate is null or contract.endDate >= now) %}
                {% if contract.terminatedAt %}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-red-100 text-red-800">
                        Smlouva ukončena
                    </span>
                {% elseif isContractActive %}
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
                        Smlouva aktivní
                    </span>
                {% endif %}
            {% endif %}
        </div>
    </div>

    {% if isUserOverdue %}
        <div class="mb-6 bg-red-50 border border-red-300 rounded-lg p-4 flex items-start gap-3">
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-red-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l6.518 11.59c.75 1.335-.213 2.98-1.742 2.98H3.481c-1.53 0-2.493-1.645-1.743-2.98L8.257 3.099zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            <div class="text-sm text-red-800">
                <strong>Tento zákazník má platbu po splatnosti.</strong>
                <a href="{{ path('admin_overdue') }}" class="link ml-2">Zobrazit přehled po splatnosti</a>
            </div>
        </div>
    {% endif %}

    {% for tx in mismatchTransactions %}
        <div class="mb-6 bg-amber-50 border border-amber-300 rounded-lg p-4 flex items-start gap-3">
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-amber-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l6.518 11.59c.75 1.335-.213 2.98-1.742 2.98H3.481c-1.53 0-2.493-1.645-1.743-2.98L8.257 3.099zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            <div class="text-sm text-amber-800">
                <strong>Neshoda částky bankovního převodu</strong>
                {% if tx.expectedAmountInHaler is not null %}
                    <p class="mt-1">
                        Očekáváno: <strong>{{ (tx.expectedAmountInHaler / 100)|number_format(0, ',', ' ') }} Kč</strong>,
                        přijato: <strong>{{ (tx.amount / 100)|number_format(0, ',', ' ') }} Kč</strong>
                        (rozdíl: {{ ((tx.amount - tx.expectedAmountInHaler) / 100)|number_format(0, ',', ' ') }} Kč)
                    </p>
                {% else %}
                    <p class="mt-1">Přijato: <strong>{{ (tx.amount / 100)|number_format(0, ',', ' ') }} Kč</strong></p>
                {% endif %}
                <p class="mt-1 text-amber-600">
                    FIO transakce: {{ tx.fioTransactionId }}{% if tx.variableSymbol %}, VS: {{ tx.variableSymbol }}{% endif %}, datum: {{ tx.transactionDate|date('d.m.Y') }}
                </p>
            </div>
        </div>
    {% endfor %}

    {% if handoverProtocol %}
        {% include 'components/handover_banner.html.twig' with {
            protocol: handoverProtocol,
            actor: 'admin',
            viewUrl: path('admin_handover_view', {id: handoverProtocol.id}),
            now: now,
        } only %}
    {% endif %}

    {% include 'admin/order/_onboarding_banner.html.twig' %}

    {% if order.onboardingDebtInHaler is not null %}
        <div class="mb-6 bg-{{ order.debtPaidAt ? 'green' : 'red' }}-50 border border-{{ order.debtPaidAt ? 'green' : 'red' }}-200 rounded-lg p-4">
            <div class="flex items-center justify-between">
                <div>
                    <h3 class="text-sm font-medium text-{{ order.debtPaidAt ? 'green' : 'red' }}-800">
                        Dluh z předchozí smlouvy: {{ (order.onboardingDebtInHaler / 100)|number_format(0, ',', ' ') }} Kč
                    </h3>
                </div>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ order.debtPaidAt ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' }}">
                    {% if order.debtPaidAt %}
                        Uhrazen {{ order.debtPaidAt|date('d.m.Y') }}
                    {% else %}
                        Neuhrazen
                    {% endif %}
                </span>
            </div>
        </div>
    {% endif %}

    {# Smluvní pokuty panel #}
    {% if contract and fines is defined %}
    <div class="mb-6 bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200 flex items-center justify-between">
            <h3 class="text-lg font-medium text-gray-900">Smluvní pokuty</h3>
            <a href="{{ path('admin_fine_create', {contractId: contract.id}) }}" class="btn btn-primary btn-sm">
                <svg class="h-4 w-4 mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Vystavit pokutu
            </a>
        </div>
        <div class="px-4 py-5 sm:p-6">
            {% if fines|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead>
                            <tr>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Datum</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Typ</th>
                                <th class="px-3 py-2 text-right text-xs font-medium text-gray-500 uppercase">Částka</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Stav</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Způsob platby</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Poznámka</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Akce</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            {% for fine in fines %}
                                <tr>
                                    <td class="px-3 py-2 text-sm text-gray-900 whitespace-nowrap">{{ fine.issuedAt|date('d.m.Y') }}</td>
                                    <td class="px-3 py-2 text-sm text-gray-900">{{ fine.type.label() }}</td>
                                    <td class="px-3 py-2 text-sm text-gray-900 text-right font-medium whitespace-nowrap">
                                        {{ (fine.amountInHaler / 100)|number_format(0, ',', ' ') }} Kč
                                    </td>
                                    <td class="px-3 py-2 text-sm whitespace-nowrap">
                                        {% if fine.isPaid() %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Zaplaceno</span>
                                        {% elseif fine.isCancelled() %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Zrušeno</span>
                                        {% else %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Nezaplaceno</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-3 py-2 text-sm text-gray-500 whitespace-nowrap">
                                        {% if fine.isPaid() %}
                                            {% if fine.goPayPaymentId %}
                                                Kartou (GoPay)
                                            {% else %}
                                                Převodem (VS {{ fine.variableSymbol }})
                                            {% endif %}
                                            {% if fineInvoices[fine.id|raw] is defined and fineInvoices[fine.id|raw].hasPdf() %}
                                                · <a href="{{ path('portal_user_invoice_pdf', {id: fineInvoices[fine.id|raw].id, download: 1}) }}" download
                                                     class="text-accent underline hover:text-accent-hover">Faktura</a>
                                            {% endif %}
                                        {% endif %}
                                    </td>
                                    <td class="px-3 py-2 text-sm text-gray-500 max-w-[200px] truncate" title="{{ fine.description }}">
                                        {{ fine.description|length > 50 ? fine.description|slice(0, 50) ~ '...' : fine.description }}
                                    </td>
                                    <td class="px-3 py-2 text-sm whitespace-nowrap">
                                        {% if fine.isPayable() %}
                                            <button type="button"
                                                    onclick="document.getElementById('cancelFineModal-{{ fine.id }}').showModal()"
                                                    class="text-red-600 hover:text-red-800 text-sm font-medium">Zrušit</button>
                                            {% embed 'components/_danger_modal.html.twig' with {
                                                id: 'cancelFineModal-' ~ fine.id,
                                                title: 'Zrušit pokutu',
                                                action: path('admin_fine_cancel', {id: fine.id}),
                                            } %}
                                                {% block description %}
                                                    Pokuta bude zrušena.
                                                    <strong class="text-red-700">Tato akce je nevratná.</strong>
                                                {% endblock %}
                                                {% block submit_label %}Zrušit pokutu{% endblock %}
                                            {% endembed %}
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-sm text-gray-500">Žádné pokuty.</p>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {% include 'admin/order/_price_change_history.html.twig' with {priceChanges: priceChanges} %}

    {% include 'admin/order/_prolongation_history.html.twig' with {prolongations: prolongations} %}

    {# Expiration Warning for contracts ending soon #}
    {% if contract and daysRemaining is not null and daysRemaining <= 7 and daysRemaining > 0 and contract.terminatedAt is null %}
    <div class="mb-6 bg-yellow-50 border border-yellow-200 rounded-lg p-4">
        <div class="flex">
            <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            <div class="ml-3">
                <h3 class="text-sm font-medium text-yellow-800">Smlouva brzy končí</h3>
                <p class="mt-1 text-sm text-yellow-700">
                    Tato smlouva končí za {{ daysRemaining }} {{ daysRemaining == 1 ? 'den' : (daysRemaining < 5 ? 'dny' : 'dni') }}.
                </p>
            </div>
        </div>
    </div>
    {% endif %}

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {# Customer Details #}
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
                <h3 class="text-lg font-medium text-gray-900">Zákazník</h3>
            </div>
            <div class="px-4 py-5 sm:p-6">
                <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Jméno</dt>
                        <dd class="mt-1 text-sm text-gray-900">
                            <a href="{{ path('portal_users_view', {id: order.user.id}) }}" class="link">
                                {{ order.user.fullName }}
                            </a>
                        </dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Email</dt>
                        <dd class="mt-1 text-sm text-gray-900">
                            <a href="mailto:{{ order.user.email }}" class="link">
                                {{ order.user.email }}
                            </a>
                        </dd>
                    </div>
                    {% if order.user.phone %}
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Telefon</dt>
                        <dd class="mt-1 text-sm text-gray-900">
                            <a href="tel:{{ order.user.phone }}" class="link">
                                {{ order.user.phone }}
                            </a>
                        </dd>
                    </div>
                    {% endif %}
                </dl>
            </div>
        </div>

        {# Order Details #}
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
                <h3 class="text-lg font-medium text-gray-900">Informace o objednávce</h3>
            </div>
            <div class="px-4 py-5 sm:p-6">
                <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Číslo objednávky</dt>
                        <dd class="mt-1 text-sm text-gray-900 font-mono">{{ order.id|slice(0, 8)|upper }}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Způsob platby</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ order.billingMode.label() }}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Datum začátku</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ order.startDate|date('d.m.Y') }}</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Datum konce</dt>
                        <dd class="mt-1 text-sm text-gray-900">
                            {% set displayEndDate = contract ? contract.endDate : order.endDate %}
                            {% if displayEndDate %}
                                {{ displayEndDate|date('d.m.Y') }}
                                {% if contract and daysRemaining is not null and contract.terminatedAt is null %}
                                    <span class="text-gray-500">({{ daysRemaining }} {{ daysRemaining == 1 ? 'den' : (daysRemaining < 5 ? 'dny' : 'dni') }})</span>
                                {% endif %}
                            {% else %}
                                od {{ order.startDate|date('d.m.Y') }}
                            {% endif %}
                        </dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-gray-500">{{ order.isRecurring ? 'Měsíční platba' : (order.isPaidInUpfrontTranches ? 'První platba' : 'Celková cena') }}</dt>
                        <dd class="mt-1 text-sm text-gray-900 font-semibold">{{ (order.firstPaymentPrice / 100)|number_format(2, ',', ' ') }} Kč{% if order.isRecurring %} / měsíc{% endif %}</dd>
                    </div>
                    {% include '_price_aggregate.html.twig' with { order: order, paymentSchedule: paymentSchedule, totalPaid: totalPaid, bankTransferReceivedTotal: bankTransferReceivedTotal } only %}
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Vytvořeno</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ order.createdAt|date('d.m.Y H:i') }}</dd>
                    </div>
                    {% if order.paidAt %}
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Datum platby</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ order.paidAt|date('d.m.Y H:i') }}</dd>
                    </div>
                    {% endif %}
                    {% if order.expiresAt %}
                    <div>
                        <dt class="text-sm font-medium text-gray-500">Expirace</dt>
                        <dd class="mt-1 text-sm text-gray-900">{{ order.expiresAt|date('d.m.Y H:i') }}</dd>
                    </div>
                    {% endif %}
                </dl>
            </div>
        </div>
    </div>

    {# Storage Details #}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">Skladová jednotka</h3>
        </div>
        <div class="px-4 py-5 sm:p-6">
            <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2 lg:grid-cols-4">
                <div>
                    <dt class="text-sm font-medium text-gray-500">Typ skladu</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ storageType.name }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500">Číslo jednotky</dt>
                    <dd class="mt-1 text-sm text-gray-900 font-semibold">{{ storage.number }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500">Rozměry</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ storageType.dimensionsInMeters }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500">Pobočka</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ place.name }}</dd>
                </div>
                <div class="sm:col-span-2 lg:col-span-4">
                    <dt class="text-sm font-medium text-gray-500">Adresa</dt>
                    <dd class="mt-1 text-sm text-gray-900">
                        {% include 'components/place_address.html.twig' with {place: place} only %}
                    </dd>
                </div>
            </dl>
        </div>
    </div>

    {# Contract Details #}
    {% if contract %}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">Smlouva</h3>
        </div>
        <div class="px-4 py-5 sm:p-6">
            <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2 lg:grid-cols-4">
                <div>
                    <dt class="text-sm font-medium text-gray-500">Číslo smlouvy</dt>
                    <dd class="mt-1 text-sm text-gray-900 font-mono">{{ contract.id|slice(0, 8)|upper }}</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500">Vytvořeno</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ contract.createdAt|date('d.m.Y H:i') }}</dd>
                </div>
                {% if contract.signedAt %}
                <div>
                    <dt class="text-sm font-medium text-gray-500">Podepsáno</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ contract.signedAt|date('d.m.Y H:i') }}</dd>
                </div>
                {% endif %}
                {% if contract.terminatedAt %}
                <div>
                    <dt class="text-sm font-medium text-gray-500">Ukončeno</dt>
                    <dd class="mt-1 text-sm text-gray-900">{{ contract.terminatedAt|date('d.m.Y H:i') }}</dd>
                </div>
                {% endif %}
            </dl>
        </div>
    </div>
    {% endif %}

    {# Contract Document Download #}
    {% if contract %}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="h-10 w-10 {{ contract.hasDocument() ? 'text-accent' : 'text-gray-400' }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <div class="ml-4">
                        <h3 class="text-lg font-medium text-gray-900">Dokument smlouvy</h3>
                        {% if contract.hasDocument() %}
                            <p class="text-sm text-gray-500">Stáhněte si kopii smlouvy</p>
                        {% else %}
                            <p class="text-sm text-yellow-600">Dokument smlouvy zatím není k dispozici</p>
                        {% endif %}
                    </div>
                </div>
                <div class="flex space-x-2">
                    {% if contract.hasDocument() %}
                        <a href="{{ path('portal_user_contract_pdf', {id: contract.id}) }}" class="btn btn-primary">
                            <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                            </svg>
                            Stáhnout PDF
                        </a>
                        <a href="{{ path('portal_user_contract_download', {id: contract.id}) }}" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                            <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                            </svg>
                            Stáhnout DOCX
                        </a>
                    {% else %}
                        <span class="inline-flex items-center px-4 py-2 border border-gray-200 text-sm font-medium rounded-md text-gray-400 bg-gray-50 cursor-not-allowed">
                            <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                            </svg>
                            Není k dispozici
                        </span>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {% if handoverProtocol and handoverProtocol.isFullyCompleted %}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <svg class="h-10 w-10 text-accent" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <div class="ml-4">
                        <h3 class="text-lg font-medium text-gray-900">Předávací protokol</h3>
                        <p class="text-sm text-gray-500">Vyplněn {{ handoverProtocol.completedAt|date('d.m.Y') }}</p>
                    </div>
                </div>
                <a href="{{ path('admin_handover_view', {id: handoverProtocol.id}) }}" class="btn btn-primary">
                    Zobrazit protokol
                </a>
            </div>
        </div>
    </div>
    {% endif %}

    {# Invoices #}
    {% if order.status.value in ['paid', 'completed'] %}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Faktury</h3>
            {% if invoices|length > 0 %}
                <div class="space-y-3">
                    {% for invoice in invoices %}
                        <div class="flex items-center justify-between py-3 {{ not loop.last ? 'border-b border-gray-100' : '' }}">
                            <div class="flex items-center">
                                <svg class="h-8 w-8 {{ invoice.hasPdf() ? 'text-accent' : 'text-gray-400' }} flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                </svg>
                                <div class="ml-3">
                                    <p class="text-sm font-medium text-gray-900">{{ invoice.invoiceNumber }}</p>
                                    <p class="text-xs text-gray-500">{{ invoice.issuedAt|date('d.m.Y') }} - {{ (invoice.amount / 100)|number_format(2, ',', ' ') }} Kč</p>
                                </div>
                            </div>
                            {% if invoice.hasPdf() %}
                                <a href="{{ path('portal_user_invoice_pdf', {id: invoice.id}) }}" class="btn btn-primary btn-sm">
                                    <svg class="h-4 w-4 mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                                    </svg>
                                    PDF
                                </a>
                            {% else %}
                                <span class="text-xs text-gray-400">PDF není k dispozici</span>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-sm text-yellow-600">Faktura zatím není k dispozici</p>
            {% endif %}
        </div>
    </div>
    {% endif %}

    {# Advance-notice trigger — visible only when the contract has an active
       recurring payment. Use when changing the recurring price or frequency:
       Podmínky opakovaných plateb čl. V requires informing the customer at
       least 7 working days in advance. #}
    {% if contract and contract.hasActiveRecurringPayment() %}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg border border-blue-200">
        <div class="px-4 py-5 sm:p-6">
            <div class="flex items-start gap-3 mb-3">
                <svg class="h-6 w-6 text-blue-500 flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
                <div>
                    <h3 class="text-lg font-medium text-gray-900">Upozornit zákazníka na změnu opakované platby</h3>
                    <p class="mt-1 text-sm text-gray-600">
                        Podmínky opakovaných plateb (čl. V) ukládají zákazníka informovat <strong>nejméně 7 pracovních dní předem</strong> o jakékoli změně parametrů opakované platby (cena, frekvence).
                        Tímto formulářem odešlete zákazníkovi e-mail s informací o změně. Změnu samotnou (např. úpravu ceny v ceníku) proveďte zvlášť.
                    </p>
                </div>
            </div>

            {% if contract.lastAdvanceNoticeSentAt %}
                <p class="text-xs text-gray-500 mb-4">Poslední upozornění bylo odesláno {{ contract.lastAdvanceNoticeSentAt|date('d.m.Y H:i') }}.</p>
            {% endif %}

            <form action="{{ path('admin_contract_advance_notice', {id: contract.id}) }}" method="post" onsubmit="return confirm('Opravdu chcete odeslat upozornění zákazníkovi?');" class="space-y-4">
                <div>
                    <label for="new_amount_czk" class="block text-sm font-medium text-gray-700">Nová částka opakované platby (Kč / měsíc, vč. DPH) <span class="text-gray-400">— volitelné</span></label>
                    <input type="number" step="0.01" min="0" max="15000" name="new_amount_czk" id="new_amount_czk"
                           placeholder="např. 3 500,00"
                           class="form-input mt-1 sm:w-1/2 text-sm">
                    <p class="mt-1 text-xs text-gray-500">Pokud se mění cena, vyplňte. Maximální částka opakované platby je 15&nbsp;000&nbsp;Kč (Podmínky čl. III).</p>
                </div>
                <div>
                    <label for="admin_note" class="block text-sm font-medium text-gray-700">Poznámka pro zákazníka <span class="text-gray-400">— volitelné, doporučené</span></label>
                    <textarea name="admin_note" id="admin_note" rows="3"
                              placeholder="např. Důvod změny ceny, datum účinnosti, …"
                              class="form-input mt-1 text-sm"></textarea>
                    <p class="mt-1 text-xs text-gray-500">Krátký lidský komentář, který se objeví v e-mailu. Vyplňte alespoň částku nebo poznámku.</p>
                </div>
                <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    Odeslat upozornění zákazníkovi
                </button>
            </form>
        </div>
    </div>
    {% endif %}

    {# Manual actions #}
    {% set hasSigningAction = order.signingToken is not null and order.signedAt is null %}
    {% set hasOnboardingAction = order.createdByAdmin is not null and order.signedAt is not null and order.paidAt is null %}
    {% set hasBillingAction = contract is not null and contract.usesManualBillingTrack() and hasPendingManualPayment %}
    {% set payableFines = fines|filter(fine => fine.payable) %}
    {% if hasSigningAction or hasOnboardingAction or hasBillingAction or payableFines|length > 0 %}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg border-l-4 border-blue-400">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">Manuální akce</h3>
        </div>
        <div class="px-4 py-5 sm:p-6">
            <div class="flex flex-wrap gap-3">
                {% if hasSigningAction %}
                    <form method="post" action="{{ path('admin_order_resend_signing_link', {id: order.id}) }}">
                        <button type="submit" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50"
                                onclick="return confirm('Opravdu chcete znovu odeslat odkaz k podpisu?');">
                            <svg class="h-4 w-4 mr-2 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            Znovu odeslat odkaz k podpisu
                        </button>
                    </form>
                {% endif %}
                {% if hasOnboardingAction %}
                    <form method="post" action="{{ path('admin_order_send_onboarding_reminder', {id: order.id}) }}">
                        <button type="submit" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50"
                                onclick="return confirm('Opravdu chcete odeslat připomínku platby?');">
                            <svg class="h-4 w-4 mr-2 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            Odeslat připomínku platby (onboarding)
                        </button>
                    </form>
                {% endif %}
                {% if hasBillingAction %}
                    <form method="post" action="{{ path('admin_order_send_billing_reminder', {id: order.id}) }}">
                        <button type="submit" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50"
                                onclick="return confirm('Opravdu chcete odeslat výzvu k platbě?');">
                            <svg class="h-4 w-4 mr-2 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            Odeslat výzvu k platbě
                        </button>
                    </form>
                {% endif %}
                {% for fine in payableFines %}
                    <form method="post" action="{{ path('admin_order_send_fine_reminder', {id: order.id, fineId: fine.id}) }}">
                        <button type="submit" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50"
                                onclick="return confirm('Opravdu chcete odeslat připomínku pokuty?');">
                            <svg class="h-4 w-4 mr-2 text-gray-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            Odeslat připomínku pokuty: {{ fine.type.label() }}
                        </button>
                    </form>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    {# Email history #}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
            <h3 class="text-lg font-medium text-gray-900">E-mailová komunikace</h3>
        </div>
        <div class="px-4 py-5 sm:p-6">
            {% if emailLogs|length > 0 %}
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead>
                            <tr>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Datum</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Typ</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Příjemce</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Stav</th>
                                <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Akce</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            {% set templateLabels = {
                                'email/signing_link': 'Odkaz k podpisu',
                                'email/order_placed': 'Potvrzení objednávky',
                                'email/order_cancelled': 'Zrušení objednávky',
                                'email/rental_activated': 'Aktivace pronájmu',
                                'email/invoice': 'Faktura',
                                'email/onboarding_payment_reminder': 'Připomínka platby (onboarding)',
                                'email/manual_billing_payment_initial': 'Výzva k platbě (7 dní)',
                                'email/manual_billing_payment_reminder': 'Připomínka platby (2 dny)',
                                'email/manual_billing_payment_due_today': 'Platba splatná dnes',
                                'email/manual_billing_payment_overdue_first': 'Upomínka — platba po splatnosti',
                                'email/manual_billing_payment_overdue_final': 'Poslední upomínka',
                                'email/manual_billing_overdue_admin': 'Upomínka (admin)',
                                'email/recurring_payment_established': 'Nastavení opakované platby',
                                'email/recurring_payment_failed': 'Selhání opakované platby',
                                'email/recurring_payment_failed_admin': 'Selhání platby (admin)',
                                'email/recurring_payment_advance_notice': 'Předběžné oznámení platby',
                                'email/recurring_payment_cancelled': 'Zrušení opakované platby',
                                'email/recurring_payment_cancelled_admin': 'Zrušení platby (admin)',
                                'email/contract_expiring': 'Blížící se konec smlouvy',
                                'email/contract_terminated': 'Ukončení smlouvy',
                                'email/termination_notice': 'Výpověď',
                                'email/termination_notice_admin': 'Výpověď (admin)',
                                'email/payment_default_tenant': 'Oznámení o prodlení',
                                'email/payment_default_admin': 'Prodlení (admin)',
                                'email/payment_demand_tenant': 'Výzva k úhradě',
                                'email/payment_demand_admin': 'Výzva k úhradě (admin)',
                                'email/external_prepayment_ending_soon': 'Končící externí předplatné',
                                'email/external_prepayment_ending_soon_admin': 'Končící předplatné (admin)',
                                'email/debt_payment_request': 'Výzva k úhradě dluhu',
                                'email/fine_issued': 'Vystavení pokuty',
                                'email/fine_payment_reminder': 'Připomínka pokuty',
                                'email/fine_paid': 'Potvrzení úhrady pokuty',
                                'email/payment_amount_mismatch': 'Nesouhlasí částka platby',
                                'email/bank_transfer_amount_mismatch_admin': 'Neshoda převodu (admin)',
                                'email/bank_transfer_amount_mismatch_customer': 'Neshoda převodu (zákazník)',
                            } %}
                            {% for log in emailLogs %}
                                <tr>
                                    <td class="px-3 py-2 text-sm text-gray-900 whitespace-nowrap">{{ log.attemptedAt|date('d.m.Y H:i') }}</td>
                                    <td class="px-3 py-2 text-sm text-gray-900">{{ templateLabels[log.templateName] ?? log.templateName ?? '—' }}</td>
                                    <td class="px-3 py-2 text-sm text-gray-500">{{ log.toAddresses[0].email ?? '—' }}</td>
                                    <td class="px-3 py-2 text-sm whitespace-nowrap">
                                        {% if log.status.value == 'sent' %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Odesláno</span>
                                        {% else %}
                                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Selhalo</span>
                                        {% endif %}
                                    </td>
                                    <td class="px-3 py-2 text-sm whitespace-nowrap">
                                        <a href="{{ path('admin_email_log_detail', {id: log.id}) }}" class="text-accent hover:text-accent/80">
                                            <svg class="h-4 w-4 inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                            </svg>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% if emailLogs|length >= 50 %}
                    <div class="mt-3 text-sm">
                        <a href="{{ path('admin_email_log', {orderId: order.id}) }}" class="link">Zobrazit vše →</a>
                    </div>
                {% endif %}
            {% else %}
                <p class="text-sm text-gray-500">Zatím nebyla odeslána žádná e-mailová komunikace k této objednávce.</p>
                <p class="text-xs text-gray-400 mt-1">Sledování e-mailů je aktivní od nasazení této funkce. Starší e-maily zde nejsou zobrazeny.</p>
            {% endif %}
        </div>
    </div>

    {# Activity timeline #}
    {% include 'admin/order/_activity_timeline.html.twig' with {
        auditLogs: auditLogs,
        emailLogs: emailLogs,
        order: order
    } %}

    {# Cancel Order Section #}
    {% if order.canBeCancelled() %}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg border border-red-200">
        <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-red-900">Zrušit objednávku</h3>
            <p class="mt-1 text-sm text-gray-600">
                Objednávku můžete zrušit, dokud nebyla zaplacena. Po zrušení bude skladová jednotka uvolněna a zákazník obdrží email.
            </p>
            <div class="mt-4">
                <button type="button"
                        onclick="document.getElementById('adminCancelOrderModal').showModal()"
                        class="inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50">
                    <svg class="h-4 w-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    Zrušit objednávku
                </button>
                {% embed 'components/_danger_modal.html.twig' with {
                    id: 'adminCancelOrderModal',
                    title: 'Zrušit objednávku',
                    action: path('admin_order_cancel', {id: order.id}),
                } %}
                    {% block description %}
                        Po zrušení bude skladová jednotka uvolněna a zákazník obdrží email.
                        <strong class="text-red-700">Tato akce je nevratná.</strong>
                    {% endblock %}
                    {% block submit_label %}Zrušit objednávku{% endblock %}
                {% endembed %}
            </div>
        </div>
    </div>
    {% endif %}

    {# Pending termination banner #}
    {% if contract and contract.hasPendingTermination() %}
    <div class="mt-6 bg-amber-50 border border-amber-200 rounded-lg p-4">
        <p class="text-sm text-amber-800">
            <strong>Výpověď podána:</strong> Smlouva bude ukončena k {{ contract.terminatesAt|date('d.m.Y') }}.
        </p>
    </div>
    {% endif %}

    {# Termination Section — admin form with immediate/with_notice radio #}
    {% if canTerminate %}
    <div class="mt-6 bg-white shadow overflow-hidden sm:rounded-lg border border-red-200">
        <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-red-900">Ukončit smlouvu</h3>
            <div class="mt-4">
                <button type="button"
                        onclick="document.getElementById('terminateContractModal').showModal()"
                        class="inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50">
                    Ukončit smlouvu
                </button>
            </div>
            {% embed 'components/_danger_modal.html.twig' with {
                id: 'terminateContractModal',
                title: 'Ukončit smlouvu',
                action: path('admin_contract_terminate', {id: contract.id}),
            } %}
                {% block description %}
                    <strong class="text-red-700">Tato akce je nevratná.</strong>
                {% endblock %}
                {% block extra_fields %}
                    <div class="space-y-3">
                        <div>
                            <label class="flex items-center gap-2">
                                <input type="radio" name="termination_type" value="with_notice" checked
                                       class="form-radio accent-red-600 focus:ring-red-500">
                                <span class="text-sm text-gray-700">S výpovědní dobou (1 měsíc)</span>
                            </label>
                        </div>
                        <div>
                            <label class="flex items-center gap-2">
                                <input type="radio" name="termination_type" value="immediate"
                                       class="form-radio accent-red-600 focus:ring-red-500">
                                <span class="text-sm text-gray-700">Okamžitě pro porušení smlouvy</span>
                            </label>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-600">Důvod (volitelný)</label>
                            <textarea name="reason" rows="2" maxlength="500"
                                      class="form-input mt-1 text-sm"></textarea>
                        </div>
                    </div>
                {% endblock %}
                {% block submit_label %}Ukončit smlouvu{% endblock %}
            {% endembed %}
        </div>
    </div>
    {% endif %}

{% endblock %}
