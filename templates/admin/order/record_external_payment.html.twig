{% extends 'portal/layout.html.twig' %}

{% block title %}Externí platba - Admin{% endblock %}

{% block breadcrumb %}
    {% include 'components/breadcrumb.html.twig' with {breadcrumb_items: [
        {label: 'Objednávky', url: path('admin_orders_list')},
        {label: 'Detail', url: path('admin_order_detail', {id: order.id})},
        {label: 'Externí platba'},
    ]} %}
{% endblock %}

{% block content %}
    <div class="max-w-2xl mx-auto">
        <h1 class="text-3xl font-bold text-gray-900 mb-6">Označit jako externě zaplaceno</h1>

        <div class="bg-gray-50 rounded-lg p-4 mb-6">
            <div class="text-sm text-gray-600 space-y-1">
                <p>Zákazník: <strong>{{ order.user.fullName }}</strong> ({{ order.user.email }})</p>
                <p>Skladová jednotka: <strong>{{ order.storage.storageType.name }} ({{ order.storage.number }})</strong></p>
                <p>Pobočka: <strong>{{ order.storage.place.name }}</strong></p>
                {% if contract is null %}
                    <p class="text-blue-700">Objednávka dosud nebyla zaplacena — zaznamenáním se pronájem aktivuje.</p>
                {% endif %}
            </div>
        </div>

        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6 text-sm text-amber-800">
            Použijte, pokud zákazník zaplatil mimo systém (hotově nebo na jiný bankovní účet). Zaznamená se přijatá
            platba a zastaví se výzvy k platbě pro toto období.
        </div>

        {{ form_start(form, {attr: {class: 'space-y-6'}}) }}
            {{ form_row(form.coverage) }}
            {{ form_row(form.paidThroughDate) }}
            {{ form_row(form.amountInCzk) }}
            {{ form_row(form.issueInvoice) }}

            <div class="flex justify-end space-x-3">
                <a href="{{ path('admin_order_detail', {id: order.id}) }}" class="btn btn-secondary">Zrušit</a>
                <button type="submit" class="btn btn-primary">Zaznamenat platbu</button>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
