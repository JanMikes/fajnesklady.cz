{% extends 'portal/layout.html.twig' %}

{% block title %}Všechny objednávky - Admin{% endblock %}

{% block content %}
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-gray-900">Všechny objednávky (Admin)</h1>
        {% include 'components/excel_export_button.html.twig' with {
            href: path('admin_orders_export', app.request.query.all)
        } %}
    </div>

    <form method="get" action="{{ path('admin_orders_list') }}" class="mb-4 flex items-center gap-2">
        {% if filter %}<input type="hidden" name="filter" value="{{ filter }}">{% endif %}
        <input type="search" name="q" value="{{ search }}" placeholder="Hledat číslo objednávky nebo zákazníka…" class="form-input text-sm py-1.5 w-72">
        <button type="submit" class="btn btn-sm btn-primary">Hledat</button>
        {% if search %}
            <a href="{{ path('admin_orders_list', filter ? {filter: filter} : {}) }}" class="btn btn-sm btn-ghost">Zrušit</a>
        {% endif %}
    </form>

    <div class="mb-4 flex items-center gap-2 flex-wrap">
        <a href="{{ path('admin_orders_list', search ? {q: search} : {}) }}" class="btn btn-sm {{ filter ? 'btn-ghost' : 'btn-primary' }}">Vše</a>
        <a href="{{ path('admin_orders_list', {filter: 'individual', q: search}) }}" class="btn btn-sm {{ filter == 'individual' ? 'btn-warning' : 'btn-ghost' }}">Indiv. cena ({{ filterCounts.individual }})</a>
        <a href="{{ path('admin_orders_list', {filter: 'external', q: search}) }}" class="btn btn-sm {{ filter == 'external' ? 'btn-info' : 'btn-ghost' }}">Externí předplatné ({{ filterCounts.external }})</a>
        <a href="{{ path('admin_orders_list', {filter: 'ending', q: search}) }}" class="btn btn-sm {{ filter == 'ending' ? 'btn-error' : 'btn-ghost' }}">Předplatné brzy končí ({{ filterCounts.ending }})</a>
        <a href="{{ path('admin_orders_list', {filter: 'free', q: search}) }}" class="btn btn-sm {{ filter == 'free' ? 'btn-success' : 'btn-ghost' }}">Zdarma ({{ filterCounts.free }})</a>
    </div>

    <div class="card">
        <div class="overflow-x-auto">
            <table class="table table-zebra">
                <thead>
                    <tr>
                        <th>Číslo</th>
                        <th>Zákazník</th>
                        <th>Sklad</th>
                        <th>Pobočka</th>
                        <th>Období</th>
                        <th>Cena</th>
                        <th>Stav</th>
                        <th>Vytvořeno</th>
                        <th>Akce</th>
                    </tr>
                </thead>
                <tbody>
                    {% for order in orders %}
                        {% set contract = contractsByOrderId[order.id.toRfc4122()] ?? null %}
                        <tr>
                            <td class="font-mono text-sm">
                                <a href="{{ path('admin_order_detail', {id: order.id}) }}" class="link">{{ order_reference(order) }}</a>
                            </td>
                            <td>
                                <a href="{{ path('portal_users_view', {id: order.user.id}) }}" class="link">
                                    {{ order.user.fullName }}
                                </a>
                                <div class="text-xs text-gray-500">{{ order.user.email }}</div>
                            </td>
                            <td class="text-gray-900">{{ order.storage.number }}</td>
                            <td class="text-gray-500">{{ order.storage.place.name }}</td>
                            <td class="text-sm">
                                {{ order.startDate|date('d.m.Y') }}
                                {% if order.endDate %}
                                    - {{ order.endDate|date('d.m.Y') }}
                                {% else %}
                                    <span class="text-gray-500">(automat. prodlužování)</span>
                                {% endif %}
                            </td>
                            <td class="font-medium">{{ (order.firstPaymentPrice / 100)|number_format(0, ',', ' ') }} Kč{% if order.isRecurring %} / {{ order.isYearlyFrequency ? 'rok' : 'měsíc' }}{% endif %}</td>
                            <td>
                                {% set statusClass = {
                                    'created': 'badge-ghost',
                                    'reserved': 'badge-info',
                                    'awaiting_payment': 'badge-warning',
                                    'paid': 'badge-success',
                                    'completed': 'badge-success',
                                    'cancelled': 'badge-error',
                                    'expired': 'badge-error'
                                } %}
                                {% set statusLabel = {
                                    'created': 'Vytvořeno',
                                    'reserved': 'Rezervováno',
                                    'awaiting_payment': 'Čeká na platbu',
                                    'paid': 'Zaplaceno',
                                    'completed': 'Dokončeno',
                                    'cancelled': 'Zrušeno',
                                    'expired': 'Expirováno'
                                } %}
                                <div class="flex flex-wrap gap-1">
                                    <span class="badge {{ statusClass[order.status.value] ?? 'badge-ghost' }}">
                                        {{ statusLabel[order.status.value] ?? order.status.value }}
                                    </span>
                                    {% if contract and contract.terminatedAt %}
                                        <span class="badge badge-error" title="Smlouva ukončena {{ contract.terminatedAt|date('d.m.Y') }}">Ukončeno</span>
                                    {% endif %}
                                    {% if order.individualMonthlyAmount is not null %}
                                        {% if order.individualMonthlyAmount == 0 %}
                                            <span class="badge badge-success badge-sm" title="Smlouva zdarma — bez fakturace">Zdarma</span>
                                        {% else %}
                                            <span class="badge badge-warning badge-sm" title="{{ order.paymentFrequency ? order.paymentFrequency.individualPriceLabel : 'Individuální měsíční cena' }}: {{ (order.individualMonthlyAmount / 100)|number_format(0, ',', ' ') }} Kč">Indiv. cena</span>
                                        {% endif %}
                                    {% endif %}
                                    {% if order.paidThroughDate %}
                                        <span class="badge badge-info badge-sm" title="Externí platba do {{ order.paidThroughDate|date('d.m.Y') }}">Předplaceno do {{ order.paidThroughDate|date('d.m.Y') }}</span>
                                    {% endif %}
                                    {% if contract and contract.outstandingDebtAmount and contract.outstandingDebtAmount > 0 %}
                                        <span class="badge badge-error badge-sm" title="Smlouva má nesplacený dluh">Dluh {{ (contract.outstandingDebtAmount / 100)|number_format(0, ',', ' ') }} Kč</span>
                                    {% endif %}
                                    {% if contract and overdueContractIdSet[contract.id.toRfc4122()] is defined %}
                                        <span class="badge badge-error badge-sm" title="Smlouva je po splatnosti">Po splatnosti</span>
                                    {% endif %}
                                    {% if order.onboardingDebtInHaler and order.onboardingDebtInHaler > 0 and order.debtPaidAt is null %}
                                        <span class="badge badge-warning badge-sm" title="Nesplacený onboarding dluh">Onboarding dluh {{ (order.onboardingDebtInHaler / 100)|number_format(0, ',', ' ') }} Kč</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="text-gray-500 text-sm">{{ order.createdAt|date('d.m.Y H:i') }}</td>
                            <td>
                                <a href="{{ path('admin_order_detail', {id: order.id}) }}" class="link text-sm font-medium">
                                    Zobrazit
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="9" class="text-center text-gray-500 py-8">
                                {{ search ? 'Žádné objednávky neodpovídají hledání.' : 'Žádné objednávky nenalezeny' }}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {% if totalPages > 1 %}
            {% include 'components/pagination.html.twig' with {
                currentPage: currentPage,
                totalPages: totalPages,
                route: 'admin_orders_list',
                routeParams: {filter: filter, q: search},
            } %}
        {% endif %}
    </div>
{% endblock %}
