{# expects: type, nonReturnDays, latePaymentBase, latePaymentDays, amount, description (form fields) #}
<div>
    {{ form_label(type) }}
    {{ form_widget(type, {attr: {class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-sm', 'data-fine-form-target': 'type', 'data-action': 'change->fine-form#typeChanged'}}) }}
    {{ form_errors(type) }}
</div>

<div data-fine-form-target="nonReturnDaysWrapper" class="hidden">
    {{ form_label(nonReturnDays) }}
    {{ form_widget(nonReturnDays, {attr: {class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-sm', 'data-action': 'input->fine-form#calculateAmount'}}) }}
    <p class="mt-1 text-xs text-gray-500">2 000 Kč za každý den nevrácení</p>
    {{ form_errors(nonReturnDays) }}
</div>

<div data-fine-form-target="latePaymentWrapper" class="hidden">
    <div class="grid grid-cols-2 gap-4">
        <div>
            {{ form_label(latePaymentBase) }}
            {{ form_widget(latePaymentBase, {attr: {class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-sm', 'data-action': 'input->fine-form#calculateAmount'}}) }}
            <p class="mt-1 text-xs text-gray-500">Dlužná částka v Kč</p>
            {{ form_errors(latePaymentBase) }}
        </div>
        <div>
            {{ form_label(latePaymentDays) }}
            {{ form_widget(latePaymentDays, {attr: {class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-sm', 'data-action': 'input->fine-form#calculateAmount'}}) }}
            <p class="mt-1 text-xs text-gray-500">Počet dní prodlení</p>
            {{ form_errors(latePaymentDays) }}
        </div>
    </div>
    <p class="mt-2 text-xs text-gray-500">Výpočet: max(základ × 0,25 % × dny, 250 Kč × dny)</p>
</div>

<div>
    {{ form_label(amount) }}
    {{ form_widget(amount, {attr: {class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-sm'}}) }}
    <p class="mt-1 text-xs text-gray-500">
        Částka v Kč.
        <span data-fine-form-target="amountDisplay" class="font-medium"></span>
    </p>
    {{ form_errors(amount) }}
</div>

<div>
    {{ form_label(description) }}
    {{ form_widget(description, {attr: {class: 'mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-accent focus:ring-accent text-sm'}}) }}
    {{ form_errors(description) }}
</div>
