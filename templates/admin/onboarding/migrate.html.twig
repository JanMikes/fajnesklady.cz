{% extends 'portal/layout.html.twig' %}

{% import 'components/_address_override.html.twig' as addr %}

{% block title %}Migrace zákazníka - Admin{% endblock %}

{% block breadcrumb %}
    {% include 'components/breadcrumb.html.twig' with {breadcrumb_items: [
        {label: 'Onboarding', url: path('admin_onboarding')},
        {label: 'Migrace papírové smlouvy'},
    ]} %}
{% endblock %}

{% block content %}
    <h1 class="text-3xl font-bold mb-2">Migrace papírové smlouvy</h1>
    <p class="text-gray-600 mb-6">Vytvořte zákazníka v systému na základě existující papírové smlouvy. Vše se vytvoří automaticky.</p>

    <div class="max-w-2xl">
        <div class="card">
            <div class="card-body">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'data-controller': 'admin-onboarding-form'}}) }}

                    <h3 class="text-lg font-semibold mb-4">Údaje zákazníka</h3>
                    <div class="grid md:grid-cols-2 gap-4 mb-6">
                        <div class="md:col-span-2">
                            {{ form_label(form.email) }}
                            {{ form_widget(form.email) }}
                            {{ form_errors(form.email) }}
                        </div>
                        <div>
                            {{ form_label(form.firstName) }}
                            {{ form_widget(form.firstName) }}
                            {{ form_errors(form.firstName) }}
                        </div>
                        <div>
                            {{ form_label(form.lastName) }}
                            {{ form_widget(form.lastName) }}
                            {{ form_errors(form.lastName) }}
                        </div>
                        <div>
                            {{ form_label(form.phone) }}
                            {{ form_widget(form.phone) }}
                            {{ form_errors(form.phone) }}
                        </div>
                        <div data-admin-onboarding-form-target="birthDateContainer"{% if form.vars.data.invoiceToCompany %} hidden{% endif %}>
                            {{ form_label(form.birthDate) }}
                            {{ form_widget(form.birthDate) }}
                            {{ form_errors(form.birthDate) }}
                        </div>
                    </div>

                    <hr class="my-6 border-t border-gray-200">

                    <h3 class="text-lg font-semibold mb-4">Firemní údaje</h3>
                    <div class="mb-4">
                        <label class="flex items-center cursor-pointer gap-3">
                            {{ form_widget(form.invoiceToCompany, {'attr': {'class': 'h-4 w-4 text-accent focus:ring-accent border-gray-300'}}) }}
                            <span class="text-sm text-gray-700">Nájemce je společnost / OSVČ</span>
                        </label>
                    </div>
                    <div data-admin-onboarding-form-target="companyFieldsContainer" class="grid md:grid-cols-2 gap-4 mb-6" data-controller="ares-lookup"{% if not form.vars.data.invoiceToCompany %} hidden{% endif %}>
                        <div>
                            {{ form_label(form.companyId) }}
                            <div class="flex">
                                {{ form_widget(form.companyId, {attr: {class: 'flex-1 min-w-0 rounded-r-none!'}}) }}
                                {% include 'components/ares_lookup_button.html.twig' %}
                            </div>
                            <p data-ares-lookup-target="status" class="text-sm mt-2" aria-live="polite"></p>
                            {{ form_errors(form.companyId) }}
                        </div>
                        <div>
                            {{ form_label(form.companyName) }}
                            {{ form_widget(form.companyName) }}
                            {{ form_errors(form.companyName) }}
                        </div>
                        <div class="md:col-span-2">
                            {{ form_label(form.companyVatId) }}
                            {{ form_widget(form.companyVatId) }}
                            {{ form_errors(form.companyVatId) }}
                        </div>
                    </div>

                    <hr class="my-6 border-t border-gray-200">

                    <h3 class="text-lg font-semibold mb-4">
                        <span data-admin-onboarding-form-target="addressHeadingPerson"{% if form.vars.data.invoiceToCompany %} hidden{% endif %}>Adresa bydliště</span>
                        <span data-admin-onboarding-form-target="addressHeadingCompany"{% if not form.vars.data.invoiceToCompany %} hidden{% endif %}>Sídlo společnosti</span>
                    </h3>
                    <p class="text-xs text-gray-500 mb-4">Vyžadováno pro účely nájemní smlouvy.</p>
                    <div class="mb-6">
                        {{ addr.render(form) }}
                    </div>

                    <hr class="my-6 border-t border-gray-200">

                    <h3 class="text-lg font-semibold mb-4">Skladová jednotka a pronájem</h3>
                    <div class="grid md:grid-cols-2 gap-4 mb-6">
                        <div class="md:col-span-2">
                            {{ form_label(form.storageId) }}
                            {{ form_widget(form.storageId) }}
                            {{ form_errors(form.storageId) }}
                        </div>
                        <div class="md:col-span-2">
                            {{ form_label(form.rentalType) }}
                            <div class="flex gap-4 mt-1">
                                {% for choice in form.rentalType %}
                                    <label class="flex items-center cursor-pointer gap-2">
                                        {{ form_widget(choice, {'attr': {'class': 'h-4 w-4 text-accent focus:ring-accent border-gray-300'}}) }}
                                        <span class="text-sm text-gray-700">{{ choice.vars.label }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                            {{ form_errors(form.rentalType) }}
                        </div>
                        <div class="md:col-span-2" data-admin-onboarding-form-target="expectedDurationContainer"{% if form.vars.data.rentalType is not null and form.vars.data.rentalType.value != 'unlimited' %} hidden{% endif %}>
                            {{ form_label(form.expectedDuration) }}
                            <div class="flex flex-wrap gap-4 mt-1">
                                {% for choice in form.expectedDuration %}
                                    <label class="flex items-center cursor-pointer gap-2">
                                        {{ form_widget(choice, {'attr': {'class': 'h-4 w-4 text-accent focus:ring-accent border-gray-300'}}) }}
                                        <span class="text-sm text-gray-700">{{ choice.vars.label }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                            {{ form_errors(form.expectedDuration) }}
                            <p class="mt-1 text-xs text-gray-500">Jen pro pronájem na dobu neurčitou. Informativní údaj pro provozovatele.</p>
                        </div>
                        <div>
                            {{ form_label(form.startDate) }}
                            {{ form_widget(form.startDate) }}
                            {{ form_errors(form.startDate) }}
                        </div>
                        <div data-admin-onboarding-form-target="endDateContainer"{% if form.vars.data.rentalType is null or form.vars.data.rentalType.value != 'limited' %} hidden{% endif %}>
                            {{ form_label(form.endDate) }}
                            {{ form_widget(form.endDate) }}
                            {{ form_errors(form.endDate) }}
                            <p class="mt-1 text-xs text-gray-500">Pouze pro dobu určitou.</p>
                        </div>
                    </div>

                    <hr class="my-6 border-t border-gray-200">

                    <h3 class="text-lg font-semibold mb-4">Smlouva a externí platba</h3>
                    <div class="grid md:grid-cols-2 gap-4 mb-6">
                        <div class="md:col-span-2">
                            {{ form_label(form.contractDocument) }}
                            {{ form_widget(form.contractDocument) }}
                            {{ form_errors(form.contractDocument) }}
                            <p class="mt-1 text-xs text-gray-500">Nahrajte sken podepsané smlouvy (PDF, JPEG nebo PNG, max 10 MB).</p>
                        </div>
                        <div>
                            {{ form_label(form.totalPriceInCzk) }}
                            {{ form_widget(form.totalPriceInCzk) }}
                            {{ form_errors(form.totalPriceInCzk) }}
                            <p class="mt-1 text-xs text-gray-500">{{ form.totalPriceInCzk.vars.help }}</p>
                        </div>
                        <div>
                            {{ form_label(form.paidAt) }}
                            {{ form_widget(form.paidAt) }}
                            {{ form_errors(form.paidAt) }}
                        </div>
                        <div>
                            {{ form_label(form.paidThroughDate) }}
                            {{ form_widget(form.paidThroughDate) }}
                            {{ form_errors(form.paidThroughDate) }}
                            <p class="mt-1 text-xs text-gray-500">{{ form.paidThroughDate.vars.help }}</p>
                        </div>
                    </div>

                    <hr class="my-6 border-t border-gray-200">

                    <h3 class="text-lg font-semibold mb-4">Cenový model pro budoucí měsíční platby</h3>
                    <div class="mb-6 space-y-3">
                        {% for choice in form.monthlyPriceMode %}
                            <label class="flex items-center cursor-pointer gap-3">
                                {{ form_widget(choice, {'attr': {'class': 'h-4 w-4 text-accent focus:ring-accent border-gray-300'}}) }}
                                <span class="text-sm text-gray-700">{{ choice.vars.label }}</span>
                            </label>
                        {% endfor %}
                        {{ form_errors(form.monthlyPriceMode) }}

                        <div>
                            {{ form_label(form.customMonthlyPriceInCzk) }}
                            {{ form_widget(form.customMonthlyPriceInCzk) }}
                            {{ form_errors(form.customMonthlyPriceInCzk) }}
                            {% if form.customMonthlyPriceInCzk.vars.help is defined %}
                                <p class="mt-1 text-xs text-gray-500">{{ form.customMonthlyPriceInCzk.vars.help }}</p>
                            {% endif %}
                        </div>

                        <p class="text-xs text-gray-500">Po vypršení externího předplatného bude zákazníkovi 7 dní předem zaslán e-mail s žádostí o nastavení automatické platby.</p>
                    </div>

                    <hr class="my-6 border-t border-gray-200">

                    <h3 class="text-lg font-semibold mb-4">Frekvence a způsob následných plateb</h3>

                    <div class="mb-6" data-admin-onboarding-form-target="paymentFrequencyContainer" hidden>
                        {{ form_label(form.paymentFrequency) }}
                        <div class="flex flex-wrap gap-4 mt-1">
                            {% for choice in form.paymentFrequency %}
                                <label class="flex items-center cursor-pointer gap-2">
                                    {{ form_widget(choice, {'attr': {
                                        'class': 'h-4 w-4 text-accent focus:ring-accent border-gray-300',
                                        'data-admin-onboarding-form-target': choice.vars.value == 'yearly' ? 'paymentFrequencyYearly' : 'paymentFrequencyMonthly',
                                    }}) }}
                                    <span class="text-sm text-gray-700">{{ choice.vars.label }}</span>
                                </label>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.paymentFrequency) }}
                        <p class="mt-1 text-xs text-gray-500">{{ form.paymentFrequency.vars.help }}</p>
                    </div>

                    <div class="mb-6 bg-blue-50 border border-blue-200 rounded-lg p-4" data-admin-onboarding-form-target="yearlyNotice" hidden>
                        <p class="text-sm text-blue-900">
                            <strong>Roční platba se vždy odbavuje ručně.</strong>
                            Kartu si neukládáme — další platbu odešleme e-mailem před vypršením roku.
                        </p>
                    </div>

                    <div class="mb-6" data-admin-onboarding-form-target="billingModeContainer" hidden>
                        {{ form_label(form.billingMode) }}
                        <div class="space-y-2 mt-1">
                            {% for choice in form.billingMode %}
                                <label class="flex items-start cursor-pointer gap-3">
                                    {{ form_widget(choice, {'attr': {
                                        'class': 'h-4 w-4 mt-0.5 text-accent focus:ring-accent border-gray-300',
                                        'data-admin-onboarding-form-target': choice.vars.value == 'auto_recurring' ? 'billingModeAuto' : (choice.vars.value == 'manual_recurring' ? 'billingModeManual' : ''),
                                    }}) }}
                                    <span class="text-sm text-gray-700">{{ choice.vars.label }}</span>
                                </label>
                            {% endfor %}
                        </div>
                        {{ form_errors(form.billingMode) }}
                        <p class="mt-1 text-xs text-gray-500">{{ form.billingMode.vars.help }}</p>
                    </div>

                    <div class="flex justify-end gap-2">
                        <a href="{{ path('admin_onboarding') }}" class="btn btn-ghost">Zrušit</a>
                        <button type="submit" class="btn btn-primary">Migrovat zákazníka</button>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}
