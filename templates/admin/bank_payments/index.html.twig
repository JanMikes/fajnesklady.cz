{% extends 'portal/layout.html.twig' %}

{% block title %}Bankovní platby - Admin{% endblock %}

{% block breadcrumb %}
    {% include 'components/breadcrumb.html.twig' with {breadcrumb_items: [
        {label: 'Bankovní platby'},
    ]} %}
{% endblock %}

{% block content %}
    <h1 class="text-3xl font-bold mb-6">Bankovní platby</h1>

    <div class="flex gap-2 mb-6 flex-wrap">
        <a href="{{ path('admin_bank_payments') }}" class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium {{ filter == 'all' ? 'bg-gray-800 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' }}">
            Vše
        </a>
        <a href="{{ path('admin_bank_payments', {filter: 'unmatched'}) }}" class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium {{ filter == 'unmatched' ? 'bg-amber-600 text-white' : 'bg-amber-50 text-amber-700 hover:bg-amber-100' }}">
            Nespárované{% if unmatchedCount > 0 %} ({{ unmatchedCount }}){% endif %}
        </a>
        <a href="{{ path('admin_bank_payments', {filter: 'matched'}) }}" class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium {{ filter == 'matched' ? 'bg-green-600 text-white' : 'bg-green-50 text-green-700 hover:bg-green-100' }}">
            Spárované
        </a>
        <a href="{{ path('admin_bank_payments', {filter: 'amount_mismatch'}) }}" class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium {{ filter == 'amount_mismatch' ? 'bg-red-600 text-white' : 'bg-red-50 text-red-700 hover:bg-red-100' }}">
            Nesouhlasí částka
        </a>
    </div>

    {% if transactions is empty %}
        <div class="bg-gray-50 rounded-lg p-8 text-center text-gray-500">
            Žádné bankovní transakce k zobrazení.
        </div>
    {% else %}
    <div class="card">
        <div class="card-header bg-gray-50 px-4 py-3 border-b">
            <span class="text-sm text-gray-600">Zobrazeno {{ transactions|length }} transakcí</span>
        </div>
        <div class="overflow-x-auto">
            <table class="table table-zebra text-sm">
                <thead>
                    <tr>
                        <th>Datum</th>
                        <th>Částka</th>
                        <th>VS</th>
                        <th>Odesílatel</th>
                        <th>Účet</th>
                        <th>Stav</th>
                        <th>Objednávka</th>
                    </tr>
                </thead>
                <tbody>
                    {% for tx in transactions %}
                    <tr>
                        <td class="text-gray-900 whitespace-nowrap">{{ tx.transactionDate|date('d.m.Y') }}</td>
                        <td class="text-gray-900 whitespace-nowrap">{{ (tx.amount / 100)|number_format(0, ',', ' ') }} Kč</td>
                        <td class="text-gray-500 whitespace-nowrap">{{ tx.variableSymbol ?? '—' }}</td>
                        <td class="text-gray-900">{{ tx.senderName ?? '—' }}</td>
                        <td class="text-gray-500 whitespace-nowrap">{{ tx.senderAccountNumber ?? '—' }}</td>
                        <td class="whitespace-nowrap">
                            {% if tx.status == 'matched' %}
                                <span class="badge badge-success">Spárováno</span>
                            {% elseif tx.status == 'unmatched' %}
                                <span class="badge badge-warning">Nespárováno</span>
                            {% elseif tx.status == 'amount_mismatch' %}
                                <span class="badge badge-error">Nesouhlasí částka</span>
                            {% elseif tx.status == 'ignored' %}
                                <span class="badge badge-ghost">Ignorováno</span>
                            {% endif %}
                        </td>
                        <td class="text-gray-500 whitespace-nowrap">
                            {% if tx.pairedOrder %}
                                <a href="{{ path('admin_order_detail', {id: tx.pairedOrder.id}) }}" class="link">
                                    {{ tx.pairedOrder.id|slice(0, 8)|upper }}
                                </a>
                            {% else %}
                                —
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
{% endblock %}
