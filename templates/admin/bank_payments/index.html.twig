{% extends 'portal/layout.html.twig' %}

{% block title %}Bankovní platby - Admin{% endblock %}

{% block breadcrumb %}
    {% include 'components/breadcrumb.html.twig' with {breadcrumb_items: [
        {label: 'Bankovní platby'},
    ]} %}
{% endblock %}

{% block content %}
    <h1 class="text-3xl font-bold mb-6">Bankovní platby</h1>

    <div class="flex gap-2 mb-6 flex-wrap">
        <a href="{{ path('admin_bank_payments') }}" class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium {{ filter == 'all' ? 'bg-gray-800 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' }}">
            Vše
        </a>
        <a href="{{ path('admin_bank_payments', {filter: 'unmatched'}) }}" class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium {{ filter == 'unmatched' ? 'bg-amber-600 text-white' : 'bg-amber-50 text-amber-700 hover:bg-amber-100' }}">
            Nespárované{% if unmatchedCount > 0 %} ({{ unmatchedCount }}){% endif %}
        </a>
        <a href="{{ path('admin_bank_payments', {filter: 'matched'}) }}" class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium {{ filter == 'matched' ? 'bg-green-600 text-white' : 'bg-green-50 text-green-700 hover:bg-green-100' }}">
            Spárované
        </a>
        <a href="{{ path('admin_bank_payments', {filter: 'amount_mismatch'}) }}" class="inline-flex items-center px-3 py-1.5 rounded-full text-sm font-medium {{ filter == 'amount_mismatch' ? 'bg-red-600 text-white' : 'bg-red-50 text-red-700 hover:bg-red-100' }}">
            Nesouhlasí částka
        </a>
    </div>

    {% if transactions is empty %}
        <div class="bg-gray-50 rounded-lg p-8 text-center text-gray-500">
            Žádné bankovní transakce k zobrazení.
        </div>
    {% else %}
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Datum</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Částka</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">VS</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Odesílatel</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Účet</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Stav</th>
                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Objednávka</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                {% for tx in transactions %}
                <tr class="hover:bg-gray-50">
                    <td class="px-4 py-3 text-sm text-gray-900 whitespace-nowrap">{{ tx.transactionDate|date('d.m.Y') }}</td>
                    <td class="px-4 py-3 text-sm text-gray-900 whitespace-nowrap">{{ (tx.amount / 100)|number_format(0, ',', ' ') }} Kč</td>
                    <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap">{{ tx.variableSymbol ?? '—' }}</td>
                    <td class="px-4 py-3 text-sm text-gray-900">{{ tx.senderName ?? '—' }}</td>
                    <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap">{{ tx.senderAccountNumber ?? '—' }}</td>
                    <td class="px-4 py-3 text-sm whitespace-nowrap">
                        {% if tx.status == 'matched' %}
                            <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-green-100 text-green-800">Spárováno</span>
                        {% elseif tx.status == 'unmatched' %}
                            <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-amber-100 text-amber-800">Nespárováno</span>
                        {% elseif tx.status == 'amount_mismatch' %}
                            <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-red-100 text-red-800">Nesouhlasí částka</span>
                        {% elseif tx.status == 'ignored' %}
                            <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 text-gray-600">Ignorováno</span>
                        {% endif %}
                    </td>
                    <td class="px-4 py-3 text-sm text-gray-500 whitespace-nowrap">
                        {% if tx.pairedOrder %}
                            <a href="{{ path('admin_orders_detail', {id: tx.pairedOrder.id}) }}" class="text-indigo-600 hover:text-indigo-900">
                                {{ tx.pairedOrder.id|slice(0, 8)|upper }}
                            </a>
                        {% else %}
                            —
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}
{% endblock %}
